lex-start;\n            gap: 10px;\n        }\n        ${popupCheckbox} {\n            width: 20px;\n            height: 20px;\n            margin: 0;\n            cursor: pointer;\n            flex-shrink: 0;\n            margin-top: 2px;\n            border: 2px solid #e0e0e0;\n            border-radius: 4px;\n            background-color: #fff;\n            appearance: none;\n            -webkit-appearance: none;\n            position: relative;\n            transition: all 0.2s ease;\n        }\n        ${popupCheckbox}:checked {\n            background-color: #fff;\n            border-color: #bdc4d0;\n        }\n        ${popupCheckbox}:checked::after {\n            content: '✓';\n            position: absolute;\n            top: 33%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            color: #fd6728;\n            font-size: 24px;\n            font-weight: bold;\n        }\n        ${popupCheckbox}:hover {\n            border-color: #fd6728;\n        }\n        ${popupCheckboxLabel} {\n            font-size: 14px;\n            font-weight: 400;\n            color: #343C4B;\n            cursor: pointer;\n            user-select: none;\n        }\n        ${popupCheckboxLabel} strong {\n            color: #2b69db;\n        }\n        /* OPT-200885 END */\n        ${popupConfirmButton} {\n            background-color: #fd6728;\n            color: #fff;\n            font-size: 16px;\n            font-weight: 400;\n            padding: 10px 20px;\n            border-radius: 5px;\n            cursor: pointer;\n            user-select: none;\n            /* OPT-200885 START */\n            transition: background-color 0.3s ease;\n            width: 100%;\n            text-align: center;\n            font-weight: 700; /* OPT-215909 */\n        }\n        ${popupConfirmButtonDisabled} {\n            background-color: #BDC4D0;\n            cursor: not-allowed;\n            pointer-events: none;\n        }\n        ${noAction} {\n          