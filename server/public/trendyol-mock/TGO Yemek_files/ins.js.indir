:'newcomer promo pack banner',targetColumn:'store_id',targetValue:storeId};self.storeIdChecker(`https://falcon.useinsider.com/partnertrendyol/v1/sheet-data?sheet_name=${hourlySheetName}&page_name=${hourlyPageName}&target_column=${targetColumn}&target_value=${targetValue}`,()=>{self.invokeCampaignExternalMethod('CreateMenuButton198199');self.invokeCampaignExternalMethod('CreatePackages216935',['/meal/bulletin'],true);self.invokeCampaignExternalMethod('CreateGreenBar198199',['advert-management/budget']);self.invokeCampaignExternalMethod('CreateHellobar198199',['/meal/promotions/\\\\d+/dashboard'])});self.storeIdChecker(`https://falcon.useinsider.com/partnertrendyol/v1/sheet-data?sheet_name=${hourlySheetName}&page_name=${pageNameBanner}&target_column=${targetColumn}&target_value=${targetValue}`,()=>{self.invokeCampaignExternalMethod('CreateHellobar198199',['/meal/\\\\d+/order'])})};self.storeIdChecker=(url,existCallback)=>{Insider.request.get({url:url,success:response=>{if(response?.data?.is_exists){if(!Insider.campaign.isControlGroup(variationId)){existCallback()}if(!isVisible){isVisible=true;Insider.campaign.custom.show(variationId)}}else{Insider.logger.log(`User store id is not exists! - ${variationId}`)}},error:()=>{Insider.logger.log(`Error: Falcon request failed! - ${variationId}`)},parse:true})};self.invokeCampaignExternalMethod=(functionName,parameters=[],isExactMatch=false)=>{if(Insider.fns.isFunction(Insider.__external[functionName])){if(!parameters.length||parameters.every(parameter=>self.checkUrlMatch(parameter,isExactMatch))){Insider.__external[functionName](variationId,builderId)}}else{Insider.logger.log(`Insider.__external.${functionName} is not a function`)}};self.checkUrlMatch=(pattern,isExactMatch)=>{const currentPath=window.location.pathname;if(pattern.startsWith('/')&&pattern.includes('\\\\d+')){const regex=new RegExp(pattern);return regex.test(currentPath)}if(isExactMatch){return currentPath===pattern}return Insider.fns.hasParameter(pattern)};self.init()})({});",relationalRule:[],isRelational:!1},804:{test:'window.location.href.indexOf("meal")>-1&&window.location.href.indexOf("order/list")>-1&&Insider.rules.call("30",794)===true&&(Insider.rules.call("818",794)===true&&Insider.rules.call("817",794)===true);',relationalRule:[30,818,817],isRelational:!1},808:{test:"Insider.__external.CreateHellobar198199=variationId=>{'use strict';const self={};const config={imageUrl:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/Hello-bar-wbackground-1766432137.png',redirectUrl:'https://partner.tgoyemek.com/meal/bulletin',title:'Hızlı Başlangıç Paketleri\\'ni Şimdi Keşfet !',buttonText:'Paketleri İncele',context:{firstLine:'Restoranınızın GO\\'daki ilk 30 günü için özel indirimler sizi bekliyor.',secondLine:'Reklam ve indirim kombinasyonları ile siparişlerinizi 5 kata kadar artırma şansı yakalayın.'}};const hellobarClickStorageName=`ins-hellobar-click-${variationId}`;const classes={style:`ins-custom-hellobar-style-${variationId}`,wrapper:`ins-custom-hellobar-wrapper-${variationId}`,container:`ins-custom-hellobar-container-${variationId}`,image:`ins-custom-hellobar-image-${variationId}`,content:`ins-custom-hellobar-content-${variationId}`,title:`ins-custom-hellobar-title-${variationId}`,context:`ins-custom-hellobar-context-${variationId}`,firstLine:`ins-custom-hellobar-first-line-${variationId}`,secondLine:`ins-custom-hellobar-second-line-${variationId}`,button:`ins-custom-hellobar-button-${variationId}`,goal:`sp-custom-${variationId}-1`};const selectors=Insider.fns.keys(classes).reduce((createdSelector,key)=>(createdSelector[key]=`.${classes[key]}`,createdSelector),{appendLocation:'#app-wrapper'});self.init=()=>{self.reset();self.buildCSS();self.buildHTML();self.setEvents();self.sendHellobarImpression()};self.reset=()=>{const{style,wrapper}=selectors;Insider.dom(`${style}, ${wrapper}`).remove()};self.buildCSS=()=>{const{wrapper,container,image,content,title,context,button,firstLine,secondLine}=selectors;const customStyle=`${wrapper} {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            padding: 15px 1%;\n            background: #E8FFEA;\n            min-height: 80px;\n            cursor: pointer;\n            text-decoration: none !important;\n            color: unset !important;\n        }\n        ${container} {\n            display: grid;\n            grid-template-columns: auto 1fr auto;\n            grid-template-areas: \"image content button\";\n            align-items: center;\n            justify-content: space-between;\n            gap: 15px;\n            width: 100%;\n            height: 100%;\n        }\n        ${image} {\n            grid-area: image;\n            width: 130px;\n            height: 70px;\n            object-fit: contain;\n            flex-shrink: 0;\n        }\n        ${content} {\n            grid-area: content;\n            display: flex;\n            flex-direction: column;\n            gap: 2px; /* OPT-215909 */\n            min-width: 0;\n        }\n        ${title} {\n            font-size: 20px; /* OPT-215909 */\n            font-weight: 600;\n            color: #333;\n            margin: 0;\n            line-height: 1.2;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n            font-family: 'Rubik Variable';\n        }\n        ${context} {\n            display: flex;\n            flex-direction: column;\n            gap: 3px;\n            font-size: 13px;\n            color: #3a3a3a;\n            line-height: 1.3;\n            margin-left: 30px;\n            list-style: disc;\n        }\n        ${context} div {\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n            font-size: 18px; /* OPT-215909 */\n        }\n        ${button} {\n            grid-area: button;\n            color: white;\n            /* OPT-200885 START */\n            background: #3AC96B;\n            padding: 20px 45px; /* OPT-215909 */\n            border-radius: 8px;\n            /* OPT-200885 END */\n            font-weight: 600;\n            font-size: 13px;\n            text-decoration: none;\n            transition: background-color 0.3s ease;\n            white-space: nowrap;\n            flex-shrink: 0;\n        }\n        ${firstLine} {\n            font-family: 'Rubik Variable';\n        }\n        ${secondLine} {\n            font-family: 'Rubik Variable';\n        }\n        ${button}:hover {\n            background: #3AC96B;\n        }\n        /* OPT-200274 START */\n        @media (max-width: 768px) {\n            ${wrapper} {\n                padding: 10px 0.5%;\n                min-height: 70px;\n            }\n            ${container} {\n                grid-template-columns: 60px 1fr auto;\n                gap: 10px;\n            }\n            ${image} {\n                width: 60px;\n                height: 60px;\n            }\n            ${title} {\n                font-size: 14px;\n            }\n            ${context} {\n                font-size: 11px;\n            }\n            ${button} {\n                padding: 8px 16px;\n                font-size: 12px;\n            }\n        }\n        /* OPT-200274 END */`;Insider.dom('<style>').addClass(classes.style).html(customStyle).appendTo('head')};self.buildHTML=()=>{const{wrapper,container,image,content,title,context,firstLine,secondLine,button,goal}=classes;const{imageUrl,title:titleText,buttonText,context:{firstLine:firstLineText,secondLine:secondLineText}}=config;const outerHtml=`<a class=\"${wrapper} ${goal}\">\n            <div class=\"${container}\">\n                <img class=\"${image}\" src=\"${imageUrl}\"/>\n                <div class=\"${content}\">\n                    <h3 class=\"${title}\">${titleText}</h3>\n                    <ul class=\"${context}\">\n                        \x3c!-- OPT-200274 START --\x3e\n                        <li class=\"${firstLine}\">${firstLineText}</li>\n                        <li class=\"${secondLine}\">${secondLineText}</li>\n                        \x3c!-- OPT-200274 END --\x3e\n                    </ul>\n                </div>\n                <div class=\"${button}\">${buttonText}</div>\n            </div>\n        </a>`;Insider.fns.onElementLoaded(selectors.appendLocation,$appendLocation=>{$appendLocation.before(outerHtml)}).listen()};self.setEvents=()=>{const{wrapper}=selectors;Insider.eventManager.once(`click.hellobar:${variationId}`,wrapper,()=>{self.sendHellobarClick()},true)};self.sendHellobarImpression=()=>{Insider.__external.sendGAEvent198199({eventName:'hellobar_impression',category:'Newcomer_Packages',action:'Banner_Impression',label:`Hellobar_${variationId}`,value:1})};self.sendHellobarClick=()=>{Insider.storage.localStorage.set({name:hellobarClickStorageName,value:true,expires:30});setTimeout(()=>{window.location.href=config.redirectUrl},500)};self.init()};true;",relationalRule:[],isRelational:!1},813:{test:'Insider.__external.standardPackageContent198199=()=>`\n\x3c!-- OPT-215909 START --\x3e\n    <div id="package-conditions"><strong>STANDART  PAKET KATILIM KOŞULLARI</strong></div>\x3c!-- OPT-200885 --\x3e\n    \n    <strong>STANDART PAKET KAPSAMINDA REKLAM BAKİYESİ TANIMLAMA</strong>\n    \nSatıcı mağazasına, Satıcı’nın “Standart Paket” onay metnini kabul edip, 2.100 TL tutarındaki reklam bakiyesini ayrıca yüklemesini takiben 3.000 TL’lik reklam bakiyesi tanımlanır. 2100 TL ve katlarında yapılacak reklam bakiyesi yüklemelerinde, tek seferlik 3000 TL’lik reklam bakiyesi tanımlanır. Reklam oluşturma işlemi mağaza bazlı olup, satıcının dilediği mağazalarında bakiye yükleyerek reklam oluşturması mümkündür. \nOtomatik olarak, bakiye yüklenen tarihten 45 gün sonrasına kadar sürecek şekilde reklam oluşturulur. Bu süre reklamın geçerli olabileceği maksimum süredir, bütçe harcama hızına bağlı olarak reklam bu süreden daha önceki bir tarihte sona erebilecektir. Satıcı’nın birden fazla mağazası için Reklam Yönetimi sayfasında herhangi bir şekilde reklam başlatmış olması halinde, yüklenen toplam bakiye satıcının reklam veren tüm  mağazaları  için geçerli olacak toplam bakiyeyi oluşturur.  Bu durumda Hızlı Başlangıç Paketleri kapsamında açılan yeni reklam 45 günlük süreden daha erken bir sürede sonuçlanabilir. Satıcı bakiye yükleme ekranından bakiye takviyesi yaparak reklamını devam ettirebilir.\nReklam oluşturma işlemi, Hızlı Başlangıç Paketini onaylayan mağazanın bakiye yüklemesini takip eden 1 günlük süre 4. maddede düzenlenen koşullarda yeni bir reklam oluşturulması ile olur. Bu süre içinde, herhangi bir şekilde, ilgili mağazanın dahil olduğu bir aktif reklam olması halinde paket kapsamında reklam açma işlemi yapılmaz. Satıcı yüklediği bakiyesi ile aktif reklamı sonlanınca kendisi yeni bir reklam açabilir.\nBütçe tipi “Günlük” olarak seçilir. Günlük bütçe 300 TL olarak seçilir. Bu durumda satıcı 3.000 TL’lik reklam bakiyesini maksimum 45 gün içerisinde günlük maksimum 300 TL hedeflenerek reklam bakiyesi bitene kadar kullanır.\nHızlı Başlangıç Paketi kapsamında tanımlanan reklamlarda, tıklama başına maliyet dinamik olacak şekilde TYG Turkey tarafından belirlenir.  \nSatıcı dilediği zaman reklam kullanımını durdurabilir.\nBelirtilen şartlar dışında, aşağıda yer verilen Reklam Hizmeti Kullanım Koşulları da geçerli olacaktır. \n\nB. REKLAM HİZMETİ KULLANIM KOŞULLARI \n\nİşbu Reklam Hizmeti Kullanım Koşulları (“Kullanım Koşulları”), Satıcı’nın, Satıcı Paneli’nde bulunan Reklam Yönetimi sayfasında, işbu Kullanım Koşulları’nda tanımlanan anlamıyla herhangi bir İşlem  yapması halinde geçerli olacak şart ve koşulları düzenlemektedir. \nReklam Bakiyesi Yükleme \nSatıcının reklam oluşturabilmesi için öncelikle reklam bakiyesi yüklemesi gerekmektedir. İstenilen tutarda reklam bakiyesi yüklenebilmekte olup, tek seferde en fazla 10.000.000 TL (on milyon türk lirası) reklam bakiyesi yüklemek mümkündür. \nYüklenen reklam bakiyesinin ödemesi iki şekilde yapılabilir: \nHesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür)\nYüklenen reklam bakiyesinin tutarı kredi kartı ile ödenebilir. \nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, reklam bakiyesi yüklendiği anda yüklenen bakiye tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez. \nAksi duyurulmadığı müddetçe, yüklenen reklam bakiyelerinin herhangi bir son kullanım tarihi bulunmamaktadır. Yüklenen bakiye tüketilene kadar kullanılabilir. \nSatıcıların tercih etmeleri halinde otomatik reklam bakiyesi yükleme talimatı vermeleri de mümkündür. Bu talimatı vermekle satıcı, mevcut reklam bakiyesinin kendisi tarafından belirlenen tutarın altına düştüğü her sefer için, belirlemiş olduğu tutarın otomatik olarak reklam bakiyesine aktarılmasını kabul eder. Otomatik reklam bakiyesi yükleme talimatı neticesinde yapılan yüklemelerin faturalanması ve ödenmesi bakımından işbu Kullanım Şartları’nda düzenlenen şart ve koşullar geçerli olacaktır. Satıcı, vermiş olduğu otomatik reklam bakiyesi yükleme talimatını her zaman Reklam Yönetimi sayfası altından iptal edebilir. \nTYG Turkey tarafından zaman zaman belirli kural setlerine uygun olarak belirlenebilecek satıcı gruplarına çeşitli reklam bakiyesi kampanyaları sunulabilecektir. Bu kampanyalar “Bakiye Satın Al” sayfası altından incelenebilir. TYG Turkey tarafından başlatılan reklam bakiyesi kampanyalarından yararlanmak isteyen satıcılar, kampanya kapsamında TYG Turkey tarafından karşılanacağı duyurulan tutarın düşürülmesi neticesinde kalan bakiyeyi ödeyerek reklam bakiyesi yükleyebilecektir. (Örneğin, TYG Turkey tarafından 2000 TL’lik reklam bakiyesi yüklemelerinin, 225 TL’sinin TYG Turkey tarafından karşılanacağı duyurulmuşsa, satıcı 1775 TL tutarında ödeme yaparak 2000 TL’lik reklam bakiyesi yükleyebilecektir.) \nHediye Bakiye\nHediye Bakiye sayfasından, TYG Turkey tarafından satıcılara karşılıksız olarak yüklenebilecek hediye reklam bakiye tutarlarına erişilebilir. TYG Turkey, hediye bakiyelere son kullanım tarihi belirleyebilir, son kullanım tarihinin belirlenmesi halinde, bu tarihe kadar kullanılmayan reklam bakiyeleri geçerliliğini kaybeder. \nReklam Oluşturma\nSatıcı reklam oluşturabilmek için Reklam Oluşturma Sayfası üzerinden, reklamına bir ad verip, reklamın geçerli olacağı tarih aralığını belirler. Satıcı tarafından belirlenen reklam adı müşterilere gözükmeyecek olup, satıcının raporlamalarında reklam metriklerini takip edebilmesi amacıyla kullanılır. \nSiparişlerinin teslimatının Satıcı tarafından yapıldığı model ile çalışan satıcılar, ayrıca reklamların gözükeceği dağıtım bölgelerini tercih edebilir. \nSatıcı tüm veya belirli şubeleri özelinde reklam başlatabilir. Bunun için reklamın geçerli olacağı şubeleri tanımlaması gerekir. \nSatıcı tarafından reklam harcamaları için günlük bütçe tutarı ve tıklama başına maliyet belirlenmelidir. Minimum 300 TL olmak kaydıyla, Satıcı tarafından belirlenen günlük bütçe her gün satıcının yüklemiş olduğu reklam bakiyesinden çekilir. Tıklama başına maliyet, kullanıcıların satıcı tarafından başlatılan reklama her tıkladığında günlük bütçeden çekilecek tutara karşılık gelmekte olup, belirlenebilecek minimum tıklama başına maliyet 9 TL iken, maksimum tıklama başına maliyet 20 TL’dir. İşbu madde 29.06.2026 tarihi itibariyle hükümsüz olup, aşağıdaki şekilde uygulanacaktır: “Satıcı tarafından reklam harcamaları için günlük bütçe tutarı ve tıklama başına maliyet belirlenmelidir. Minimum 300 TL olmak kaydıyla, Satıcı tarafından belirlenen günlük bütçe her gün satıcının yüklemiş olduğu reklam bakiyesinden çekilir. Tıklama başına maliyet, kullanıcıların satıcı tarafından başlatılan reklama her tıkladığında günlük bütçeden çekilecek tutara karşılık gelmekte olup, belirlenebilecek minimum tıklama başına maliyet 9 TL iken, maksimum tıklama başına maliyet 25 TL’dir.”\nSatıcı ayrıca seçtiği belirli bir tarih aralığı için geçerli olacak toplam bütçeyi ve tıklama başına maliyeti belirleyip, belirlemiş olduğu toplam bütçenin reklamının geçerli olacağı tarih içindeki dağılımını TYG Turkey tarafından yapılmasını da tercih edebilir. Satıcının bu tercihte bulunması, herhangi bir şekilde satıcıya sıralanma/listeleme garantisi veya bütçenin seçilen tarih aralığında kısmen/tamamen harcanılacağı taahhüdü vermemektedir. \nTYG Turkey tarafından zaman zaman satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, reklam bakiyesi yükleyen satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder. \nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Kullanım Koşullarının tüm hükümlerini ve reklam oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\nAbonelik Sistemi \nSatıcılar oluşturdukları reklamların işbu Abonelik Sistemi Şart ve Koşulları uyarınca, satıcının sonradan aboneliklerini sonlandırmayı tercih edecekleri tarihe kadar sürekli olarak yenilenmesini tercih edebilir. \nAbonelik oluşturabilmek için satıcının öncelikle ilgili sayfada kendisine TYG Turkey tarafından önerilen reklam paketlerinden birini tercih etmesi ya da tarih, bütçe, tıklama başına maliyet, şube tercihlerini yaparak şart ve koşullarını kendisinin belirlediği bir reklam oluşturması gerekmektedir. Satıcı, TYG Turkey tarafından oluşturulan reklam paketlerini paket kapsamında satıcıya önerilen bütçe, tarih, tıklama başına maliyet, şube seçeneklerini de özelleştirerek reklam oluşturma imkanına sahiptir. TYG Turkey tarafından satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, satıcı dilerse reklamını oluştururken tıklama başına maliyetin TYG Turkey tarafından belirlenmesini tercih edebilir. \nSatıcının abonelik sistemini başlatması halinde, satıcının oluşturduğu reklam, ilgili reklamın bitiş tarihinin dolması üzerine, reklamın geçerli olduğu dönem uzunluğunda tekrar etmeye devam eder. Örneğin, satıcının başlangıçta 7 günlük bir reklam oluşturması ve bu reklamla birlikte abonelik sistemine geçmesi halinde, 7 günlük reklam süresinin dolması üzerine, oluşturulan reklam satıcının tercih etmiş olduğu bütçe, tıklama başına maliyet ve şube tercihleri ile birlikte 7’şer günlük dönemlerde devam etmeye devam edecektir. \nSatıcı, Reklam Yönetimi sayfasında yer alan “Abonelik İptal Et” seçeneğini tercih ederek abonelik sisteminden çıkma imkanına sahiptir. Satıcının bu tercihte bulunması halinde, mevcutta geçerli olan reklamının bitiş tarihinin sona ermesi beklenir ve bu tarihin dolması üzerine ilgili reklam yenilenmez. \nAbonelik sistemini başlatmak isteyen satıcının ödemeleri iki şekilde yapılabilir:\nHesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür. Şüpheye mahal vermemek adına, satıcının tercih etmiş olduğu reklam bütçesinin içeride bulunan ve ancak henüz ödemesi Satıcıya yapılmamış hakediş tutarından fazla olması halinde satıcı bu opsiyon uyarınca ödeme gerçekleştiremeyecek ve abonelik başlatamayacaktır.)\nSatıcının reklam cüzdanında yeterli bakiye olması halinde, ödemeler reklam cüzdanından düşülür.\nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, yapılan ödeme tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez.\nReklam oluşturan satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder.  \n\nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Abonelik Sistemi Şart ve Koşullarının tüm hükümlerini ve reklam oluşturma/abonelik oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\nDiğer Hükümler\nReklam Yönetimi sekmesine girmeniz, bu sekmede yer alan herhangi bir bilgiyi kullanmanız ve bu sekmede herhangi bir işlem yapmış olmanız (Hepsi birlikte "İşlem" olarak kullanılacaktır) aşağıdaki koşulları kabul ettiğiniz anlamına gelir.\nİşlem yapılması sebebiyle, herhangi bir sözleşmenin ihlali, haksız fiil ya da başkaca sebeplere binaen, doğabilecek doğrudan ya da dolaylı hiçbir zarardan TYG Turkey veya herhangi bir grup şirketi sorumlu değildir. TYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti hususunda herhangi bir sorumluluk kabul etmez.\nTYG Turkey işbu Reklam Yönetimi sekmesi başta olmak üzere, Satıcı Paneli ve uzantısında mevcut her tür hizmet, ürün, uygulamayı kullanma koşulları ile uygulamada sunulan bilgileri önceden bir ihtara gerek olmaksızın değiştirme, uygulamayı yeniden organize etme, yayını durdurma hakkını saklı tutar. Değişiklikler, aksi duyurulmadığı müddetçe, uygulamada yayın anında yürürlüğe girer. İşlem yapılması ile bu değişiklikler de kabul edilmiş sayılır. Bu koşullar link verilen diğer web sayfaları/uygulamalar için de geçerlidir.\nTYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti, silinme, kayıp, işlemin veya iletişimin gecikmesi, bilgisayar virüsü, iletişim hatası, hırsızlık, imha veya izinsiz olarak kayıtlara girilmesi, değiştirilmesi veya kullanılması hususunda herhangi bir sorumluluk kabul etmez.\nReklam Yönetimi alanı/sekmesi TYG Turkey’nin kontrolü altında olmayan başka internet sitelerine / uygulamalara bağlantı veya referans içerebilir. TYG Turkey, bu sitelerin/uygulamaların içerikleri veya içerdikleri diğer bağlantılardan sorumlu değildir.\nTYG Turkey Reklam Yönetimi alanının/sekmesinin genel görünüm ve dizaynı ile alandaki/sekmedeki tüm bilgi, resim, Trendyol Go markası ve diğer markalar, işbu İşlem yapılan uygulama adı, logo, ikon, demonstratif, yazılı, elektronik, grafik veya makinede okunabilir şekilde sunulan teknik veriler, bilgisayar yazılımları, uygulanan satış sistemi, iş metodu ve iş modeli de dahil tüm materyallerin (\\"Materyaller\\") ve bunlara ilişkin fikri ve sınai mülkiyet haklarının sahibi veya lisans sahibidir ve yasal koruma altındadır. Reklam Yönetimi alanında/sekmesinde bulunan hiçbir Materyal; önceden izin alınmadan ve kaynak gösterilmeden, kod ve yazılım da dahil olmak üzere, değiştirilemez, kopyalanamaz, çoğaltılamaz, başka bir lisana çevrilemez, yeniden yayımlanamaz, başka bir bilgisayara yüklenemez, postalanamaz, iletilemez, sunulamaz ya da dağıtılamaz. Reklam Yönetimi alanının/sekmesinin bütünü veya bir kısmı başka bir internet sitesinde/uygulamada izinsiz olarak kullanılamaz. Aksine hareketler hukuki ve cezai sorumluluğu gerektirir. TYG Turkey’nin burada açıkça belirtilmeyen diğer tüm hakları saklıdır.\nTYG Turkey, dilediği zaman bu Kullanım Koşulları sayfasının içeriğini önceden duyurmak kaydıyla, güncelleme yetkisini saklı tutmaktadır ve kullanıcılarına Reklam Yönetimi alanına/sekmesine her girişte ayrıca Kullanım Koşulları sayfasını ziyaret etmelerini tavsiye etmektedir.\n\n\nC. SEPET İNDİRİMİ KAMPANYASI \nSTANDART PAKET KAPSAMINDA MAĞAZANIZIN SEPET İNDİRİMİ  KAMPANYASINA KATILIMI, TURBO PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nSEPET İNDİRİMİ KATILIM KOŞULLARI\nİstanbul, Ankara, İzmir, Bursa, Kocaeli, Antalya, Mersin, Şanlıurfa, Van, Diyarbakır, Bolu, Yalova, Kahramanmaraş, Batman, Uşak, Rize, Mardin, Erzincan, Karaman, Bingöl, Artvin, Bartın, Bitlis illerinde bulunan restoranlar için  kampanya kapsamında verilen, 500 TL ve üzeri siparişlerde 150 TL indirim uygulanır.\nEskişehir, Adana, Konya, Kayseri, Karabük, Erzurum, Osmaniye, Elazığ, Siirt, Gaziantep, Balıkesir, Sakarya, Kırklareli, Bilecik, Hatay, Kars, Ordu, Yozgat, Sinop, Niğde, Giresun illerinde bulunan restoranlar için  kampanya kapsamında verilen, 450 TL ve üzeri siparişlerde 140 TL indirim uygulanır.\nSamsun, Muğla, Aydın, Kütahya, Kilis, Iğdır, Hakkari, Muş, Manisa, Tekirdağ, Denizli, Çanakkale, Edirne, Aksaray, Sivas, Zonguldak, Nevşehir, Tunceli, Trabzon, Ardahan, Malatya, Adıyaman, Amasya, Şırnak, Çorum, Burdur, Kastamonu, Ağrı, Tokat, Isparta, Düzce, Kırşehir, Çankırı, Kırıkkale, Gümüşhane, Bayburt, Afyonkarahisar illerinde bulunan restoranlar için  kampanya kapsamında verilen, 400 TL ve üzeri siparişlerde 125 TL indirim uygulanır.\nİstanbul, Ankara, İzmir, Bursa, Kocaeli, Antalya, Mersin, Şanlıurfa, Van, Diyarbakır, Bolu, Yalova, Kahramanmaraş, Batman, Uşak, Rize, Mardin, Erzincan, Karaman, Bingöl, Artvin, Bartın, Bitlis illerinde bulunan restoranlar bakımından siparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 500 TL\'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 500 TL olması gerekmektedir.\nEskişehir, Adana, Konya, Kayseri, Karabük, Erzurum, Osmaniye, Elazığ, Siirt, Gaziantep, Balıkesir, Sakarya, Kırklareli, Bilecik, Hatay, Kars, Ordu, Yozgat, Sinop, Niğde, Giresun illerinde bulunan restoranlar bakımından siparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 450 TL\'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 450 TL olması gerekmektedir.\nSamsun, Muğla, Aydın, Kütahya, Kilis, Iğdır, Hakkari, Muş, Manisa, Tekirdağ, Denizli, Çanakkale, Edirne, Aksaray, Sivas, Zonguldak, Nevşehir, Tunceli, Trabzon, Ardahan, Malatya, Adıyaman, Amasya, Şırnak, Çorum, Burdur, Kastamonu, Ağrı, Tokat, Isparta, Düzce, Kırşehir, Çankırı, Kırıkkale, Gümüşhane, Bayburt, Afyonkarahisar illerinde bulunan restoranlar bakımından siparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 400 TL\'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 400 TL olması gerekmektedir.\nİndirimin tamamı restoran tarafından karşılanacaktır.\nHerhangi bir kullanıcı bakımından kampanyadan yararlanabilme sınırı (kampanyaya katılma sayısı vb.) bulunmamaktadır.\nKampanya ilk olarak 01 Ocak 2025 tarihinde başlayıp, Uber Eats Trendyol Go tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir. Satıcı vermiş olduğu onayla, kampanya başlangıç tarihinden sonra kampanyadan çıkmadığı müddetçe kampanyanın onay vermiş olduğu mağazasında geçerli olacağını kabul eder. Kampanyaya katılım ve kampanyadan çıkış işlemleri kampanya başlangıç tarihinden sonra herhangi bir zamanda yapılabilir.\nUber Eats Trendyol Go kampanya tarihleri, indirim tutarı, minimum sepet tutarı dahil olmak üzere kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda belirtilen tarihte yürürlüğe girecektir. Kampanyaya katılmış olan restoranlar, kampanyadan çıkmadıkları müddetçe, Uber Eats Trendyol Go tarafından yapılan değişikliklerin yürürlük tarihinden itibaren kendiliğinden geçerli olacağını kabul etmiş olacaktır.\nBu kampanya, Flaş İndirim kampanyası, Yedikçe İndirim, kupon, indirim kodu ve maliyetinin tamamına satıcının katlandığı sepet indirimleri ile birleştirilemez. Maliyetine kısmen satıcının katlandığı veya maliyetine tamamen Uber Eats Trendyol Go’nun katlandığı sepet indirimleri işbu kampanya şartlarında belirtilen sınırlamalara tabi olarak birleştirilebilir.\nAynı anda birden fazla kampanyaya katılmanız halinde indirim miktarı yüksek olan kampanya geçerli olacaktır.\nUber Eats Trendyol Go, kampanya süresinde ve koşullarında değişiklik yapma hakkını saklı tutar.\nİndirime sınırlı sayıda restoran katılabilecek olup, kampanya Uber Eats Trendyol Go tarafından duyurularla desteklenecektir.\nBu kampanyanın tamamı satıcı tarafından karşılanacaktır.\nSatıcının katıldığı bu kampanyaya ek olarak, aynı siparişte kullanıcı için daha avantajlı başka bir kampanya, indirim veya promosyonun da geçerli olması halinde; daha avantajlı olan kampanya, indirim veya promosyonun tutarı üst sınır oluşturmak kaydıyla, işbu kampanya ile diğer kampanya, indirim veya promosyon birleşebilecektir. Satıcı’nın karşılamayı üstlendiği tutar işbu kampanya için kullanılacak olup, birleşen kampanya kapsamında tüketiciye sunulacak ek faydanın maliyeti Uber Eats Trendyol Go tarafından karşılanacaktır.\n\n    \x3c!-- OPT-215909 END --\x3e\n`;true;',relationalRule:[],isRelational:!1},814:{test:'Insider.__external.advantagePackageContent198199=()=>`\n    \x3c!-- OPT-215909 START --\x3e\n    <div id="package-conditions"><strong>AVANTAJ PAKET KATILIM KOŞULLARI</strong></div> \x3c!-- OPT-200885 --\x3e\n    \n    <strong>AVANTAJ PAKET KAPSAMINDA REKLAM BAKİYESİ TANIMLAMA</strong>\n\nSatıcı mağazasına, Satıcı’nın “Avantaj Paket” onay metnini kabul edip, 2.400 TL tutarındaki reklam bakiyesini ayrıca yüklemesini takiben 4.000 TL’lik reklam bakiyesi tanımlanır. 2400 TL ve katlarında yapılacak reklam bakiyesi yüklemelerinde, tek seferlik 4000 TL’lik reklam bakiyesi tanımlanır. Reklam oluşturma işlemi mağaza bazlı olup, satıcının dilediği mağazalarında bakiye yükleyerek reklam oluşturması mümkündür. \nOtomatik olarak, bakiye yüklenen tarihten 45 gün sonrasına kadar sürecek şekilde reklam oluşturulur. Bu süre reklamın geçerli olabileceği maksimum süredir, bütçe harcama hızına bağlı olarak reklam bu süreden daha önceki bir tarihte sona erebilecektir. Satıcı’nın birden fazla mağazası için Reklam Yönetimi sayfasında herhangi bir şekilde reklam başlatmış olması halinde, yüklenen toplam bakiye satıcının reklam veren tüm  mağazaları  için geçerli olacak toplam bakiyeyi oluşturur.  Bu durumda Hızlı Başlangıç Paketleri kapsamında açılan yeni reklam 45 günlük süreden daha erken bir sürede sonuçlanabilir. Satıcı bakiye yükleme ekranından bakiye takviyesi yaparak reklamını devam ettirebilir.\nReklam oluşturma işlemi, Hızlı Başlangıç Paketini onaylayan mağazanın bakiye yüklemesini takip eden 1 günlük süre 4. maddede düzenlenen koşullarda yeni bir reklam oluşturulması ile olur. Bu süre içinde, herhangi bir şekilde, ilgili mağazanın dahil olduğu bir aktif reklam olması halinde paket kapsamında reklam açma işlemi yapılmaz. Satıcı yüklediği bakiyesi ile aktif reklamı sonlanınca kendisi yeni bir reklam açabilir.\nBütçe tipi “Günlük” olarak seçilir. Günlük bütçe 300 TL olarak seçilir. Bu durumda satıcı 4.000 TL’lik reklam bakiyesini maksimum 45 gün içerisinde günlük maksimum 300 TL hedeflenerek reklam bakiyesi bitene kadar kullanır.\nHızlı Başlangıç Paketi kapsamında tanımlanan reklamlarda, tıklama başına maliyet dinamik olacak şekilde TYG Turkey tarafından belirlenir.  \nSatıcı dilediği zaman reklam kullanımını durdurabilir.\nBelirtilen şartlar dışında, aşağıda yer verilen Reklam Hizmeti Kullanım Koşulları da geçerli olacaktır. \nB. PLUS\nAVANTAJ PAKET KAPSAMINDA MAĞAZANIZIN PLUS KATILIMI, AVANTAJ PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nPlus Katılım Şartları\nKullanıcılar her bir takvim ayı boyunca Plus programı kapsamında ulaştıkları seviyenin kupon kazanımına yeterli olması halinde Trendyol veya Uber Eats Trendyol Go uygulamalarında geçerli toplamda her bir takvim ayı için 2 adet olacak şekilde her biri 60 TL tutarında Plus kuponu kazanır. 01.07.2026 tarihinden itibaren bu madde hükümsüz olup, aşağıdaki şekilde uygulanacaktır: “Kullanıcılar her bir takvim ayı boyunca Plus programı kapsamında ulaştıkları seviyenin kupon kazanımına yeterli olması halinde Trendyol veya Uber Eats Trendyol Go uygulamalarında geçerli toplamda her bir takvim ayı için 2 adet olacak şekilde her biri 125 TL tutarında Plus kuponu kazanır.”\nPlus kuponları kullanıcının Plus programı kapsamında ulaştığı seviyeye bağlı olarak kazanılabilir, kazanılan Plus kuponları Plus kampanyasına dahil olmuş restoranlarda (“Plus restoranları”) harcanabilir.\nBir kullanıcı bir siparişte tanımlanan Plus yemek kuponlarından yalnızca bir tanesini kullanabilecektir. Her siparişte 1 kupon kullanılabilecektir. Plus kuponları yalnızca kazanıldıkları takvim ayı içerisinde geçerli olacaktır, bir sonraki takvim ayına devretmez. \nTrendyol ve Uber Eats Trendyol Go uygulamalarında kullanıcılara tanımlanacak 2 adet kupona ek olarak yalnızca Uber Eats Trendyol Go uygulamasını kullanan kullanıcıların faydalanabileceği üçüncü, dördüncü ve beşinci Plus yemek kuponları aktif olacaktır. Bu kuponlar da Plus programı kapsamında kullanıcının ulaştığı seviyeye bağlı olarak tanımlanacak olup, üçüncü kuponun değeri 60 TL; dördüncü ve beşinci kuponların değeri ise sırasıyla 75 TL ve 90 TL olacak, Plus kuponlarının koşullarına tabi olacak ve Plus restoranlarda harcanabilecektir. 01.07.2026 tarihinden itibaren bu madde hükümsüz olup, aşağıdaki şekilde uygulanacaktır: “Trendyol ve Uber Eats Trendyol Go uygulamalarında kullanıcılara tanımlanacak 2 adet kupona ek olarak yalnızca Uber Eats Trendyol Go uygulamasını kullanan kullanıcıların faydalanabileceği üçüncü, dördüncü ve beşinci Plus yemek kuponları aktif olacaktır. Bu kuponlar da Plus programı kapsamında kullanıcının ulaştığı seviyeye bağlı olarak tanımlanacak olup, üçüncü kuponun değeri 175 TL; dördüncü ve beşinci kuponların değeri ise sırasıyla 250 TL ve 300 TL olacak, Plus kuponlarının koşullarına tabi olacak ve Plus restoranlarda harcanabilecektir.”\nSatıcı, kullanılan kupon tutarından bağımsız olarak, kullanıcı tarafından kullanılan ilk üç kupon için, her bir kuponun 60 TL’lik tutarının maliyetini karşılar. Satıcı tarafından karşılanan kısmı aşan kupon tutarlarının maliyeti TYG Turkey tarafından karşılanır. 01.07.2026 tarihinden itibaren bu madde hükümsüz olup, aşağıdaki şekilde uygulanacaktır: “Satıcı, kullanılan kupon tutarından bağımsız olarak, kullanıcı tarafından kullanılan ilk iki kupon için, her bir kuponun 125 TL’lik tutarının maliyetini ve yine kullanılan kupon tutarından bağımsız olarak, kullanıcı tarafından kullanılan üçüncü kuponun 175 TL’lik maliyetini karşılar. Satıcı tarafından karşılanan kısmı aşan kupon tutarlarının maliyeti TYG Turkey tarafından karşılanır.”\nİndirimde karşıladığınız tutar üzerinden komisyon kesintisi yapılmayacaktır.\nKullanıcılar Plus kuponunu diğer kampanyalarla birleştiremez.\nGüncellenen şartlarıyla kampanya belirtilen güncelleme tarihlerinde başlayacak olup, TYG Turkey tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir. \nPlus Yemek Kuponu Kampanyasına katılan restoranlar ana sayfada,  Plus sayfasında, filtrelerde ve birçok farklı alanda listelenecektir.\nKampanya TYG Turkey tarafından duyurular ve reklamlarla desteklenecektir. \nTYG Turkey kampanya tarihleri, kupon adedi, kupon tutarı, kupon maliyetinin kimin tarafından hangi oranda karşılanacağı dahil olmak üzere Plus kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda daha ileri bir tarih belirtilmediği müddetçe duyurunun çıkılmasından 7 gün sonra kendiliğinden yürürlüğe girecektir. Restoran lehine yapılacak değişiklikler duyurunun çıkılmasından 1 gün sonra kendiliğinden yürürlüğe girecektir. \nRestoran vermiş olduğu onay ile Plus kuponlarının maliyetlerini karşılamayı ve restoranında platform üzerinden kazanılmış Plus kuponlarının kullanılabilmesini kabul etmiş olacaktır. Plus kampanyası restoran tarafından kampanyadan çıkılmadığı veya TYG Turkey tarafından iptal edilmediği müddetçe süresiz olarak yürürlükte kalacaktır. \nPlus Yemek Kuponu kampanyasına herhangi bir zamanda katılma ve kampanyadan çıkma hakkı bulunmaktadır. \nKampanya süresince yapacağınız katıl/çık işlemleri, kullanıcı memnuniyeti sebepli uygulamaya 1 saat sonrasında yansıyacaktır.\nTYG Turkey,  Plus programının, Plus kampanya koşullarının ve/veya Platform kullanıcılarının (Satıcı ve Alıcı da dahil)  Plus programı ve/veya Plus kampanya deneyiminin geliştirilmesi ve iyileştirilmesi amaçlarıyla sınırlı olarak ve bu amaçların gerektirdiği ölçüde, Platform kullanıcılarının (Satıcı ve Alıcı da dahil) beklenti, tercih ve davranışlarını tespit etmeye yönelik kullanıcı grupları bazlı veya kullanıcı gruplarına kampanya kapsamında sağlanan menfaatler özelinde satıcıya ilave maliyet yüklemeksizin geçici süreli, mevzuata uygun test uygulamalarını devreye alabilecektir. \nKullanıcının Plus kuponu kullanılmadan önceki sepet tutarının minimum 250 TL olması ve Plus kuponunun kullanılmasıyla oluşan sepet tutarının her koşulda restoranının minimum sepet tutarını karşılaması gerekmektedir. 01.07.2026 tarihinden itibaren bu madde hükümsüz olup, aşağıdaki şekilde uygulanacaktır: “Kullanıcının 125 TL değerindeki Plus kuponu kullanılmadan önceki sepet tutarının minimum 450 TL olması; 175 TL değerindeki Plus kuponu kullanılmadan önceki sepet tutarının minimum 500 TL, 250 TL değerindeki Plus kuponu kullanılmadan önceki sepet tutarının minimum 550 TL, 300 TL değerindeki Plus kuponu kullanılmadan önceki sepet tutarının minimum 600 TL olması ve Plus kuponunun kullanılmasıyla oluşan sepet tutarının her koşulda restoranının minimum sepet tutarını karşılaması gerekmektedir."\n\nC. REKLAM HİZMETİ KULLANIM KOŞULLARI \n\nİşbu Reklam Hizmeti Kullanım Koşulları (“Kullanım Koşulları”), Satıcı’nın, Satıcı Paneli’nde bulunan Reklam Yönetimi sayfasında, işbu Kullanım Koşulları’nda tanımlanan anlamıyla herhangi bir İşlem  yapması halinde geçerli olacak şart ve koşulları düzenlemektedir. \nReklam Bakiyesi Yükleme \nSatıcının reklam oluşturabilmesi için öncelikle reklam bakiyesi yüklemesi gerekmektedir. İstenilen tutarda reklam bakiyesi yüklenebilmekte olup, tek seferde en fazla 10.000.000 TL (on milyon türk lirası) reklam bakiyesi yüklemek mümkündür. \nYüklenen reklam bakiyesinin ödemesi iki şekilde yapılabilir: \nHesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür)\nYüklenen reklam bakiyesinin tutarı kredi kartı ile ödenebilir. \nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, reklam bakiyesi yüklendiği anda yüklenen bakiye tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez. \nAksi duyurulmadığı müddetçe, yüklenen reklam bakiyelerinin herhangi bir son kullanım tarihi bulunmamaktadır. Yüklenen bakiye tüketilene kadar kullanılabilir. \nSatıcıların tercih etmeleri halinde otomatik reklam bakiyesi yükleme talimatı vermeleri de mümkündür. Bu talimatı vermekle satıcı, mevcut reklam bakiyesinin kendisi tarafından belirlenen tutarın altına düştüğü her sefer için, belirlemiş olduğu tutarın otomatik olarak reklam bakiyesine aktarılmasını kabul eder. Otomatik reklam bakiyesi yükleme talimatı neticesinde yapılan yüklemelerin faturalanması ve ödenmesi bakımından işbu Kullanım Şartları’nda düzenlenen şart ve koşullar geçerli olacaktır. Satıcı, vermiş olduğu otomatik reklam bakiyesi yükleme talimatını her zaman Reklam Yönetimi sayfası altından iptal edebilir. \nTYG Turkey tarafından zaman zaman belirli kural setlerine uygun olarak belirlenebilecek satıcı gruplarına çeşitli reklam bakiyesi kampanyaları sunulabilecektir. Bu kampanyalar “Bakiye Satın Al” sayfası altından incelenebilir. TYG Turkey tarafından başlatılan reklam bakiyesi kampanyalarından yararlanmak isteyen satıcılar, kampanya kapsamında TYG Turkey tarafından karşılanacağı duyurulan tutarın düşürülmesi neticesinde kalan bakiyeyi ödeyerek reklam bakiyesi yükleyebilecektir. (Örneğin, TYG Turkey tarafından 2000 TL’lik reklam bakiyesi yüklemelerinin, 225 TL’sinin TYG Turkey tarafından karşılanacağı duyurulmuşsa, satıcı 1775 TL tutarında ödeme yaparak 2000 TL’lik reklam bakiyesi yükleyebilecektir.) \nHediye Bakiye\nHediye Bakiye sayfasından, TYG Turkey tarafından satıcılara karşılıksız olarak yüklenebilecek hediye reklam bakiye tutarlarına erişilebilir. TYG Turkey, hediye bakiyelere son kullanım tarihi belirleyebilir, son kullanım tarihinin belirlenmesi halinde, bu tarihe kadar kullanılmayan reklam bakiyeleri geçerliliğini kaybeder. \nReklam Oluşturma\nSatıcı reklam oluşturabilmek için Reklam Oluşturma Sayfası üzerinden, reklamına bir ad verip, reklamın geçerli olacağı tarih aralığını belirler. Satıcı tarafından belirlenen reklam adı müşterilere gözükmeyecek olup, satıcının raporlamalarında reklam metriklerini takip edebilmesi amacıyla kullanılır. \nSiparişlerinin teslimatının Satıcı tarafından yapıldığı model ile çalışan satıcılar, ayrıca reklamların gözükeceği dağıtım bölgelerini tercih edebilir. \nSatıcı tüm veya belirli şubeleri özelinde reklam başlatabilir. Bunun için reklamın geçerli olacağı şubeleri tanımlaması gerekir. \nSatıcı tarafından reklam harcamaları için günlük bütçe tutarı ve tıklama başına maliyet belirlenmelidir. Minimum 300 TL olmak kaydıyla, Satıcı tarafından belirlenen günlük bütçe her gün satıcının yüklemiş olduğu reklam bakiyesinden çekilir. Tıklama başına maliyet, kullanıcıların satıcı tarafından başlatılan reklama her tıkladığında günlük bütçeden çekilecek tutara karşılık gelmekte olup, belirlenebilecek minimum tıklama başına maliyet 9 TL iken, maksimum tıklama başına maliyet 20 TL’dir. İşbu madde 29.06.2026 tarihi itibariyle hükümsüz olup, aşağıdaki şekilde uygulanacaktır: “Satıcı tarafından reklam harcamaları için günlük bütçe tutarı ve tıklama başına maliyet belirlenmelidir. Minimum 300 TL olmak kaydıyla, Satıcı tarafından belirlenen günlük bütçe her gün satıcının yüklemiş olduğu reklam bakiyesinden çekilir. Tıklama başına maliyet, kullanıcıların satıcı tarafından başlatılan reklama her tıkladığında günlük bütçeden çekilecek tutara karşılık gelmekte olup, belirlenebilecek minimum tıklama başına maliyet 9 TL iken, maksimum tıklama başına maliyet 25 TL’dir.”\nSatıcı ayrıca seçtiği belirli bir tarih aralığı için geçerli olacak toplam bütçeyi ve tıklama başına maliyeti belirleyip, belirlemiş olduğu toplam bütçenin reklamının geçerli olacağı tarih içindeki dağılımını TYG Turkey tarafından yapılmasını da tercih edebilir. Satıcının bu tercihte bulunması, herhangi bir şekilde satıcıya sıralanma/listeleme garantisi veya bütçenin seçilen tarih aralığında kısmen/tamamen harcanılacağı taahhüdü vermemektedir. \nTYG Turkey tarafından zaman zaman satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, reklam bakiyesi yükleyen satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder. \nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Kullanım Koşullarının tüm hükümlerini ve reklam oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\nAbonelik Sistemi \nSatıcılar oluşturdukları reklamların işbu Abonelik Sistemi Şart ve Koşulları uyarınca, satıcının sonradan aboneliklerini sonlandırmayı tercih edecekleri tarihe kadar sürekli olarak yenilenmesini tercih edebilir. \nAbonelik oluşturabilmek için satıcının öncelikle ilgili sayfada kendisine TYG Turkey tarafından önerilen reklam paketlerinden birini tercih etmesi ya da tarih, bütçe, tıklama başına maliyet, şube tercihlerini yaparak şart ve koşullarını kendisinin belirlediği bir reklam oluşturması gerekmektedir. Satıcı, TYG Turkey tarafından oluşturulan reklam paketlerini paket kapsamında satıcıya önerilen bütçe, tarih, tıklama başına maliyet, şube seçeneklerini de özelleştirerek reklam oluşturma imkanına sahiptir. TYG Turkey tarafından satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, satıcı dilerse reklamını oluştururken tıklama başına maliyetin TYG Turkey tarafından belirlenmesini tercih edebilir. \nSatıcının abonelik sistemini başlatması halinde, satıcının oluşturduğu reklam, ilgili reklamın bitiş tarihinin dolması üzerine, reklamın geçerli olduğu dönem uzunluğunda tekrar etmeye devam eder. Örneğin, satıcının başlangıçta 7 günlük bir reklam oluşturması ve bu reklamla birlikte abonelik sistemine geçmesi halinde, 7 günlük reklam süresinin dolması üzerine, oluşturulan reklam satıcının tercih etmiş olduğu bütçe, tıklama başına maliyet ve şube tercihleri ile birlikte 7’şer günlük dönemlerde devam etmeye devam edecektir. \nSatıcı, Reklam Yönetimi sayfasında yer alan “Abonelik İptal Et” seçeneğini tercih ederek abonelik sisteminden çıkma imkanına sahiptir. Satıcının bu tercihte bulunması halinde, mevcutta geçerli olan reklamının bitiş tarihinin sona ermesi beklenir ve bu tarihin dolması üzerine ilgili reklam yenilenmez. \nAbonelik sistemini başlatmak isteyen satıcının ödemeleri iki şekilde yapılabilir:\nHesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür. Şüpheye mahal vermemek adına, satıcının tercih etmiş olduğu reklam bütçesinin içeride bulunan ve ancak henüz ödemesi Satıcıya yapılmamış hakediş tutarından fazla olması halinde satıcı bu opsiyon uyarınca ödeme gerçekleştiremeyecek ve abonelik başlatamayacaktır.)\nSatıcının reklam cüzdanında yeterli bakiye olması halinde, ödemeler reklam cüzdanından düşülür.\nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, yapılan ödeme tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez.\nReklam oluşturan satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder.  \n\nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Abonelik Sistemi Şart ve Koşullarının tüm hükümlerini ve reklam oluşturma/abonelik oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\nDiğer Hükümler\nReklam Yönetimi sekmesine girmeniz, bu sekmede yer alan herhangi bir bilgiyi kullanmanız ve bu sekmede herhangi bir işlem yapmış olmanız (Hepsi birlikte "İşlem" olarak kullanılacaktır) aşağıdaki koşulları kabul ettiğiniz anlamına gelir.\nİşlem yapılması sebebiyle, herhangi bir sözleşmenin ihlali, haksız fiil ya da başkaca sebeplere binaen, doğabilecek doğrudan ya da dolaylı hiçbir zarardan TYG Turkey veya herhangi bir grup şirketi sorumlu değildir. TYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti hususunda herhangi bir sorumluluk kabul etmez.\nTYG Turkey işbu Reklam Yönetimi sekmesi başta olmak üzere, Satıcı Paneli ve uzantısında mevcut her tür hizmet, ürün, uygulamayı kullanma koşulları ile uygulamada sunulan bilgileri önceden bir ihtara gerek olmaksızın değiştirme, uygulamayı yeniden organize etme, yayını durdurma hakkını saklı tutar. Değişiklikler, aksi duyurulmadığı müddetçe, uygulamada yayın anında yürürlüğe girer. İşlem yapılması ile bu değişiklikler de kabul edilmiş sayılır. Bu koşullar link verilen diğer web sayfaları/uygulamalar için de geçerlidir.\nTYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti, silinme, kayıp, işlemin veya iletişimin gecikmesi, bilgisayar virüsü, iletişim hatası, hırsızlık, imha veya izinsiz olarak kayıtlara girilmesi, değiştirilmesi veya kullanılması hususunda herhangi bir sorumluluk kabul etmez.\nReklam Yönetimi alanı/sekmesi TYG Turkey’nin kontrolü altında olmayan başka internet sitelerine / uygulamalara bağlantı veya referans içerebilir. TYG Turkey, bu sitelerin/uygulamaların içerikleri veya içerdikleri diğer bağlantılardan sorumlu değildir.\nTYG Turkey Reklam Yönetimi alanının/sekmesinin genel görünüm ve dizaynı ile alandaki/sekmedeki tüm bilgi, resim, Trendyol Go markası ve diğer markalar, işbu İşlem yapılan uygulama adı, logo, ikon, demonstratif, yazılı, elektronik, grafik veya makinede okunabilir şekilde sunulan teknik veriler, bilgisayar yazılımları, uygulanan satış sistemi, iş metodu ve iş modeli de dahil tüm materyallerin (\\"Materyaller\\") ve bunlara ilişkin fikri ve sınai mülkiyet haklarının sahibi veya lisans sahibidir ve yasal koruma altındadır. Reklam Yönetimi alanında/sekmesinde bulunan hiçbir Materyal; önceden izin alınmadan ve kaynak gösterilmeden, kod ve yazılım da dahil olmak üzere, değiştirilemez, kopyalanamaz, çoğaltılamaz, başka bir lisana çevrilemez, yeniden yayımlanamaz, başka bir bilgisayara yüklenemez, postalanamaz, iletilemez, sunulamaz ya da dağıtılamaz. Reklam Yönetimi alanının/sekmesinin bütünü veya bir kısmı başka bir internet sitesinde/uygulamada izinsiz olarak kullanılamaz. Aksine hareketler hukuki ve cezai sorumluluğu gerektirir. TYG Turkey’nin burada açıkça belirtilmeyen diğer tüm hakları saklıdır.\nTYG Turkey, dilediği zaman bu Kullanım Koşulları sayfasının içeriğini önceden duyurmak kaydıyla, güncelleme yetkisini saklı tutmaktadır ve kullanıcılarına Reklam Yönetimi alanına/sekmesine her girişte ayrıca Kullanım Koşulları sayfasını ziyaret etmelerini tavsiye etmektedir.\n\nD. SEPET İNDİRİMİ KAMPANYASI \nAVANTAJ PAKET KAPSAMINDA MAĞAZANIZIN SEPET İNDİRİMİ  KAMPANYASINA KATILIMI, TURBO PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nSEPET İNDİRİMİ KATILIM KOŞULLARI\nİstanbul, Ankara, İzmir, Bursa, Kocaeli, Antalya, Mersin, Şanlıurfa, Van, Diyarbakır, Bolu, Yalova, Kahramanmaraş, Batman, Uşak, Rize, Mardin, Erzincan, Karaman, Bingöl, Artvin, Bartın, Bitlis illerinde bulunan restoranlar için  kampanya kapsamında verilen, 500 TL ve üzeri siparişlerde 150 TL indirim uygulanır.\nEskişehir, Adana, Konya, Kayseri, Karabük, Erzurum, Osmaniye, Elazığ, Siirt, Gaziantep, Balıkesir, Sakarya, Kırklareli, Bilecik, Hatay, Kars, Ordu, Yozgat, Sinop, Niğde, Giresun illerinde bulunan restoranlar için  kampanya kapsamında verilen, 450 TL ve üzeri siparişlerde 140 TL indirim uygulanır.\nSamsun, Muğla, Aydın, Kütahya, Kilis, Iğdır, Hakkari, Muş, Manisa, Tekirdağ, Denizli, Çanakkale, Edirne, Aksaray, Sivas, Zonguldak, Nevşehir, Tunceli, Trabzon, Ardahan, Malatya, Adıyaman, Amasya, Şırnak, Çorum, Burdur, Kastamonu, Ağrı, Tokat, Isparta, Düzce, Kırşehir, Çankırı, Kırıkkale, Gümüşhane, Bayburt, Afyonkarahisar illerinde bulunan restoranlar için  kampanya kapsamında verilen, 400 TL ve üzeri siparişlerde 125 TL indirim uygulanır.\nİstanbul, Ankara, İzmir, Bursa, Kocaeli, Antalya, Mersin, Şanlıurfa, Van, Diyarbakır, Bolu, Yalova, Kahramanmaraş, Batman, Uşak, Rize, Mardin, Erzincan, Karaman, Bingöl, Artvin, Bartın, Bitlis illerinde bulunan restoranlar bakımından siparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 500 TL\'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 500 TL olması gerekmektedir.\nEskişehir, Adana, Konya, Kayseri, Karabük, Erzurum, Osmaniye, Elazığ, Siirt, Gaziantep, Balıkesir, Sakarya, Kırklareli, Bilecik, Hatay, Kars, Ordu, Yozgat, Sinop, Niğde, Giresun illerinde bulunan restoranlar bakımından siparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 450 TL\'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 450 TL olması gerekmektedir.\nSamsun, Muğla, Aydın, Kütahya, Kilis, Iğdır, Hakkari, Muş, Manisa, Tekirdağ, Denizli, Çanakkale, Edirne, Aksaray, Sivas, Zonguldak, Nevşehir, Tunceli, Trabzon, Ardahan, Malatya, Adıyaman, Amasya, Şırnak, Çorum, Burdur, Kastamonu, Ağrı, Tokat, Isparta, Düzce, Kırşehir, Çankırı, Kırıkkale, Gümüşhane, Bayburt, Afyonkarahisar illerinde bulunan restoranlar bakımından siparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 400 TL\'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 400 TL olması gerekmektedir.\nİndirimin tamamı restoran tarafından karşılanacaktır.\nHerhangi bir kullanıcı bakımından kampanyadan yararlanabilme sınırı (kampanyaya katılma sayısı vb.) bulunmamaktadır.\nKampanya ilk olarak 01 Ocak 2025 tarihinde başlayıp, Uber Eats Trendyol Go tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir. Satıcı vermiş olduğu onayla, kampanya başlangıç tarihinden sonra kampanyadan çıkmadığı müddetçe kampanyanın onay vermiş olduğu mağazasında geçerli olacağını kabul eder. Kampanyaya katılım ve kampanyadan çıkış işlemleri kampanya başlangıç tarihinden sonra herhangi bir zamanda yapılabilir.\nUber Eats Trendyol Go kampanya tarihleri, indirim tutarı, minimum sepet tutarı dahil olmak üzere kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda belirtilen tarihte yürürlüğe girecektir. Kampanyaya katılmış olan restoranlar, kampanyadan çıkmadıkları müddetçe, Uber Eats Trendyol Go tarafından yapılan değişikliklerin yürürlük tarihinden itibaren kendiliğinden geçerli olacağını kabul etmiş olacaktır.\nBu kampanya, Flaş İndirim kampanyası, Yedikçe İndirim, kupon, indirim kodu ve maliyetinin tamamına satıcının katlandığı sepet indirimleri ile birleştirilemez. Maliyetine kısmen satıcının katlandığı veya maliyetine tamamen Uber Eats Trendyol Go’nun katlandığı sepet indirimleri işbu kampanya şartlarında belirtilen sınırlamalara tabi olarak birleştirilebilir.\nAynı anda birden fazla kampanyaya katılmanız halinde indirim miktarı yüksek olan kampanya geçerli olacaktır.\nUber Eats Trendyol Go, kampanya süresinde ve koşullarında değişiklik yapma hakkını saklı tutar.\nİndirime sınırlı sayıda restoran katılabilecek olup, kampanya Uber Eats Trendyol Go tarafından duyurularla desteklenecektir.\nBu kampanyanın tamamı satıcı tarafından karşılanacaktır.\nSatıcının katıldığı bu kampanyaya ek olarak, aynı siparişte kullanıcı için daha avantajlı başka bir kampanya, indirim veya promosyonun da geçerli olması halinde; daha avantajlı olan kampanya, indirim veya promosyonun tutarı üst sınır oluşturmak kaydıyla, işbu kampanya ile diğer kampanya, indirim veya promosyon birleşebilecektir. Satıcı’nın karşılamayı üstlendiği tutar işbu kampanya için kullanılacak olup, birleşen kampanya kapsamında tüketiciye sunulacak ek faydanın maliyeti Uber Eats Trendyol Go tarafından karşılanacaktır.\n\n    \x3c!-- OPT-215909 END --\x3e\n`;true;',relationalRule:[],isRelational:!1},815:{test:'Insider.rules.call("35",803)===true;',relationalRule:[35],isRelational:!1},816:{test:"Insider.__external.turboPackageContent198199=()=>`\n    \x3c!-- OPT-215909 START --\x3e\n    <div id=\"package-conditions\"><strong>TURBO  PAKET KATILIM KOŞULLARI</strong></div>\x3c!-- OPT-200885 --\x3e\n    \n    <strong>TURBO PAKET KAPSAMINDA REKLAM BAKİYESİ TANIMLAMA</strong>\n    \nTURBO  PAKET KATILIM KOŞULLARI\nTURBO PAKET KAPSAMINDA REKLAM BAKİYESİ TANIMLAMA \nSatıcı mağazasına, Satıcı’nın “Turbo Paket” onay metnini kabul edip, 3.000 TL tutarındaki reklam bakiyesini ayrıca yüklemesini takiben 6.000 TL’lik reklam bakiyesi tanımlanır. 3.000 TL ve katlarında yapılacak reklam bakiyesi yüklemelerinde, tek seferlik 6.000 TL’lik reklam bakiyesi tanımlanır. Reklam oluşturma işlemi mağaza bazlı olup, satıcının dilediği mağazalarında bakiye yükleyerek reklam oluşturması mümkündür. \nOtomatik olarak, bakiye yüklenen tarihten 45 gün sonrasına kadar sürecek şekilde reklam oluşturulur. Bu süre reklamın geçerli olabileceği maksimum süredir, bütçe harcama hızına bağlı olarak reklam bu süreden daha önceki bir tarihte sona erebilecektir. Satıcı’nın birden fazla mağazası için Reklam Yönetimi sayfasında herhangi bir şekilde reklam başlatmış olması halinde, yüklenen toplam bakiye satıcının reklam veren tüm  mağazaları  için geçerli olacak toplam bakiyeyi oluşturur.  Bu durumda Hızlı Başlangıç Paketleri kapsamında açılan yeni reklam 45 günlük süreden daha erken bir sürede sonuçlanabilir. Satıcı bakiye yükleme ekranından bakiye takviyesi yaparak reklamını devam ettirebilir.\nReklam oluşturma işlemi, Hızlı Başlangıç Paketini onaylayan mağazanın bakiye yüklemesini takip eden 1 günlük süre 4. maddede düzenlenen koşullarda yeni bir reklam oluşturulması ile olur. Bu süre içinde, herhangi bir şekilde, ilgili mağazanın dahil olduğu bir aktif reklam olması halinde paket kapsamında reklam açma işlemi yapılmaz. Satıcı yüklediği bakiyesi ile aktif reklamı sonlanınca kendisi yeni bir reklam açabilir. \nBütçe tipi “Günlük” olarak seçilir. Günlük bütçe 300 TL olarak seçilir. Bu durumda satıcı 6.000 TL’lik reklam bakiyesini maksimum 45 gün içerisinde günlük maksimum 300 TL hedeflenerek reklam bakiyesi bitene kadar kullanır.\nHızlı Başlangıç Paketi kapsamında tanımlanan reklamlarda, tıklama başına maliyet dinamik olacak şekilde TYG Turkey tarafından belirlenir.  \nSatıcı dilediği zaman reklam kullanımını durdurabilir.\nBelirtilen şartlar dışında, aşağıda yer verilen Reklam Hizmeti Kullanım Koşulları da geçerli olacaktır. \nC. PLUS\nTURBO PAKET KAPSAMINDA MAĞAZANIZIN PLUS KATILIMI, AVANTAJ PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nPlus Katılım Şartları\nKullanıcılar her bir takvim ayı boyunca Plus programı kapsamında ulaştıkları seviyenin kupon kazanımına yeterli olması halinde Trendyol veya Uber Eats Trendyol Go uygulamalarında geçerli toplamda her bir takvim ayı için 2 adet olacak şekilde her biri 60 TL tutarında Plus kuponu kazanır. 01.07.2026 tarihinden itibaren bu madde hükümsüz olup, aşağıdaki şekilde uygulanacaktır: “Kullanıcılar her bir takvim ayı boyunca Plus programı kapsamında ulaştıkları seviyenin kupon kazanımına yeterli olması halinde Trendyol veya Uber Eats Trendyol Go uygulamalarında geçerli toplamda her bir takvim ayı için 2 adet olacak şekilde her biri 125 TL tutarında Plus kuponu kazanır.”\nPlus kuponları kullanıcının Plus programı kapsamında ulaştığı seviyeye bağlı olarak kazanılabilir, kazanılan Plus kuponları Plus kampanyasına dahil olmuş restoranlarda (“Plus restoranları”) harcanabilir.\nBir kullanıcı bir siparişte tanımlanan Plus yemek kuponlarından yalnızca bir tanesini kullanabilecektir. Her siparişte 1 kupon kullanılabilecektir. Plus kuponları yalnızca kazanıldıkları takvim ayı içerisinde geçerli olacaktır, bir sonraki takvim ayına devretmez. \nTrendyol ve Uber Eats Trendyol Go uygulamalarında kullanıcılara tanımlanacak 2 adet kupona ek olarak yalnızca Uber Eats Trendyol Go uygulamasını kullanan kullanıcıların faydalanabileceği üçüncü, dördüncü ve beşinci Plus yemek kuponları aktif olacaktır. Bu kuponlar da Plus programı kapsamında kullanıcının ulaştığı seviyeye bağlı olarak tanımlanacak olup, üçüncü kuponun değeri 60 TL; dördüncü ve beşinci kuponların değeri ise sırasıyla 75 TL ve 90 TL olacak, Plus kuponlarının koşullarına tabi olacak ve Plus restoranlarda harcanabilecektir. 01.07.2026 tarihinden itibaren bu madde hükümsüz olup, aşağıdaki şekilde uygulanacaktır: “Trendyol ve Uber Eats Trendyol Go uygulamalarında kullanıcılara tanımlanacak 2 adet kupona ek olarak yalnızca Uber Eats Trendyol Go uygulamasını kullanan kullanıcıların faydalanabileceği üçüncü, dördüncü ve beşinci Plus yemek kuponları aktif olacaktır. Bu kuponlar da Plus programı kapsamında kullanıcının ulaştığı seviyeye bağlı olarak tanımlanacak olup, üçüncü kuponun değeri 175 TL; dördüncü ve beşinci kuponların değeri ise sırasıyla 250 TL ve 300 TL olacak, Plus kuponlarının koşullarına tabi olacak ve Plus restoranlarda harcanabilecektir.”\nSatıcı, kullanılan kupon tutarından bağımsız olarak, kullanıcı tarafından kullanılan ilk üç kupon için, her bir kuponun 60 TL’lik tutarının maliyetini karşılar. Satıcı tarafından karşılanan kısmı aşan kupon tutarlarının maliyeti TYG Turkey tarafından karşılanır. 01.07.2026 tarihinden itibaren bu madde hükümsüz olup, aşağıdaki şekilde uygulanacaktır: “Satıcı, kullanılan kupon tutarından bağımsız olarak, kullanıcı tarafından kullanılan ilk iki kupon için, her bir kuponun 125 TL’lik tutarının maliyetini ve yine kullanılan kupon tutarından bağımsız olarak, kullanıcı tarafından kullanılan üçüncü kuponun 175 TL’lik maliyetini karşılar. Satıcı tarafından karşılanan kısmı aşan kupon tutarlarının maliyeti TYG Turkey tarafından karşılanır.”\nİndirimde karşıladığınız tutar üzerinden komisyon kesintisi yapılmayacaktır.\nKullanıcılar Plus kuponunu diğer kampanyalarla birleştiremez.\nGüncellenen şartlarıyla kampanya belirtilen güncelleme tarihlerinde başlayacak olup, TYG Turkey tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir. \nPlus Yemek Kuponu Kampanyasına katılan restoranlar ana sayfada,  Plus sayfasında, filtrelerde ve birçok farklı alanda listelenecektir.\nKampanya TYG Turkey tarafından duyurular ve reklamlarla desteklenecektir. \nTYG Turkey kampanya tarihleri, kupon adedi, kupon tutarı, kupon maliyetinin kimin tarafından hangi oranda karşılanacağı dahil olmak üzere Plus kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda daha ileri bir tarih belirtilmediği müddetçe duyurunun çıkılmasından 7 gün sonra kendiliğinden yürürlüğe girecektir. Restoran lehine yapılacak değişiklikler duyurunun çıkılmasından 1 gün sonra kendiliğinden yürürlüğe girecektir. \nRestoran vermiş olduğu onay ile Plus kuponlarının maliyetlerini karşılamayı ve restoranında platform üzerinden kazanılmış Plus kuponlarının kullanılabilmesini kabul etmiş olacaktır. Plus kampanyası restoran tarafından kampanyadan çıkılmadığı veya TYG Turkey tarafından iptal edilmediği müddetçe süresiz olarak yürürlükte kalacaktır. \nPlus Yemek Kuponu kampanyasına herhangi bir zamanda katılma ve kampanyadan çıkma hakkı bulunmaktadır. \nKampanya süresince yapacağınız katıl/çık işlemleri, kullanıcı memnuniyeti sebepli uygulamaya 1 saat sonrasında yansıyacaktır.\nTYG Turkey,  Plus programının, Plus kampanya koşullarının ve/veya Platform kullanıcılarının (Satıcı ve Alıcı da dahil)  Plus programı ve/veya Plus kampanya deneyiminin geliştirilmesi ve iyileştirilmesi amaçlarıyla sınırlı olarak ve bu amaçların gerektirdiği ölçüde, Platform kullanıcılarının (Satıcı ve Alıcı da dahil) beklenti, tercih ve davranışlarını tespit etmeye yönelik kullanıcı grupları bazlı veya kullanıcı gruplarına kampanya kapsamında sağlanan menfaatler özelinde satıcıya ilave maliyet yüklemeksizin geçici süreli, mevzuata uygun test uygulamalarını devreye alabilecektir. \nKullanıcının Plus kuponu kullanılmadan önceki sepet tutarının minimum 250 TL olması ve Plus kuponunun kullanılmasıyla oluşan sepet tutarının her koşulda restoranının minimum sepet tutarını karşılaması gerekmektedir. 01.07.2026 tarihinden itibaren bu madde hükümsüz olup, aşağıdaki şekilde uygulanacaktır: “Kullanıcının 125 TL değerindeki Plus kuponu kullanılmadan önceki sepet tutarının minimum 450 TL olması; 175 TL değerindeki Plus kuponu kullanılmadan önceki sepet tutarının minimum 500 TL, 250 TL değerindeki Plus kuponu kullanılmadan önceki sepet tutarının minimum 550 TL, 300 TL değerindeki Plus kuponu kullanılmadan önceki sepet tutarının minimum 600 TL olması ve Plus kuponunun kullanılmasıyla oluşan sepet tutarının her koşulda restoranının minimum sepet tutarını karşılaması gerekmektedir.”\nD. SEPET İNDİRİMİ KAMPANYASI \nTURBO PAKET KAPSAMINDA MAĞAZANIZIN SEPET İNDİRİMİ  KAMPANYASINA KATILIMI, TURBO PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nSEPET İNDİRİMİ KATILIM KOŞULLARI\nİstanbul, Ankara, İzmir, Bursa, Kocaeli, Antalya, Mersin, Şanlıurfa, Van, Diyarbakır, Bolu, Yalova, Kahramanmaraş, Batman, Uşak, Rize, Mardin, Erzincan, Karaman, Bingöl, Artvin, Bartın, Bitlis illerinde bulunan restoranlar için  kampanya kapsamında verilen, 500 TL ve üzeri siparişlerde 150 TL indirim uygulanır.\nEskişehir, Adana, Konya, Kayseri, Karabük, Erzurum, Osmaniye, Elazığ, Siirt, Gaziantep, Balıkesir, Sakarya, Kırklareli, Bilecik, Hatay, Kars, Ordu, Yozgat, Sinop, Niğde, Giresun illerinde bulunan restoranlar için  kampanya kapsamında verilen, 450 TL ve üzeri siparişlerde 140 TL indirim uygulanır.\nSamsun, Muğla, Aydın, Kütahya, Kilis, Iğdır, Hakkari, Muş, Manisa, Tekirdağ, Denizli, Çanakkale, Edirne, Aksaray, Sivas, Zonguldak, Nevşehir, Tunceli, Trabzon, Ardahan, Malatya, Adıyaman, Amasya, Şırnak, Çorum, Burdur, Kastamonu, Ağrı, Tokat, Isparta, Düzce, Kırşehir, Çankırı, Kırıkkale, Gümüşhane, Bayburt, Afyonkarahisar illerinde bulunan restoranlar için  kampanya kapsamında verilen, 400 TL ve üzeri siparişlerde 125 TL indirim uygulanır.\nİstanbul, Ankara, İzmir, Bursa, Kocaeli, Antalya, Mersin, Şanlıurfa, Van, Diyarbakır, Bolu, Yalova, Kahramanmaraş, Batman, Uşak, Rize, Mardin, Erzincan, Karaman, Bingöl, Artvin, Bartın, Bitlis illerinde bulunan restoranlar bakımından siparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 500 TL'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 500 TL olması gerekmektedir.\nEskişehir, Adana, Konya, Kayseri, Karabük, Erzurum, Osmaniye, Elazığ, Siirt, Gaziantep, Balıkesir, Sakarya, Kırklareli, Bilecik, Hatay, Kars, Ordu, Yozgat, Sinop, Niğde, Giresun illerinde bulunan restoranlar bakımından siparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 450 TL'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 450 TL olması gerekmektedir.\nSamsun, Muğla, Aydın, Kütahya, Kilis, Iğdır, Hakkari, Muş, Manisa, Tekirdağ, Denizli, Çanakkale, Edirne, Aksaray, Sivas, Zonguldak, Nevşehir, Tunceli, Trabzon, Ardahan, Malatya, Adıyaman, Amasya, Şırnak, Çorum, Burdur, Kastamonu, Ağrı, Tokat, Isparta, Düzce, Kırşehir, Çankırı, Kırıkkale, Gümüşhane, Bayburt, Afyonkarahisar illerinde bulunan restoranlar bakımından siparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 400 TL'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 400 TL olması gerekmektedir.\nİndirimin tamamı restoran tarafından karşılanacaktır.\nHerhangi bir kullanıcı bakımından kampanyadan yararlanabilme sınırı (kampanyaya katılma sayısı vb.) bulunmamaktadır.\nKampanya ilk olarak 01 Ocak 2025 tarihinde başlayıp, Uber Eats Trendyol Go tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir. Satıcı vermiş olduğu onayla, kampanya başlangıç tarihinden sonra kampanyadan çıkmadığı müddetçe kampanyanın onay vermiş olduğu mağazasında geçerli olacağını kabul eder. Kampanyaya katılım ve kampanyadan çıkış işlemleri kampanya başlangıç tarihinden sonra herhangi bir zamanda yapılabilir.\nUber Eats Trendyol Go kampanya tarihleri, indirim tutarı, minimum sepet tutarı dahil olmak üzere kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda belirtilen tarihte yürürlüğe girecektir. Kampanyaya katılmış olan restoranlar, kampanyadan çıkmadıkları müddetçe, Uber Eats Trendyol Go tarafından yapılan değişikliklerin yürürlük tarihinden itibaren kendiliğinden geçerli olacağını kabul etmiş olacaktır.\nBu kampanya, Flaş İndirim kampanyası, Yedikçe İndirim, kupon, indirim kodu ve maliyetinin tamamına satıcının katlandığı sepet indirimleri ile birleştirilemez. Maliyetine kısmen satıcının katlandığı veya maliyetine tamamen Uber Eats Trendyol Go’nun katlandığı sepet indirimleri işbu kampanya şartlarında belirtilen sınırlamalara tabi olarak birleştirilebilir.\nAynı anda birden fazla kampanyaya katılmanız halinde indirim miktarı yüksek olan kampanya geçerli olacaktır.\nUber Eats Trendyol Go, kampanya süresinde ve koşullarında değişiklik yapma hakkını saklı tutar.\nİndirime sınırlı sayıda restoran katılabilecek olup, kampanya Uber Eats Trendyol Go tarafından duyurularla desteklenecektir.\nBu kampanyanın tamamı satıcı tarafından karşılanacaktır.\nSatıcının katıldığı bu kampanyaya ek olarak, aynı siparişte kullanıcı için daha avantajlı başka bir kampanya, indirim veya promosyonun da geçerli olması halinde; daha avantajlı olan kampanya, indirim veya promosyonun tutarı üst sınır oluşturmak kaydıyla, işbu kampanya ile diğer kampanya, indirim veya promosyon birleşebilecektir. Satıcı’nın karşılamayı üstlendiği tutar işbu kampanya için kullanılacak olup, birleşen kampanya kapsamında tüketiciye sunulacak ek faydanın maliyeti Uber Eats Trendyol Go tarafından karşılanacaktır.\n\n\n\n\n\n\n\n\nREKLAM HİZMETİ KULLANIM KOŞULLARI \n\nİşbu Reklam Hizmeti Kullanım Koşulları (“Kullanım Koşulları”), Satıcı’nın, Satıcı Paneli’nde bulunan Reklam Yönetimi sayfasında, işbu Kullanım Koşulları’nda tanımlanan anlamıyla herhangi bir İşlem  yapması halinde geçerli olacak şart ve koşulları düzenlemektedir. \nReklam Bakiyesi Yükleme \nSatıcının reklam oluşturabilmesi için öncelikle reklam bakiyesi yüklemesi gerekmektedir. İstenilen tutarda reklam bakiyesi yüklenebilmekte olup, tek seferde en fazla 10.000.000 TL (on milyon türk lirası) reklam bakiyesi yüklemek mümkündür. \nYüklenen reklam bakiyesinin ödemesi iki şekilde yapılabilir: \nHesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür)\nYüklenen reklam bakiyesinin tutarı kredi kartı ile ödenebilir. \nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, reklam bakiyesi yüklendiği anda yüklenen bakiye tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez. \nAksi duyurulmadığı müddetçe, yüklenen reklam bakiyelerinin herhangi bir son kullanım tarihi bulunmamaktadır. Yüklenen bakiye tüketilene kadar kullanılabilir. \nSatıcıların tercih etmeleri halinde otomatik reklam bakiyesi yükleme talimatı vermeleri de mümkündür. Bu talimatı vermekle satıcı, mevcut reklam bakiyesinin kendisi tarafından belirlenen tutarın altına düştüğü her sefer için, belirlemiş olduğu tutarın otomatik olarak reklam bakiyesine aktarılmasını kabul eder. Otomatik reklam bakiyesi yükleme talimatı neticesinde yapılan yüklemelerin faturalanması ve ödenmesi bakımından işbu Kullanım Şartları’nda düzenlenen şart ve koşullar geçerli olacaktır. Satıcı, vermiş olduğu otomatik reklam bakiyesi yükleme talimatını her zaman Reklam Yönetimi sayfası altından iptal edebilir. \nTYG Turkey tarafından zaman zaman belirli kural setlerine uygun olarak belirlenebilecek satıcı gruplarına çeşitli reklam bakiyesi kampanyaları sunulabilecektir. Bu kampanyalar “Bakiye Satın Al” sayfası altından incelenebilir. TYG Turkey tarafından başlatılan reklam bakiyesi kampanyalarından yararlanmak isteyen satıcılar, kampanya kapsamında TYG Turkey tarafından karşılanacağı duyurulan tutarın düşürülmesi neticesinde kalan bakiyeyi ödeyerek reklam bakiyesi yükleyebilecektir. (Örneğin, TYG Turkey tarafından 2000 TL’lik reklam bakiyesi yüklemelerinin, 225 TL’sinin TYG Turkey tarafından karşılanacağı duyurulmuşsa, satıcı 1775 TL tutarında ödeme yaparak 2000 TL’lik reklam bakiyesi yükleyebilecektir.) \nHediye Bakiye\nHediye Bakiye sayfasından, TYG Turkey tarafından satıcılara karşılıksız olarak yüklenebilecek hediye reklam bakiye tutarlarına erişilebilir. TYG Turkey, hediye bakiyelere son kullanım tarihi belirleyebilir, son kullanım tarihinin belirlenmesi halinde, bu tarihe kadar kullanılmayan reklam bakiyeleri geçerliliğini kaybeder. \nReklam Oluşturma\nSatıcı reklam oluşturabilmek için Reklam Oluşturma Sayfası üzerinden, reklamına bir ad verip, reklamın geçerli olacağı tarih aralığını belirler. Satıcı tarafından belirlenen reklam adı müşterilere gözükmeyecek olup, satıcının raporlamalarında reklam metriklerini takip edebilmesi amacıyla kullanılır. \nSiparişlerinin teslimatının Satıcı tarafından yapıldığı model ile çalışan satıcılar, ayrıca reklamların gözükeceği dağıtım bölgelerini tercih edebilir. \nSatıcı tüm veya belirli şubeleri özelinde reklam başlatabilir. Bunun için reklamın geçerli olacağı şubeleri tanımlaması gerekir. \nSatıcı tarafından reklam harcamaları için günlük bütçe tutarı ve tıklama başına maliyet belirlenmelidir. Minimum 300 TL olmak kaydıyla, Satıcı tarafından belirlenen günlük bütçe her gün satıcının yüklemiş olduğu reklam bakiyesinden çekilir. Tıklama başına maliyet, kullanıcıların satıcı tarafından başlatılan reklama her tıkladığında günlük bütçeden çekilecek tutara karşılık gelmekte olup, belirlenebilecek minimum tıklama başına maliyet 9 TL iken, maksimum tıklama başına maliyet 20 TL’dir. İşbu madde 29.06.2026 tarihi itibariyle hükümsüz olup, aşağıdaki şekilde uygulanacaktır: “Satıcı tarafından reklam harcamaları için günlük bütçe tutarı ve tıklama başına maliyet belirlenmelidir. Minimum 300 TL olmak kaydıyla, Satıcı tarafından belirlenen günlük bütçe her gün satıcının yüklemiş olduğu reklam bakiyesinden çekilir. Tıklama başına maliyet, kullanıcıların satıcı tarafından başlatılan reklama her tıkladığında günlük bütçeden çekilecek tutara karşılık gelmekte olup, belirlenebilecek minimum tıklama başına maliyet 9 TL iken, maksimum tıklama başına maliyet 25 TL’dir.”\nSatıcı ayrıca seçtiği belirli bir tarih aralığı için geçerli olacak toplam bütçeyi ve tıklama başına maliyeti belirleyip, belirlemiş olduğu toplam bütçenin reklamının geçerli olacağı tarih içindeki dağılımını TYG Turkey tarafından yapılmasını da tercih edebilir. Satıcının bu tercihte bulunması, herhangi bir şekilde satıcıya sıralanma/listeleme garantisi veya bütçenin seçilen tarih aralığında kısmen/tamamen harcanılacağı taahhüdü vermemektedir. \nTYG Turkey tarafından zaman zaman satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, reklam bakiyesi yükleyen satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder. \nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Kullanım Koşullarının tüm hükümlerini ve reklam oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\nAbonelik Sistemi \nSatıcılar oluşturdukları reklamların işbu Abonelik Sistemi Şart ve Koşulları uyarınca, satıcının sonradan aboneliklerini sonlandırmayı tercih edecekleri tarihe kadar sürekli olarak yenilenmesini tercih edebilir. \nAbonelik oluşturabilmek için satıcının öncelikle ilgili sayfada kendisine TYG Turkey tarafından önerilen reklam paketlerinden birini tercih etmesi ya da tarih, bütçe, tıklama başına maliyet, şube tercihlerini yaparak şart ve koşullarını kendisinin belirlediği bir reklam oluşturması gerekmektedir. Satıcı, TYG Turkey tarafından oluşturulan reklam paketlerini paket kapsamında satıcıya önerilen bütçe, tarih, tıklama başına maliyet, şube seçeneklerini de özelleştirerek reklam oluşturma imkanına sahiptir. TYG Turkey tarafından satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, satıcı dilerse reklamını oluştururken tıklama başına maliyetin TYG Turkey tarafından belirlenmesini tercih edebilir. \nSatıcının abonelik sistemini başlatması halinde, satıcının oluşturduğu reklam, ilgili reklamın bitiş tarihinin dolması üzerine, reklamın geçerli olduğu dönem uzunluğunda tekrar etmeye devam eder. Örneğin, satıcının başlangıçta 7 günlük bir reklam oluşturması ve bu reklamla birlikte abonelik sistemine geçmesi halinde, 7 günlük reklam süresinin dolması üzerine, oluşturulan reklam satıcının tercih etmiş olduğu bütçe, tıklama başına maliyet ve şube tercihleri ile birlikte 7’şer günlük dönemlerde devam etmeye devam edecektir. \nSatıcı, Reklam Yönetimi sayfasında yer alan “Abonelik İptal Et” seçeneğini tercih ederek abonelik sisteminden çıkma imkanına sahiptir. Satıcının bu tercihte bulunması halinde, mevcutta geçerli olan reklamının bitiş tarihinin sona ermesi beklenir ve bu tarihin dolması üzerine ilgili reklam yenilenmez. \nAbonelik sistemini başlatmak isteyen satıcının ödemeleri iki şekilde yapılabilir:\nHesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür. Şüpheye mahal vermemek adına, satıcının tercih etmiş olduğu reklam bütçesinin içeride bulunan ve ancak henüz ödemesi Satıcıya yapılmamış hakediş tutarından fazla olması halinde satıcı bu opsiyon uyarınca ödeme gerçekleştiremeyecek ve abonelik başlatamayacaktır.)\nSatıcının reklam cüzdanında yeterli bakiye olması halinde, ödemeler reklam cüzdanından düşülür.\nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, yapılan ödeme tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez.\nReklam oluşturan satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder.  \n\nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Abonelik Sistemi Şart ve Koşullarının tüm hükümlerini ve reklam oluşturma/abonelik oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\nDiğer Hükümler\nReklam Yönetimi sekmesine girmeniz, bu sekmede yer alan herhangi bir bilgiyi kullanmanız ve bu sekmede herhangi bir işlem yapmış olmanız (Hepsi birlikte \"İşlem\" olarak kullanılacaktır) aşağıdaki koşulları kabul ettiğiniz anlamına gelir.\nİşlem yapılması sebebiyle, herhangi bir sözleşmenin ihlali, haksız fiil ya da başkaca sebeplere binaen, doğabilecek doğrudan ya da dolaylı hiçbir zarardan TYG Turkey veya herhangi bir grup şirketi sorumlu değildir. TYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti hususunda herhangi bir sorumluluk kabul etmez.\nTYG Turkey işbu Reklam Yönetimi sekmesi başta olmak üzere, Satıcı Paneli ve uzantısında mevcut her tür hizmet, ürün, uygulamayı kullanma koşulları ile uygulamada sunulan bilgileri önceden bir ihtara gerek olmaksızın değiştirme, uygulamayı yeniden organize etme, yayını durdurma hakkını saklı tutar. Değişiklikler, aksi duyurulmadığı müddetçe, uygulamada yayın anında yürürlüğe girer. İşlem yapılması ile bu değişiklikler de kabul edilmiş sayılır. Bu koşullar link verilen diğer web sayfaları/uygulamalar için de geçerlidir.\nTYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti, silinme, kayıp, işlemin veya iletişimin gecikmesi, bilgisayar virüsü, iletişim hatası, hırsızlık, imha veya izinsiz olarak kayıtlara girilmesi, değiştirilmesi veya kullanılması hususunda herhangi bir sorumluluk kabul etmez.\nReklam Yönetimi alanı/sekmesi TYG Turkey’nin kontrolü altında olmayan başka internet sitelerine / uygulamalara bağlantı veya referans içerebilir. TYG Turkey, bu sitelerin/uygulamaların içerikleri veya içerdikleri diğer bağlantılardan sorumlu değildir.\nTYG Turkey Reklam Yönetimi alanının/sekmesinin genel görünüm ve dizaynı ile alandaki/sekmedeki tüm bilgi, resim, Trendyol Go markası ve diğer markalar, işbu İşlem yapılan uygulama adı, logo, ikon, demonstratif, yazılı, elektronik, grafik veya makinede okunabilir şekilde sunulan teknik veriler, bilgisayar yazılımları, uygulanan satış sistemi, iş metodu ve iş modeli de dahil tüm materyallerin (\\\"Materyaller\\\") ve bunlara ilişkin fikri ve sınai mülkiyet haklarının sahibi veya lisans sahibidir ve yasal koruma altındadır. Reklam Yönetimi alanında/sekmesinde bulunan hiçbir Materyal; önceden izin alınmadan ve kaynak gösterilmeden, kod ve yazılım da dahil olmak üzere, değiştirilemez, kopyalanamaz, çoğaltılamaz, başka bir lisana çevrilemez, yeniden yayımlanamaz, başka bir bilgisayara yüklenemez, postalanamaz, iletilemez, sunulamaz ya da dağıtılamaz. Reklam Yönetimi alanının/sekmesinin bütünü veya bir kısmı başka bir internet sitesinde/uygulamada izinsiz olarak kullanılamaz. Aksine hareketler hukuki ve cezai sorumluluğu gerektirir. TYG Turkey’nin burada açıkça belirtilmeyen diğer tüm hakları saklıdır.\nTYG Turkey, dilediği zaman bu Kullanım Koşulları sayfasının içeriğini önceden duyurmak kaydıyla, güncelleme yetkisini saklı tutmaktadır ve kullanıcılarına Reklam Yönetimi alanına/sekmesine her girişte ayrıca Kullanım Koşulları sayfasını ziyaret etmelerini tavsiye etmektedir.\n\nE. FLAŞ\nTURBO PAKET KAPSAMINDA MAĞAZANIZIN FLAŞ KATILIMI, TURBO PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nFLAŞ İNDİRİM GÜNCEL KAMPANYA ŞARTLARI \nFlaş İndirim kampanyasından, kampanyaya katılan restoranın seçimine göre i. daha önce hiç sipariş vermemiş kullanıcılar veya ii. daha önce hiç sipariş vermemiş kullanıcılara ek olarak daha önce sipariş vermesine rağmen restoranın belirlediği süre zarfında tekrardan sipariş vermemiş kullanıcılar (ilgili restoran bu süreyi son 1 ay, son 2 ay veya son 3 ay olarak belirleyebilecektir) yararlanacaktır.\nFlaş İndirim kampanyası, uygulamaya girdiğinde doğrudan Flaş indirim kampanyasından yararlanabilecek kullanıcının karşısına çıkacak olup, kullanıcının indirimden faydalanabilmesi için 15 dakika içinde siparişini tamamlaması gerekmektedir. Kampanyanın gösterileceği kullanıcılar, restoranınızın bu duyuruda açıklanan şartlar uyarınca kitleyi genişletme hakkı saklı olmak üzere, Uber Eats Trendyol Go tarafından belirlenecektir.\nKampanyaya katılan herhangi bir restoranın, Flaş İndirim Restoranı olarak Kullanıcılara gösterilebilmesi için ilgili restoranın Satıcı Paneli üzerinden i. kampanyadan yararlanabilecek günlük müşteri sayısını belirlemesi ya da ii. Flaş İndirim Kampanyasının geçerli olacağı tarih ve saat aralıklarını her bir tarih için geçerli olacak müşteri sayısı ile birlikte belirlemesi gerekmektedir. Restoran kampanyadan çıkmadığı müddetçe, restoran tarafından yapılan bu seçimler otomatik olarak uygulanmaya devam eder.\n\nFlaş İndirim kampanyası kapsamında kullanıcıların hem Uber Eats Trendyol Go uygulamasında hem de Trendyol uygulamasından erişim verilen Uber Eats Trendyol Go kanalında faydalanacağı indirimler, her takvim ayı başlangıcında hesaplanan kullanıcının son 6 ay içinde oluşturduğu sepet tutarı ortalamasına göre belirlenecek olup, farklı kullanıcı grupları arasında değişiklik gösterebilecektir. Uber Eats Trendyol Go tarafından bu kural doğrultusunda düşükten yükseğe sepet ortalaması tutarlarına göre 4 farklı kullanıcı grubu oluşturulmuş olup, her bir kullanıcı grubu için, kullanıcının sepet tutarına göre geçerli olacak indirim tutarları aşağıdaki gibi olacaktır: \n\n1.grupta yer alan kullanıcı her 250 TL'lik siparişte 70 TL, 325 TL'lik siparişte 110 TL, 400 TL'lik siparişte 150 TL'lik bir indirim kazanacaktır. Ek olarak flaş indirim kampanyası kapsamında kullanıcılar yalnızca Uber Eats Trendyol Go uygulamasında geçerli her 500 TL'lik siparişte, 200 TL'lik bir indirim kazanacaktır. \n\n2.grupta yer alan kullanıcı her 275 TL'lik siparişte 70 TL, 350 TL'lik siparişte 100 TL, 450 TL'lik siparişte 150 TL'lik bir indirim kazanacaktır. Ek olarak flaş indirim kampanyası kapsamında kullanıcılar yalnızca Uber Eats Trendyol Go uygulamasında geçerli her 550 TL'lik siparişte, 200 TL'lik bir indirim kazanacaktır. \n\n3.grupta yer alan kullanıcı her 350 TL'lik siparişte 100 TL, 475 TL'lik siparişte 140 TL, 600 TL'lik siparişte 190 TL'lik bir indirim kazanacaktır. Ek olarak flaş indirim kampanyası kapsamında kullanıcılar yalnızca Uber Eats Trendyol Go uygulamasında geçerli her 750 TL'lik siparişte, 250 TL'lik bir indirim kazanacaktır. \n\n4.grupta yer alan kullanıcı her 400 TL'lik siparişte 80 TL, 550 TL'lik siparişte 150 TL, 700 TL'lik siparişte 200 TL'lik bir indirim kazanacaktır. Ek olarak flaş indirim kampanyası kapsamında kullanıcılar yalnızca Uber Eats Trendyol Go uygulamasında geçerli her 850 TL'lik siparişte, 250 TL'lik bir indirim kazanacaktır.\n\n5.grupta yer alan kullanıcı her 250 TL'lik siparişte 100 TL, 350 TL'lik siparişte 130 TL, 450 TL'lik siparişte 160 TL'lik bir indirim kazanacaktır. Ek olarak flaş indirim kampanyası kapsamında kullanıcılar yalnızca Uber Eats Trendyol Go uygulamasında geçerli her 550 TL'lik siparişte, 200 TL'lik bir indirim kazanacaktır.\n\nKullanıcıların kazandığı bu indirim tutarlarının maliyetine ilgili Flaş İndirim Restoranı katlanacaktır. Ayrıca daha önce Uber Eats Trendyol Go uygulamasında ya da Trendyol uygulamasından erişim verilen Uber Eats Trendyol Go kanalında yer alan Yemek bölümünden hiç sipariş vermemiş kullanıcıların, Uber Eats Trendyol Go uygulaması veya Trendyol uygulamasından erişim verilen Uber Eats Trendyol Go kanalında bulunan Yemek bölümünden verecekleri ilk siparişlerinde faydalanacağı indirimler, kullanıcının oluşturduğu sepet tutarına göre değişiklik gösterecek olup, kullanıcı 200 TL'lik siparişte 150 TL, 300 TL'lik siparişte 200 TL, 450 TL'lik siparişte 250 TL; yalnızca Uber Eats Trendyol Go uygulamasında geçerli 600 TL'lik siparişte, 300 TL'lik bir indirim kazanacaktır. Daha önce Uber Eats Trendyol Go kanalında bulunan Yemek bölümünden hiç sipariş vermemiş kullanıcıların verecekleri ilk siparişlerinde geçerli olacak bu indirim tutarlarının %47’sine karşılık gelen kısmının maliyetine Uber Eats Trendyol Go katlanacaktır. Daha önce Uber Eats Trendyol Go kanalında bulunan Yemek bölümünden hiç sipariş vermemiş kullanıcıların yararlanacağı indirimler, restoranın kullanıcı kitlesi olarak \"\"daha önce restoranından hiç sipariş vermemiş kullanıcıları\"\" tercih etmesi halinde uygulanacak olup, daha önce sipariş vermesine rağmen restoranın belirlediği süre zarfında tekrardan sipariş vermemiş kullanıcı kitlesini tercih eden restoranlar bakımından geçerli olmayacaktır.\n\nFlaş İndirim Restoranı'nın karşıladığı indirim tutarı üzerinden Uber Eats Trendyol Go tarafından komisyon kesintisi yapılmayacaktır.\nFlaş İndirim kampanyası, Yedikçe İndirim, kupon, indirim kodu ve maliyetinin tamamına satıcının katlandığı sepet indirimleri ile birleştirilemez. Maliyetine kısmen satıcının katlandığı veya maliyetine tamamen Uber Eats Trendyol Go'nun katlandığı sepet indirimleri işbu kampanya şartlarında belirtilen sınırlamalara tabi olarak birleştirilebilir. Ayrıca, herhangi bir kullanıcı, kampanyadan yararlanmasından itibaren 15 dakika geçmedikçe, aynı restorandan vereceği siparişte herhangi bir kampanyadan tekrar yararlanamayacaktır.\nFlaş İndirim Restoranı tarafından belirli tarih için tanımlanan belirli adetteki kullanıcı indiriminin, Kullanıcılar tarafından ilgili tarihlerde kullanılmaması halinde, kullanılmayan indirimler sonraki bir tarihe devredilmez.\nKampanya ilk olarak 10 Temmuz 2023 tarihinde başlamış olup, Uber Eats Trendyol Go tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir. Flaş İndirim Restoranı'nın kampanyanın devam ettiği süre boyunca kampanyadan yararlanabilmesi için Satıcı Paneli üzerinden ya kampanyadan yararlanabilecek günlük müşteri sayısını belirlemesi ya da Flaş İndirim Kampanyasının geçerli olacağı tarih ve saat aralıklarını her bir tarih için geçerli olacak müşteri sayısı ile birlikte belirlemesi gerekmektedir.\nRestoran vermiş olduğu onay ile Flaş İndirim kampanyası kapsamında Kullanıcıya tanımlanan indirimlerin maliyetlerini karşılamayı ve restoranında bu indirimlerin kullanılabilmesini kabul etmiş olacaktır.\nFlaş İndirim kampanyasına herhangi bir zamanda katılma ve kampanyadan çıkma hakkı bulunmaktadır. Kampanya kapsamında Flaş indirimler, indirimin tanımlanmasından veya güncellenmesinden itibaren; kampanyadan çıkma ise çıkma hakkının kullanılmasından itibaren 1 gün sonra kullanıcılara gösterilecek olup, tanımlanan veya güncellenen indirimler ya da kampanyadan çıkıldığı aynı gün içinde kullanıcıya gösterilmez.\nKampanyadan çıkmadan önce ilgili restoranda Flaş İndirim'in geçerli olduğunu gören kullanıcılar, siparişlerini indirimli olarak tamamlayabilir, diğer kullanıcılar ise restoranın kampanyadan çıktığı andan itibaren restoranı Flaş İndirim Restoranları arasında görmezler.\nUber Eats Trendyol Go kampanya tarihleri, indirim tutarı dahil olmak üzere Flaş İndirim kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda belirtilen tarihte yürürlüğe girecektir. Kampanyaya katılmış olan restoranlar, kampanyadan çıkmadıkları müddetçe, Uber Eats Trendyol Go tarafından yapılan değişikliklerin yürürlük tarihinden itibaren kendiliğinden geçerli olacağını kabul etmiş olacaktır.\nFlaş indirimler, sadece belli bir uygulamada geçerli olacağı özel olarak belirtilen ek indirimler saklı olmak üzere, hem Uber Eats Trendyol Go  uygulamasında hem de Trendyol uygulamasından erişim verilen Uber Eats Trendyol Go  kanalında geçerli olup, kullanıcının Flaş İndirim'den yararlanmasıyla oluşan indirimli sepet tutarının sipariş verilen restoranın minimum sepet tutarını karşılaması gerekmektedir.\nUber Eats Trendyol Go, Aracılık Hizmetleri'nin ve/veya satıcı ve alıcıların Platform ve ilgili Flaş indirim kampanya deneyiminin geliştirilmesi ve iyileştirilmesi amaçlarıyla sınırlı olarak ve bu amaçların gerektirdiği ölçüde, indirimlerin geçerli olduğu uygulama / kanal, indirimleri görebilecek kullanıcı kitlesi, kampanya kapsamında geçerli olacak indirim sayıları, indirimlerin geçerli olduğu şehir konuları başta olmak üzere çeşitli konularda Satıcı ve Alıcıların beklenti, tercih ve davranışlarını tespit etmeye yönelik geçici süreli test uygulamalarını devreye alabilecektir.\nSatıcının katıldığı bu kampanyaya ek olarak, aynı siparişte kullanıcı için daha avantajlı başka bir kampanya, indirim veya promosyonun da geçerli olması halinde; daha avantajlı olan kampanya, indirim veya promosyonun tutarı üst sınır oluşturmak kaydıyla, işbu kampanya ile diğer kampanya, indirim veya promosyon birleşebilecektir. Satıcı'nın karşılamayı üstlendiği tutar işbu kampanya için kullanılacak olup, birleşen kampanya kapsamında tüketiciye sunulacak ek faydanın maliyeti Uber Eats Trendyol Go tarafından karşılanacaktır.\n\n\n\x3c!-- OPT-215909 END --\x3e\n`;true;",relationalRule:[],isRelational:!1},817:{test:"(self=>{'use strict';const builderId=794;const variationId=Insider.campaign.userSegment.getActiveVariationByBuilderId(builderId);const surveyVariationId=1595;const storageName=`ins-survey-completed-${variationId}`;let sheetData={};let isStoreUser=true;const checkList={flag_ads_missing:'1620236070556',flag_mbs_status_zero:'6584706167200',flag_growth_tool_missing:'9167606206059',flag_foodcard_missing:'9313762656030',flag_kapida_odeme_missing:'1702736868057',flag_uptime_low:'1766519069033',flag_km2_low:'1407061196255',flag_image_low:'6151716320540',flag_description_low:'3605591046470',flag_score_null:'6446073405915',flag_product_count_low:'6718697134679'};const goExtCheckList=['flag_ads_missing','flag_growth_tool_missing','flag_foodcard_missing','flag_kapida_odeme_missing','flag_uptime_low','flag_image_low','flag_description_low','flag_score_null','flag_product_count_low'];const classes={style:`ins-custom-style-${variationId}`,wrapper:`ins-custom-wrapper-${variationId}`,container:`ins-custom-container-${variationId}`,goal:`sp-custom-${variationId}-1`,pointerImage:`ins-pointer-image-${variationId}`,popupWrapper:`ins-popup-wrapper-${variationId}`,popupContainer:`ins-popup-container-${variationId}`,popupCloseButton:`ins-popup-close-button-${variationId}`,buttonsContainer:`ins-buttons-container-${variationId}`,redirectButton:`ins-redirect-button-${variationId}`,closeButton:`ins-close-button-${variationId}`,popupBody:`ins-popup-body-${variationId}`,popupOverlay:`ins-popup-overlay-${variationId}`,fullProgressBar:`ins-full-progress-bar-${variationId}`,trueCheckbox:`ins-checkbox-true-${variationId}`,falseCheckBox:`ins-checkbox-false-${variationId}`,completedItems:`ins-completed-items-${variationId}`,cloneCompletedItems:`ins-clone-completed-items-${variationId}`,hide:`ins-hide-${variationId}`,completedTitleClass:`ins-completed-title-${variationId}`};const selectors=Insider.fns.keys(classes).reduce((createdSelector,key)=>{createdSelector[key]=`.${classes[key]}`;return createdSelector},{closeSurvey:'.ins-element-close-button',readyButton:'#button-3915487124648',progressBar:'.ins-progress-bar',appendElement:'.meal-footer__container',surveyWrapper:`.ins-preview-wrapper.ins-preview-wrapper-${surveyVariationId}`,optionContent:'.ins-element-content',checkboxButton:'.ins-checkbox-button',startSurveyButton:'#button-7406741596772',closeSurveyButton:'#button-3170874527441',surveyHolder:'.ins-survey-selection-container.ins-survey-holder',checkedItems:'.ins-survey-selection-checked',surveySelectionRow:'.ins-survey-selection-row'});const config={hamburgerImage:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/Gemini_Generated_Image_37qoe337qoe337qo_5_35-1778225527.png',redirectPage:{text:'Yapılacaklar listesindeki geri kalan maddeleri de tamamlayın, daha üst sıralarda görünerek rekabette geride kalmayın! Maddeleri tamamlamak için gereken tüm bilgileri eğitim sayfalarımızda bulabilirsiniz.',redirectButtonText:'Hemen İncele',closeButtonText:'Kapat',redirectLink:'https://tygoakademi.trendyol.com/Elearning?TrainingId=18565'},trueCheckboxColor:'green',falseCheckboxColor:'red',hyperLinks:{flag_ads_missing:'https://partner.tgoyemek.com/advert-management/',flag_mbs_status_zero:'https://partner.tgoyemek.com/meal-store/{{store_id}}/delivery-areas',flag_growth_tool_missing:'https://partner.tgoyemek.com/meal/promotions/{{store_id}}/dashboard',flag_foodcard_missing:'https://partner.tgoyemek.com/meal-store/{{store_id}}/payment-options',flag_kapida_odeme_missing:'https://partner.tgoyemek.com/meal-store/{{store_id}}/payment-options',flag_uptime_low:'https://partner.tgoyemek.com/meal-store/{{store_id}}/working-hours?tab=GO',flag_km2_low:'https://partner.tgoyemek.com/meal-store/{{store_id}}/delivery-areas',flag_image_low:'https://partner.tgoyemek.com/meal/{{store_id}}/menu/products',flag_description_low:'https://partner.tgoyemek.com/meal/{{store_id}}/menu/products',flag_score_null:'https://tygoakademi.trendyol.com/Elearning?TrainingId=15790',flag_product_count_low:'https://partner.tgoyemek.com/meal/{{store_id}}/menu/products'}};self.init=()=>{if(variationId&&!Insider.storage.localStorage.get(storageName)){Insider.storage.localStorage.remove(`sp-camp-${surveyVariationId}`);self.checkStoreIdFromSheet()}};self.checkStoreIdFromSheet=()=>{const storeId=Insider.fns.isFunction(window.meal?.getRestaurant??'')?String(window.meal.getRestaurant().id??0):'';const storePayload={builderId:builderId,payload:{sheet_name:'hourlySegment',page_name:'New checklist - STORE EXT',target_column:'store_id',target_value:String(storeId)}};const goPayload={builderId:builderId,payload:{sheet_name:'hourlySegment',page_name:'New checklist DS - GO EXT',target_column:'store_id',target_value:String(storeId)}};if(storeId){self.sendSheetRequest(storePayload,data=>{if(data.is_exists){sheetData=data;isStoreUser=true;self.showCampaign();return}self.sendSheetRequest(goPayload,goData=>{if(goData.is_exists){sheetData=goData;isStoreUser=false;self.showCampaign()}})})}};self.sendSheetRequest=(payload,callback)=>{if(Insider.fns.isFunction(Insider.__external.SendSheetRequest170480)){Insider.__external.SendSheetRequest170480(payload,callback)}else{Insider.logger.log(`Insider.__external.SendSheetRequest170480 is not a function!VID: ${variationId}`)}};self.showCampaign=()=>{if(!Insider.campaign.isControlGroup(variationId)){self.reset();self.buildCSS();self.buildHTML();self.setEvents();self.listenSurveyRequest()}Insider.campaign.custom.show(variationId)};self.reset=()=>{const{style,wrapper,popupOverlay,popupWrapper}=selectors;Insider.dom(`${style}, ${wrapper} , ${popupOverlay}, ${popupWrapper}`).remove()};self.buildCSS=()=>{const{container,wrapper,popupWrapper,popupContainer,popupCloseButton,pointerImage,buttonsContainer,redirectButton,closeButton,popupBody,popupOverlay,fullProgressBar,trueCheckbox,falseCheckBox,completedItems,hide,completedTitleClass}=selectors;const customStyle=`${wrapper}  {\n            display: block;\n        /* ZEN-142113 START */\n        animation: fadeInRightAndShake 1s ease-in-out;\n        }\n    \n        @keyframes fadeInRightAndShake {\n            0% {\n                opacity: 0;\n                transform: translateX(20px);\n            }\n            100% {\n                opacity: 1;\n                transform: translateX(0);\n            }\n            25% {\n                transform: translateX(-30px); \n            }\n            50% {\n                transform: translateX(30px);  \n            }\n            75% {\n                transform: translateX(-20px); \n            }\n            100% {\n                transform: translateX(0);\n            }\n        } /* ZEN-142113 END */\n        ${container} {\n            /* ZEN-154351 START */\n            position: relative;\n            background-color: #fff; \n            right : 40px; /* OPT-189871 */\n            /* ZEN-154351 END */\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            border-radius: 8px;\n            cursor: pointer;\n            height: 50px; /* OPT-216325 */\n        }\n        ${pointerImage} {\n            cursor: pointer;\n            height: 30px; /* OPT-216325 */\n        }\n        ${popupOverlay} {\n            position: fixed;\n            z-index: 98;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            opacity: 0.6;\n            background-color: rgb(0, 0, 0);\n        }\n        ${popupWrapper}  {\n            display: block;\n            position: absolute;\n            z-index: 99;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n        }\n        ${popupContainer} {\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            height: 400px;\n            width: 400px;\n            padding: 20px 40px;\n            color: black; /* QH-144463 */\n            background-color: #fff; /* QH-144463 */\n            border-radius: 10px;\n            text-align: center;\n            line-height: 1.5;\n            font-size: 18px; \n            font-family: \"Insider-Open Sans\", sans-serif; /* ZEN-159881 */\n        }\n        ${popupCloseButton} {\n            color: #ffffff;\n            cursor: pointer;\n            font-size: 28px;\n            line-height: 28px;\n            width: 28px;\n            font-family: Arial, sans-serif;\n            text-align: center;\n            position: absolute;\n            z-index: 100;\n            top: 6px;\n            right: 3px;\n            display: block;\n        }\n        ${popupBody} {\n            height: 300px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n        ${buttonsContainer} {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            gap: 15px;\n            height: 100px;\n            font-family: \"Insider-Open Sans\", sans-serif; /* ZEN-159881 */\n        }\n        ${redirectButton},\n        ${closeButton} {\n            padding: 10px 20px;\n            border-radius: 10px;\n            background-color: #f27a1a; /* QH-144463 */\n            border:none !important; /* QH-144463 */\n            color: white; /* QH-144463 */\n            font-weight: bold;\n            cursor: pointer;\n        }\n        ${redirectButton}:focus, /* QH-144463 */\n        ${redirectButton}:focus-visible, \n        ${closeButton}:focus, /* QH-144463 */\n        ${closeButton}:focus-visible {\n            outline: none;\n        }\n        ${fullProgressBar} {\n            width: 100% !important;\n        }\n        /* OPT-216325 START */\n        ${trueCheckbox} {\n            background: url(https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/accept-1778225659.png);\n            background-size: cover;\n            border: unset !important;\n        }\n        ${falseCheckBox} {\n            background: unset !important;\n        }\n        ${completedItems} {\n            padding: 0 30px;\n            text-align: left !important;\n        }\n        ${hide} {\n            display: none !important;\n        }\n        ${completedTitleClass} {\n            text-decoration: underline;\n            color: #141415;\n            opacity: 0.5;\n            display: block;\n            margin-top: 12px;\n            font-size: 14px !important;\n            text-align: start !important;\n            padding: 0 30px;\n        }\n        /* OPT-216325 END */`;Insider.dom('<style>').addClass(classes.style).html(customStyle).appendTo('head')};self.buildHTML=()=>{const{container,wrapper,goal,pointerImage}=classes;const outerHTML=`<div class=\"${wrapper} ${goal}\">\n            <div class=\"${container}\">\n                <img class=\"${pointerImage}\" src=\"${config.hamburgerImage}\"/>\n            </div>\n        </div>`;Insider.dom(selectors.appendElement).prepend(outerHTML)};self.setEvents=()=>{const{popupWrapper,popupOverlay,pointerImage,redirectButton,closeButton,popupCloseButton,readyButton,progressBar,closeSurvey,startSurveyButton,closeSurveyButton,surveyWrapper}=