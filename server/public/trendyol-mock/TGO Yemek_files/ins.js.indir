${subHeaderTitle}</div>\n                    </div>\n                    <div class=\"${packageIncludedText}\">${includedText}</div>\n                    <div class=\"${packageIncludedItems}\">\n                        ${includedItems.map(({icon})=>`<img class=\"${packageIncludedIcon}\" src=\"${icon}\" />`).join('')}\n                    </div>\n                    <div class=\"${packageAdvertisingText}\">${advertisingText}</div>\n                    <div class=\"${packageAdvertisingPrice}\">${originalPrice}${currencyIcon}</div>\n                    <div class=\"${packageBalanceText}\">${balanceText}</div>\n                    <div class=\"${packagePriceContainer}\">\n                        <div class=\"${packageOriginalPrice}\">${originalPrice}${currencyIcon}</div>\n                        <div class=\"${packageDiscountPrice}\">${discountPrice}${currencyIcon}</div>\n                        <div class=\"${packageDiscountPercent}\">\n                            <div class=\"${packageDiscountValue}\">\n                                ${discountValue}${discountIcon}\n                            </div>\n                            <div class=\"${packageDiscountText}\">${discountText}</div>\n                        </div>\n                        <div class=\"${packageTagIcon}\"><img src=\"${tagIcon}\"/></div>\n                    </div>\n                </div>\n                <div class=\"${packageSelectPackageButton}\n                    ${isSelectedPackage?packageSelectPackageButtonActive:''}\n                    ${isPassivePackage?packageSelectPackageButtonPassive:''}\">\n                    ${isSelectedPackage?selectedPackageText:selectPackageText}\n                </div>\n                <div class=\"${packageInformationButton}\">${informationText}</div>\n            </div>`},'');return packageHTML};self.getPackageSubHeaderIcon=(index,subHeaderIcon)=>Array.from({length:index+1},()=>`<img class=\"${classes.packageSubHeaderIcon}\" src=\"${subHeaderIcon}\"/>`).join(