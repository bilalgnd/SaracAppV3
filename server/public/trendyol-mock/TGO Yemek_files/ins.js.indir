rapper,stickyWrapper,stickyButton,hide,mainText,textArea,buttonArea}=selectors;const tabletStyle=Insider.browser.isTablet()?`${wrapper} {\n                bottom: 44px !important;\n            }`:'';const customStyle=`${wrapper} ${minimizeWrapper} {\n            position: absolute;\n            z-index: 1;\n            top: 8px;\n            right: 30px;\n            display: block;\n            font-weight: bold;\n            font-size: 16px;\n            color: #fff;\n            padding: 0 5px;\n            cursor: pointer;\n        }\n        ${wrapper} ${stickyWrapper} {\n            display: none !important; /* OPT-154553 */\n            background-color: #f27919;\n            height: 43px;\n            width: 440px;\n            bottom: -305px;\n            position: fixed;\n            z-index: 2147483647;\n            border-radius: 10px !important;\n            position: relative;\n            bottom: -1px;\n        }\n        ${stickyWrapper}{\n            display: flex !important;\n            background-color: #484d5a !important;\n            color: #fff !important;\n            align-items: center;\n            justify-content: space-between;\n        }\n        ${wrapper} ${textArea} img {\n            width: 16px;\n            height: 16px;\n            margin: 0 10px;\n        }\n        ${textArea} {\n            display: flex !important;\n            align-items: center;\n        }\n        ${mainText} {\n            font-weight: bold;\n            margin-right: 10px;\n        }\n        ${wrapper} ${stickyButton} {\n            position: absolute;\n            right: 0;\n            font-weight: bold;\n            font-size: 16px;\n            color: #fff;\n            padding: 8px;\n            cursor: pointer;\n            justify-content: center;\n            display: flex;\n            align-content: center;\n            flex-wrap: wrap;\n            align-items: center;\n            height: inherit;\n        }\n        ${wrapper} {\n            /* OPT-154553 START */\n            bottom: 60px !important;\n            left: 50% !important;\n            /* OPT-154553 END */\n            top: initial !important;\n            -webkit-transform: translate(-50%, 0%) !important;\n            -ms-transform: translate(-50%, 0%) !important;\n            transform: translate(-50%) !important;\n            position: fixed !important;\n            z-index: 2147483647 !important;\n        }\n        ${buttonArea} {\n            display: flex !important;\n            align-items: center;\n            justify-content: center;\n            width: 32px;\n            height: 32px;\n            cursor: pointer;\n        }\n        ${hide} {\n            display: none !important;\n        }\n        ${tabletStyle} /* OPT-154553 */`;Insider.dom('<style>').addClass(classes.style).html(customStyle).appendTo('head')};self.addCustomHtml=()=>{const{minimizeButton,stickyWrapper,stickyButton,mainText,textArea,buttonArea,hide}=classes;const{content}=selectors;const{mainText:mainTextConfig,eyesEmoji,upArrow,downArrow}=config;const stickyHtml=`<div class=\"${stickyWrapper}\">\n            <div class=\"${textArea}\">\n                <img src=\"${eyesEmoji}\">\n                <div class=\"${mainText}\">${mainTextConfig}</div>\n            </div>\n            <div class=\"${buttonArea}\">\n                <img src=\"${upArrow}\" class=\"${hide} ${stickyButton}\">\n                <img src=\"${downArrow}\" class=\"${minimizeButton}\">\n            </div>\n        </div>`;Insider.dom(content).after(stickyHtml)};self.setEvents=()=>{const{minimizeButton,content,stickyButton}=selectors;const{hide}=classes;Insider.eventManager.once(`click.button:minus:${variationId}`,`${minimizeButton}, ${stickyButton}`,event=>{if(event.target.className.includes(classes.minimizeButton)){Insider.dom(content).fadeOut(200);Insider.dom(stickyButton).removeClass(hide);Insider.dom(minimizeButton).addClass(hide);Insider.campaign.info.storeCloseLog(variationId)}else{Insider.dom(content).fadeIn(200);Insider.dom(stickyButton).addClass(hide);Insider.dom(minimizeButton).removeClass(hide)}});if(Insider.fns.isFunction(Insider.__external.xhrListener)){Insider.__external.xhrListener((url,response,ajaxData)=>{if(url.includes('/v2/form/save-questionnaire/')&&Insider.fns.parse(ajaxData)?.campaign_id===Number(variationId)&&!Insider.__external.isRequestSent161956){Insider.__external.isRequestSent161956=true;const otherPlatformId=!isDesktop?371:370;self.sendSellerId();self.sendSubmitRequest(builderId);setTimeout(()=>{self.sendSubmitRequest(otherPlatformId)},100)}})}else{Insider.logger.log(`xhrListener is not a function. varId: ${variationId}`)}};self.sendSubmitRequest=campId=>{delete npsPayload.expires;npsPayload.camp_id=campId;Insider.storage.localStorage.set({name:config.visibilityStorageName,value:true,expires:333});self.sendSurveyListRequest(npsPayload)};self.sendSellerId=()=>{const partnerName=Insider.partner.name;const userSellerId=(Insider.storage.localStorage.get('insCustomAttributes')||{}).store_id_v2||'';const lastPageInputId=isDesktop?'5721720007319':'5010588069732';const leadData={form_data:[{type:'text',id:lastPageInputId,text:'text',options:[{id:lastPageInputId,text:userSellerId,type:'text'}],required_question:'true',questionId:lastPageInputId}],uid:Insider.getUserId(),campaign_id:Number(variationId),source:Insider.fns.parseURL().rawHref,coupon_action:{type:'none',email:'',coupon_code:''}};Insider.request.post({url:`https://carrier.useinsider.com/v2/form/save-questionnaire/${partnerName}`,headers:{'Content-Type':'application/json',partner:partnerName},parse:true,data:Insider.fns.stringify(leadData),success:()=>{Insider.eventManager.dispatch('leadCollection:userData:sent',{campaignId:variationId,formData:leadData.form_data,email:userSellerId})},error:xhr=>{Insider.logger.log(xhr.response)}})};self.markCampaignAsViewed=()=>{Insider.storage.localStorage.set({name:config.visibilityStorageName,value:true,expires:Insider.dateHelper.addMinutes(npsPayload.expires).getTime()})};self.init()})({});",relationalRule:[],isRelational:!1},462:{test:'Insider.__external.standardPackageContent198199=()=>`\n    <div id="package-conditions">STANDART  PAKET KATILIM KOŞULLARI</div>\x3c!-- OPT-200885 --\x3e\n    STANDART  PAKET KATILIM KOŞULLARI\nSTANDART PAKET KAPSAMINDA REKLAM BAKİYESİ TANIMLAMA \nSatıcı mağazasına, Satıcı’nın “Standart Paket” onay metnini kabul edip, 2.100 TL tutarındaki reklam bakiyesini ayrıca yüklemesini takiben 3.000 TL’lik reklam bakiyesi tanımlanır. 2100 TL ve katlarında yapılacak reklam bakiyesi yüklemelerinde, tek seferlik 3000 TL’lik reklam bakiyesi tanımlanır. Reklam oluşturma işlemi mağaza bazlı olup, satıcının dilediği mağazalarında bakiye yükleyerek reklam oluşturması mümkündür. \nOtomatik olarak, bakiye yüklenen tarihten 45 gün sonrasına kadar sürecek şekilde reklam oluşturulur. Bu süre reklamın geçerli olabileceği maksimum süredir, bütçe harcama hızına bağlı olarak reklam bu süreden daha önceki bir tarihte sona erebilecektir. Satıcı’nın birden fazla mağazası için Reklam Yönetimi sayfasında herhangi bir şekilde reklam başlatmış olması halinde, yüklenen toplam bakiye satıcının reklam veren tüm  mağazaları  için geçerli olacak toplam bakiyeyi oluşturur.  Bu durumda Hızlı Başlangıç Paketleri kapsamında açılan yeni reklam 45 günlük süreden daha erken bir sürede sonuçlanabilir. Satıcı bakiye yükleme ekranından bakiye takviyesi yaparak reklamını devam ettirebilir.\nReklam oluşturma işlemi, Hızlı Başlangıç Paketini onaylayan mağazanın bakiye yüklemesini takip eden 1 günlük süre 4. maddede düzenlenen koşullarda yeni bir reklam oluşturulması ile olur. Bu süre içinde, herhangi bir şekilde, ilgili mağazanın dahil olduğu bir aktif reklam olması halinde paket kapsamında reklam açma işlemi yapılmaz. Satıcı yüklediği bakiyesi ile aktif reklamı sonlanınca kendisi yeni bir reklam açabilir.\nBütçe tipi “Günlük” olarak seçilir. Günlük bütçe 300 TL olarak seçilir. Bu durumda satıcı 3.000 TL’lik reklam bakiyesini maksimum 45 gün içerisinde günlük maksimum 300 TL hedeflenerek reklam bakiyesi bitene kadar kullanır.\nHızlı Başlangıç Paketi kapsamında tanımlanan reklamlarda, tıklama başına maliyet dinamik olacak şekilde TYG Turkey tarafından belirlenir.  \nSatıcı dilediği zaman reklam kullanımını durdurabilir.\nBelirtilen şartlar dışında, aşağıda yer verilen Reklam Hizmeti Kullanım Koşulları da geçerli olacaktır. \n\nB. REKLAM HİZMETİ KULLANIM KOŞULLARI\nİşbu Reklam Hizmeti Kullanım Koşulları (“Kullanım Koşulları”), Satıcı’nın, Satıcı Paneli’nde bulunan Reklam Yönetimi sayfasında, işbu Kullanım Koşulları’nda tanımlanan anlamıyla herhangi bir İşlem yapması halinde geçerli olacak şart ve koşulları düzenlemektedir. \n1. Reklam Bakiyesi Yükleme\nSatıcının reklam oluşturabilmesi için öncelikle reklam bakiyesi yüklemesi gerekmektedir. İstenilen tutarda reklam bakiyesi yüklenebilmekte olup, tek seferde en fazla 10.000.000 TL (on milyon türk lirası) reklam bakiyesi yüklemek mümkündür. Yüklenen reklam bakiyesinin ödemesi iki şekilde yapılabilir:\n Hesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür)\nYüklenen reklam bakiyesinin tutarı kredi kartı ile ödenebilir.\nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, reklam bakiyesi yüklendiği anda yüklenen bakiye tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez.\n Aksi duyurulmadığı müddetçe, yüklenen reklam bakiyelerinin herhangi bir son kullanım tarihi bulunmamaktadır. Yüklenen bakiye tüketilene kadar kullanılabilir. \nSatıcıların tercih etmeleri halinde otomatik reklam bakiyesi yükleme talimatı vermeleri de mümkündür. Bu talimatı vermekle satıcı, mevcut reklam bakiyesinin kendisi tarafından belirlenen tutarın altına düştüğü her sefer için, belirlemiş olduğu tutarın otomatik olarak reklam bakiyesine aktarılmasını kabul eder. Otomatik reklam bakiyesi yükleme talimatı neticesinde yapılan yüklemelerin faturalanması ve ödenmesi bakımından işbu Kullanım Şartları’nda düzenlenen şart ve koşullar geçerli olacaktır. Satıcı, vermiş olduğu otomatik reklam bakiyesi yükleme talimatını her zaman Reklam Yönetimi sayfası altından iptal edebilir. TYG Turkey tarafından zaman zaman belirli kural setlerine uygun olarak belirlenebilecek satıcı gruplarına çeşitli reklam bakiyesi kampanyaları sunulabilecektir. Bu kampanyalar “Bakiye Satın Al” sayfası altından incelenebilir. \nTYG Turkey tarafından başlatılan reklam bakiyesi kampanyalarından yararlanmak isteyen satıcılar, kampanya kapsamında TYG Turkey tarafından karşılanacağı duyurulan tutarın düşürülmesi neticesinde kalan bakiyeyi ödeyerek reklam bakiyesi yükleyebilecektir. (Örneğin, TYG Turkey tarafından 2000 TL’lik reklam bakiyesi yüklemelerinin, 225 TL’sinin TYG Turkey tarafından karşılanacağı duyurulmuşsa, satıcı 1775 TL tutarında ödeme yaparak 2000 TL’lik reklam bakiyesi yükleyebilecektir.)\n2. Hediye Bakiye\nHediye bakiye sayfasından, TYG Turkey tarafından satıcılara karşılıksız olarak yüklenebilecek hediye reklam bakiye tutarlarına erişilebilir. TYG Turkey, hediye bakiyelere son kullanım tarihi belirleyebilir, son kullanım tarihinin belirlenmesi halinde, bu tarihe kadar kullanılmayan reklam bakiyeleri geçerliliğini kaybeder. \n\n3. Reklam Oluşturma\nSatıcı reklam oluşturabilmek için Reklam Oluşturma Sayfası üzerinden, reklamına bir ad verip, reklamın geçerli olacağı tarih aralığını belirler. Satıcı tarafından belirlenen reklam adı müşterilere gözükmeyecek olup, satıcının raporlamalarında reklam metriklerini takip edebilmesi amacıyla kullanılır.\nSiparişlerinin teslimatının Satıcı tarafından yapıldığı model ile çalışan satıcılar, ayrıca reklamların gözükeceği dağıtım bölgelerini tercih edebilir.\nSatıcı tüm veya belirli şubeleri özelinde reklam başlatabilir. Bunun için reklamın geçerli olacağı şubeleri tanımlaması gerekir.\nSatıcı tarafından reklam harcamaları için günlük bütçe tutarı ve tıklama başına maliyet belirlenmelidir. Minimum 200 TL olmak kaydıyla, Satıcı tarafından belirlenen günlük bütçe her gün satıcının yüklemiş olduğu reklam bakiyesinden çekilir. Tıklama başına maliyet, kullanıcıların satıcı tarafından başlatılan reklama her tıkladığında günlük bütçeden çekilecek tutara karşılık gelmekte olup, belirlenebilecek minimum tıklama başına maliyet 7.5 TL iken, maksimum tıklama başına maliyet 20 TL’dir.\nSatıcı ayrıca seçtiği belirli bir tarih aralığı için geçerli olacak toplam bütçeyi ve tıklama başına maliyeti belirleyip, belirlemiş olduğu toplam bütçenin reklamının geçerli olacağı tarih içindeki dağılımını TYG Turkey tarafından yapılmasını da tercih edebilir. Satıcının bu tercihte bulunması, herhangi bir şekilde satıcıya sıralanma/listeleme garantisi veya bütçenin seçilen tarih aralığında kısmen/tamamen harcanılacağı taahhüdü vermemektedir.\nTYG Turkey tarafından zaman zaman satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, reklam bakiyesi yükleyen satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder.\nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Kullanım Koşullarının tüm hükümlerini ve reklam oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\n4. Abonelik Sistemi\nSatıcılar oluşturdukları reklamların işbu Abonelik Sistemi Şart ve Koşulları uyarınca, satıcının sonradan aboneliklerini sonlandırmayı tercih edecekleri tarihe kadar sürekli olarak yenilenmesini tercih edebilir.\nAbonelik oluşturabilmek için satıcının öncelikle ilgili sayfada kendisine TYG Turkey tarafından önerilen reklam paketlerinden birini tercih etmesi ya da tarih, bütçe, tıklama başına maliyet, şube tercihlerini yaparak şart ve koşullarını kendisinin belirlediği bir reklam oluşturması gerekmektedir. Satıcı, TYG Turkey tarafından oluşturulan reklam paketlerini paket kapsamında satıcıya önerilen bütçe, tarih, tıklama başına maliyet, şube seçeneklerini de özelleştirerek reklam oluşturma imkanına sahiptir. TYG Turkey tarafından satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, satıcı dilerse reklamını oluştururken tıklama başına maliyetin TYG Turkey tarafından belirlenmesini tercih edebilir.\nSatıcının abonelik sistemini başlatması halinde, satıcının oluşturduğu reklam, ilgili reklamın bitiş tarihinin dolması üzerine, reklamın geçerli olduğu dönem uzunluğunda tekrar etmeye devam eder. Örneğin, satıcının başlangıçta 7 günlük bir reklam oluşturması ve bu reklamla birlikte abonelik sistemine geçmesi halinde, 7 günlük reklam süresinin dolması üzerine, oluşturulan reklam satıcının tercih etmiş olduğu bütçe, tıklama başına maliyet ve şube tercihleri ile birlikte 7’şer günlük dönemlerde devam etmeye devam edecektir.\nSatıcı, Reklam Yönetimi sayfasında yer alan “Abonelik İptal Et” seçeneğini tercih ederek abonelik sisteminden çıkma imkanına sahiptir. Satıcının bu tercihte bulunması halinde, mevcutta geçerli olan reklamının bitiş tarihinin sona ermesi beklenir ve bu tarihin dolması üzerine ilgili reklam yenilenmez.\nAbonelik sistemini başlatmak isteyen satıcının ödemeleri iki şekilde yapılabilir:\nHesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür. Şüpheye mahal vermemek adına, satıcının tercih etmiş olduğu reklam bütçesinin içeride bulunan ve ancak henüz ödemesi Satıcıya yapılmamış hakediş tutarından fazla olması halinde satıcı bu opsiyon uyarınca ödeme gerçekleştiremeyecek ve abonelik başlatamayacaktır.)\nSatıcının reklam cüzdanında yeterli bakiye olması halinde, ödemeler reklam cüzdanından düşülür.\nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, yapılan ödeme tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez.\nReklam oluşturan satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder.\nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Abonelik Sistemi Şart ve Koşullarının tüm hükümlerini ve reklam oluşturma/abonelik oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\n5. Diğer Hükümler\nReklam Yönetimi sekmesine girmeniz, bu sekmede yer alan herhangi bir bilgiyi kullanmanız ve bu sekmede herhangi bir işlem yapmış olmanız (Hepsi birlikte "İşlem" olarak kullanılacaktır) aşağıdaki koşulları kabul ettiğiniz anlamına gelir.\nİşlem yapılması sebebiyle, herhangi bir sözleşmenin ihlali, haksız fiil ya da başkaca sebeplere binaen, doğabilecek doğrudan ya da dolaylı hiçbir zarardan TYG Turkey veya herhangi bir grup şirketi sorumlu değildir. TYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti hususunda herhangi bir sorumluluk kabul etmez.\nTYG Turkey işbu Reklam Yönetimi sekmesi başta olmak üzere, Satıcı Paneli ve uzantısında mevcut her tür hizmet, ürün, uygulamayı kullanma koşulları ile uygulamada sunulan bilgileri önceden bir ihtara gerek olmaksızın değiştirme, uygulamayı yeniden organize etme, yayını durdurma hakkını saklı tutar. Değişiklikler, aksi duyurulmadığı müddetçe, uygulamada yayın anında yürürlüğe girer. İşlem yapılması ile bu değişiklikler de kabul edilmiş sayılır. Bu koşullar link verilen diğer web sayfaları/uygulamalar için de geçerlidir.\nTYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti, silinme, kayıp, işlemin veya iletişimin gecikmesi, bilgisayar virüsü, iletişim hatası, hırsızlık, imha veya izinsiz olarak kayıtlara girilmesi, değiştirilmesi veya kullanılması hususunda herhangi bir sorumluluk kabul etmez. \nReklam Yönetimi alanı/sekmesi TYG Turkey’nin kontrolü altında olmayan başka internet sitelerine / uygulamalara bağlantı veya referans içerebilir. TYG Turkey, bu sitelerin/uygulamaların içerikleri veya içerdikleri diğer bağlantılardan sorumlu değildir.\nTYG Turkey Reklam Yönetimi alanının/sekmesinin genel görünüm ve dizaynı ile alandaki/sekmedeki tüm bilgi, resim, Trendyol Go markası ve diğer markalar, işbu İşlem yapılan uygulama adı, logo, ikon, demonstratif, yazılı, elektronik, grafik veya makinede okunabilir şekilde sunulan teknik veriler, bilgisayar yazılımları, uygulanan satış sistemi, iş metodu ve iş modeli de dahil tüm materyallerin (\\"Materyaller\\") ve bunlara ilişkin fikri ve sınai mülkiyet haklarının sahibi veya lisans sahibidir ve yasal koruma altındadır. Reklam Yönetimi alanında/sekmesinde bulunan hiçbir Materyal; önceden izin alınmadan ve kaynak gösterilmeden, kod ve yazılım da dahil olmak üzere, değiştirilemez, kopyalanamaz, çoğaltılamaz, başka bir lisana çevrilemez, yeniden yayımlanamaz, başka bir bilgisayara yüklenemez, postalanamaz, iletilemez, sunulamaz ya da dağıtılamaz. Reklam Yönetimi alanının/sekmesinin bütünü veya bir kısmı başka bir internet sitesinde/uygulamada izinsiz olarak kullanılamaz. Aksine hareketler hukuki ve cezai sorumluluğu gerektirir.TYG Turkey’nin burada açıkça belirtilmeyen diğer tüm hakları saklıdır.\nTYG Turkey, dilediği zaman bu Kullanım Koşulları sayfasının içeriğini önceden duyurmak kaydıyla, güncelleme yetkisini saklı tutmaktadır ve kullanıcılarına Reklam Yönetimi alanına/sekmesine her girişte ayrıca Kullanım Koşulları sayfasını ziyaret etmelerini tavsiye etmektedir.\n\nC. SEPET İNDİRİMİ KAMPANYASI \nSTANDART PAKET KAPSAMINDA MAĞAZANIZIN SEPET İNDİRİMİ  KAMPANYASINA KATILIMI, TURBO PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nSEPET İNDİRİMİ KATILIM KOŞULLARI\nKampanya kapsamında, 400 TL ve üzeri siparişlerde 125 TL indirim uygulanır.\nSiparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 400 TL\'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 400 TL olması gerekmektedir.\nİndirimin tamamı restoran tarafından karşılanacaktır.\nHerhangi bir kullanıcı bakımından kampanyadan yararlanabilme sınırı (kampanyaya katılma sayısı vb.) bulunmamaktadır.\nKampanya ilk olarak 01 Ocak 2025 tarihinde başlayıp, Trendyol Yemek tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir. Satıcı vermiş olduğu onayla, kampanya başlangıç tarihinden sonra kampanyadan çıkmadığı müddetçe kampanyanın onay vermiş olduğu mağazasında geçerli olacağını kabul eder. Kampanyaya katılım ve kampanyadan çıkış işlemleri kampanya başlangıç tarihinden sonra herhangi bir zamanda yapılabilir.\nTrendyol Yemek kampanya tarihleri, indirim tutarı, minimum sepet tutarı dahil olmak üzere kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda belirtilen tarihte yürürlüğe girecektir. Kampanyaya katılmış olan restoranlar, kampanyadan çıkmadıkları müddetçe, Trendyol Yemek tarafından yapılan değişikliklerin yürürlük tarihinden itibaren kendiliğinden geçerli olacağını kabul etmiş olacaktır.\nBu kampanya, Flaş İndirim kampanyası, Yedikçe İndirim, kupon, indirim kodu ve maliyetinin tamamına satıcının katlandığı sepet indirimleri ile birleştirilemez. Maliyetine kısmen satıcının katlandığı veya maliyetine tamamen Trendyol Yemek’in katlandığı sepet indirimleri işbu kampanya şartlarında belirtilen sınırlamalara tabi olarak birleştirilebilir.\nAynı anda birden fazla kampanyaya katılmanız halinde indirim miktarı yüksek olan kampanya geçerli olacaktır.\nTrendyol Yemek, kampanya süresinde ve koşullarında değişiklik yapma hakkını saklı tutar.\nİndirime sınırlı sayıda restoran katılabilecek olup, kampanya Trendyol Yemek tarafından duyurularla desteklenecektir.\nBu kampanyanın tamamı satıcı tarafından karşılanacaktır.\nSatıcının katıldığı bu kampanyaya ek olarak, aynı siparişte kullanıcı için daha avantajlı başka bir kampanya, indirim veya promosyonun da geçerli olması halinde; daha avantajlı olan kampanya, indirim veya promosyonun tutarı üst sınır oluşturmak kaydıyla, işbu kampanya ile diğer kampanya, indirim veya promosyon birleşebilecektir. Satıcı’nın karşılamayı üstlendiği tutar işbu kampanya için kullanılacak olup, birleşen kampanya kapsamında tüketiciye sunulacak ek faydanın maliyeti Trendyol Yemek tarafından karşılanacaktır.\nBu kampanyanın tamamı satıcı tarafından karşılanacaktır.\n`;true;',relationalRule:[],isRelational:!1},463:{test:'Insider.__external.advantagePackageContent198199=()=>`\n    <div id="package-conditions">AVANTAJ PAKET KATILIM KOŞULLARI</div> \x3c!-- OPT-200885 --\x3e\n   AVANTAJ PAKET KATILIM KOŞULLARI\nAVANTAJ PAKET KAPSAMINDA REKLAM BAKİYESİ TANIMLAMA \nSatıcı mağazasına, Satıcı’nın “Avantaj Paket” onay metnini kabul edip, 2.400 TL tutarındaki reklam bakiyesini ayrıca yüklemesini takiben 4.000 TL’lik reklam bakiyesi tanımlanır. 2400 TL ve katlarında yapılacak reklam bakiyesi yüklemelerinde, tek seferlik 4000 TL’lik reklam bakiyesi tanımlanır. Reklam oluşturma işlemi mağaza bazlı olup, satıcının dilediği mağazalarında bakiye yükleyerek reklam oluşturması mümkündür. \nOtomatik olarak, bakiye yüklenen tarihten 45 gün sonrasına kadar sürecek şekilde reklam oluşturulur. Bu süre reklamın geçerli olabileceği maksimum süredir, bütçe harcama hızına bağlı olarak reklam bu süreden daha önceki bir tarihte sona erebilecektir. Satıcı’nın birden fazla mağazası için Reklam Yönetimi sayfasında herhangi bir şekilde reklam başlatmış olması halinde, yüklenen toplam bakiye satıcının reklam veren tüm  mağazaları  için geçerli olacak toplam bakiyeyi oluşturur.  Bu durumda Hızlı Başlangıç Paketleri kapsamında açılan yeni reklam 45 günlük süreden daha erken bir sürede sonuçlanabilir. Satıcı bakiye yükleme ekranından bakiye takviyesi yaparak reklamını devam ettirebilir.\nReklam oluşturma işlemi, Hızlı Başlangıç Paketini onaylayan mağazanın bakiye yüklemesini takip eden 1 günlük süre 4. maddede düzenlenen koşullarda yeni bir reklam oluşturulması ile olur. Bu süre içinde, herhangi bir şekilde, ilgili mağazanın dahil olduğu bir aktif reklam olması halinde paket kapsamında reklam açma işlemi yapılmaz. Satıcı yüklediği bakiyesi ile aktif reklamı sonlanınca kendisi yeni bir reklam açabilir.\nBütçe tipi “Günlük” olarak seçilir. Günlük bütçe 300 TL olarak seçilir. Bu durumda satıcı 4.000 TL’lik reklam bakiyesini maksimum 45 gün içerisinde günlük maksimum 300 TL hedeflenerek reklam bakiyesi bitene kadar kullanır.\nHızlı Başlangıç Paketi kapsamında tanımlanan reklamlarda, tıklama başına maliyet dinamik olacak şekilde TYG Turkey tarafından belirlenir.  \nSatıcı dilediği zaman reklam kullanımını durdurabilir.\nBelirtilen şartlar dışında, aşağıda yer verilen Reklam Hizmeti Kullanım Koşulları da geçerli olacaktır. \n\n\t \n\n\nB. GO PLUS\nAVANTAJ PAKET KAPSAMINDA MAĞAZANIZIN GO PLUS KATILIMI, AVANTAJ PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nGo Plus Katılım Koşulları\nKullanıcılar her bir takvim ayı boyunca Go Plus programı kapsamında ulaştıkları seviyenin kupon kazanımına yeterli olması halinde Trendyol veya Trendyol Go uygulamalarında geçerli toplamda her bir takvim ayı için 2 adet olacak şekilde her biri 60 TL tutarında Go Plus kuponu kazanır.\nGo Plus kuponları kullanıcının Go Plus programı kapsamında ulaştığı seviyeye bağlı olarak kazanılabilir, kazanılan Go Plus kuponları Go Plus kampanyasına dahil olmuş restoranlarda (“Go Plus restoranları”) harcanabilir.\nBir kullanıcı bir siparişte tanımlanan Go Plus kuponlarından yalnızca bir tanesini kullanabilecektir. Her siparişte 1 kupon kullanılabilecektir. Go Plus kuponları yalnızca kazanıldıkları takvim ayı içerisinde geçerli olacaktır, bir sonraki takvim ayına devretmez.\nTrendyol ve Trendyol Go uygulamalarında kullanıcılara tanımlanacak 2 adet kupona ek olarak yalnızca Trendyol Go uygulamasını kullanan kullanıcıların faydalanabileceği üçüncü, dördüncü ve beşinci Go Plus kuponları aktif olacaktır. Bu kuponlar da Go Plus programı kapsamında kullanıcının ulaştığı seviyeye bağlı olarak tanımlanacak olup, üçüncü kuponun değeri 60 TL; dördüncü ve beşinci kuponların değeri ise sırasıyla 75 TL ve 90 TL olacak, Go Plus kuponlarının koşullarına tabi olacak ve Go Plus kampanyasına dahil olmuş restoranlarda (“Go Plus restoranları”) harcanabilecektir.\nSatıcı, kullanılan kupon tutarından bağımsız olarak, kullanıcı tarafından kullanılan ilk üç kupon için, her bir kuponun 60 TL’lik tutarının maliyetini karşılar. Satıcı tarafından karşılanan kısmı aşan kupon tutarlarının maliyeti Trendyol Yemek tarafından karşılanır.\nİndirimde karşıladığınız tutar üzerinden komisyon kesintisi yapılmayacaktır.\nKullanıcılar Go Plus kuponunu diğer kampanyalarla birleştiremez.\nGüncellenen şartlarıyla kampanya belirtilen güncelleme tarihlerinde başlayacak olup, Trendyol tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir.\nGo Plus Yemek Kuponu Kampanyasına katılan restoranlar ana sayfada, Go Plus sayfasında, filtrelerde ve birçok farklı alanda listelenecektir.\nKampanya Trendyol Yemek tarafından duyurular ve reklamlarla desteklenecektir.\nTrendyol kampanya tarihleri, kupon adedi, kupon tutarı, kupon maliyetinin kimin tarafından hangi oranda karşılanacağı dahil olmak üzere Go Plus kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda daha ileri bir tarih belirtilmediği müddetçe duyurunun çıkılmasından 7 gün sonra kendiliğinden yürürlüğe girecektir. Restoran lehine yapılacak değişiklikler duyurunun çıkılmasından 1 gün sonra kendiliğinden yürürlüğe girecektir.\nRestoran vermiş olduğu onay ile Go Plus kuponlarının maliyetlerini karşılamayı ve restoranında platform üzerinden kazanılmış Go Plus kuponlarının kullanılabilmesini kabul etmiş olacaktır. Go Plus kampanyası restoran tarafından kampanyadan çıkılmadığı veya Trendyol Yemek tarafından iptal edilmediği müddetçe süresiz olarak yürürlükte kalacaktır.\nGo Plus Yemek Kuponu kampanyasına herhangi bir zamanda katılma ve kampanyadan çıkma hakkı bulunmaktadır.\nKampanya süresince yapacağınız katıl/çık işlemleri, kullanıcı memnuniyeti sebepli uygulamaya 1 saat sonrasında yansıyacaktır.\nTYG Turkey, Go Plus programının, Go Plus kampanya koşullarının ve/veya Platform kullanıcılarının (Satıcı ve Alıcı da dahil) Go Plus programı ve/veya Go Plus kampanya deneyiminin geliştirilmesi ve iyileştirilmesi amaçlarıyla sınırlı olarak ve bu amaçların gerektirdiği ölçüde, Platform kullanıcılarının (Satıcı ve Alıcı da dahil) beklenti, tercih ve davranışlarını tespit etmeye yönelik kullanıcı grupları bazlı veya kullanıcı gruplarına kampanya kapsamında sağlanan menfaatler özelinde satıcıya ilave maliyet yüklemeksizin geçici süreli, mevzuata uygun test uygulamalarını devreye alabilecektir.\nKullanıcının Go Plus kuponu kullanılmadan önceki sepet tutarının minimum 150 TL olması ve Go Plus kuponunun kullanılmasıyla oluşan sepet tutarının her koşulda restoranının minimum sepet tutarını karşılaması gerekmektedir.\n\n\n\n\nC. REKLAM HİZMETİ KULLANIM KOŞULLARI\nİşbu Reklam Hizmeti Kullanım Koşulları (“Kullanım Koşulları”), Satıcı’nın, Satıcı Paneli’nde bulunan Reklam Yönetimi sayfasında, işbu Kullanım Koşulları’nda tanımlanan anlamıyla herhangi bir İşlem yapması halinde geçerli olacak şart ve koşulları düzenlemektedir. \n1. Reklam Bakiyesi Yükleme\nSatıcının reklam oluşturabilmesi için öncelikle reklam bakiyesi yüklemesi gerekmektedir. İstenilen tutarda reklam bakiyesi yüklenebilmekte olup, tek seferde en fazla 10.000.000 TL (on milyon türk lirası) reklam bakiyesi yüklemek mümkündür. Yüklenen reklam bakiyesinin ödemesi iki şekilde yapılabilir:\n Hesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür)\nYüklenen reklam bakiyesinin tutarı kredi kartı ile ödenebilir.\nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, reklam bakiyesi yüklendiği anda yüklenen bakiye tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez.\n Aksi duyurulmadığı müddetçe, yüklenen reklam bakiyelerinin herhangi bir son kullanım tarihi bulunmamaktadır. Yüklenen bakiye tüketilene kadar kullanılabilir. \nSatıcıların tercih etmeleri halinde otomatik reklam bakiyesi yükleme talimatı vermeleri de mümkündür. Bu talimatı vermekle satıcı, mevcut reklam bakiyesinin kendisi tarafından belirlenen tutarın altına düştüğü her sefer için, belirlemiş olduğu tutarın otomatik olarak reklam bakiyesine aktarılmasını kabul eder. Otomatik reklam bakiyesi yükleme talimatı neticesinde yapılan yüklemelerin faturalanması ve ödenmesi bakımından işbu Kullanım Şartları’nda düzenlenen şart ve koşullar geçerli olacaktır. Satıcı, vermiş olduğu otomatik reklam bakiyesi yükleme talimatını her zaman Reklam Yönetimi sayfası altından iptal edebilir. TYG Turkey tarafından zaman zaman belirli kural setlerine uygun olarak belirlenebilecek satıcı gruplarına çeşitli reklam bakiyesi kampanyaları sunulabilecektir. Bu kampanyalar “Bakiye Satın Al” sayfası altından incelenebilir. \nTYG Turkey tarafından başlatılan reklam bakiyesi kampanyalarından yararlanmak isteyen satıcılar, kampanya kapsamında TYG Turkey tarafından karşılanacağı duyurulan tutarın düşürülmesi neticesinde kalan bakiyeyi ödeyerek reklam bakiyesi yükleyebilecektir. (Örneğin, TYG Turkey tarafından 2000 TL’lik reklam bakiyesi yüklemelerinin, 225 TL’sinin TYG Turkey tarafından karşılanacağı duyurulmuşsa, satıcı 1775 TL tutarında ödeme yaparak 2000 TL’lik reklam bakiyesi yükleyebilecektir.)\n2. Hediye Bakiye\nHediye bakiye sayfasından, TYG Turkey tarafından satıcılara karşılıksız olarak yüklenebilecek hediye reklam bakiye tutarlarına erişilebilir. TYG Turkey, hediye bakiyelere son kullanım tarihi belirleyebilir, son kullanım tarihinin belirlenmesi halinde, bu tarihe kadar kullanılmayan reklam bakiyeleri geçerliliğini kaybeder. \n\n\n3. Reklam Oluşturma\nSatıcı reklam oluşturabilmek için Reklam Oluşturma Sayfası üzerinden, reklamına bir ad verip, reklamın geçerli olacağı tarih aralığını belirler. Satıcı tarafından belirlenen reklam adı müşterilere gözükmeyecek olup, satıcının raporlamalarında reklam metriklerini takip edebilmesi amacıyla kullanılır.\nSiparişlerinin teslimatının Satıcı tarafından yapıldığı model ile çalışan satıcılar, ayrıca reklamların gözükeceği dağıtım bölgelerini tercih edebilir.\nSatıcı tüm veya belirli şubeleri özelinde reklam başlatabilir. Bunun için reklamın geçerli olacağı şubeleri tanımlaması gerekir.\nSatıcı tarafından reklam harcamaları için günlük bütçe tutarı ve tıklama başına maliyet belirlenmelidir. Minimum 200 TL olmak kaydıyla, Satıcı tarafından belirlenen günlük bütçe her gün satıcının yüklemiş olduğu reklam bakiyesinden çekilir. Tıklama başına maliyet, kullanıcıların satıcı tarafından başlatılan reklama her tıkladığında günlük bütçeden çekilecek tutara karşılık gelmekte olup, belirlenebilecek minimum tıklama başına maliyet 7.5 TL iken, maksimum tıklama başına maliyet 20 TL’dir.\nSatıcı ayrıca seçtiği belirli bir tarih aralığı için geçerli olacak toplam bütçeyi ve tıklama başına maliyeti belirleyip, belirlemiş olduğu toplam bütçenin reklamının geçerli olacağı tarih içindeki dağılımını TYG Turkey tarafından yapılmasını da tercih edebilir. Satıcının bu tercihte bulunması, herhangi bir şekilde satıcıya sıralanma/listeleme garantisi veya bütçenin seçilen tarih aralığında kısmen/tamamen harcanılacağı taahhüdü vermemektedir.\nTYG Turkey tarafından zaman zaman satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, reklam bakiyesi yükleyen satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder.\nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Kullanım Koşullarının tüm hükümlerini ve reklam oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\n4. Abonelik Sistemi\nSatıcılar oluşturdukları reklamların işbu Abonelik Sistemi Şart ve Koşulları uyarınca, satıcının sonradan aboneliklerini sonlandırmayı tercih edecekleri tarihe kadar sürekli olarak yenilenmesini tercih edebilir.\nAbonelik oluşturabilmek için satıcının öncelikle ilgili sayfada kendisine TYG Turkey tarafından önerilen reklam paketlerinden birini tercih etmesi ya da tarih, bütçe, tıklama başına maliyet, şube tercihlerini yaparak şart ve koşullarını kendisinin belirlediği bir reklam oluşturması gerekmektedir. Satıcı, TYG Turkey tarafından oluşturulan reklam paketlerini paket kapsamında satıcıya önerilen bütçe, tarih, tıklama başına maliyet, şube seçeneklerini de özelleştirerek reklam oluşturma imkanına sahiptir. TYG Turkey tarafından satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, satıcı dilerse reklamını oluştururken tıklama başına maliyetin TYG Turkey tarafından belirlenmesini tercih edebilir.\nSatıcının abonelik sistemini başlatması halinde, satıcının oluşturduğu reklam, ilgili reklamın bitiş tarihinin dolması üzerine, reklamın geçerli olduğu dönem uzunluğunda tekrar etmeye devam eder. Örneğin, satıcının başlangıçta 7 günlük bir reklam oluşturması ve bu reklamla birlikte abonelik sistemine geçmesi halinde, 7 günlük reklam süresinin dolması üzerine, oluşturulan reklam satıcının tercih etmiş olduğu bütçe, tıklama başına maliyet ve şube tercihleri ile birlikte 7’şer günlük dönemlerde devam etmeye devam edecektir.\nSatıcı, Reklam Yönetimi sayfasında yer alan “Abonelik İptal Et” seçeneğini tercih ederek abonelik sisteminden çıkma imkanına sahiptir. Satıcının bu tercihte bulunması halinde, mevcutta geçerli olan reklamının bitiş tarihinin sona ermesi beklenir ve bu tarihin dolması üzerine ilgili reklam yenilenmez.\nAbonelik sistemini başlatmak isteyen satıcının ödemeleri iki şekilde yapılabilir:\nHesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür. Şüpheye mahal vermemek adına, satıcının tercih etmiş olduğu reklam bütçesinin içeride bulunan ve ancak henüz ödemesi Satıcıya yapılmamış hakediş tutarından fazla olması halinde satıcı bu opsiyon uyarınca ödeme gerçekleştiremeyecek ve abonelik başlatamayacaktır.)\nSatıcının reklam cüzdanında yeterli bakiye olması halinde, ödemeler reklam cüzdanından düşülür.\nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, yapılan ödeme tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez.\nReklam oluşturan satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder.\nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Abonelik Sistemi Şart ve Koşullarının tüm hükümlerini ve reklam oluşturma/abonelik oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\n5. Diğer Hükümler\nReklam Yönetimi sekmesine girmeniz, bu sekmede yer alan herhangi bir bilgiyi kullanmanız ve bu sekmede herhangi bir işlem yapmış olmanız (Hepsi birlikte "İşlem" olarak kullanılacaktır) aşağıdaki koşulları kabul ettiğiniz anlamına gelir.\nİşlem yapılması sebebiyle, herhangi bir sözleşmenin ihlali, haksız fiil ya da başkaca sebeplere binaen, doğabilecek doğrudan ya da dolaylı hiçbir zarardan TYG Turkey veya herhangi bir grup şirketi sorumlu değildir. TYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti hususunda herhangi bir sorumluluk kabul etmez.\nTYG Turkey işbu Reklam Yönetimi sekmesi başta olmak üzere, Satıcı Paneli ve uzantısında mevcut her tür hizmet, ürün, uygulamayı kullanma koşulları ile uygulamada sunulan bilgileri önceden bir ihtara gerek olmaksızın değiştirme, uygulamayı yeniden organize etme, yayını durdurma hakkını saklı tutar. Değişiklikler, aksi duyurulmadığı müddetçe, uygulamada yayın anında yürürlüğe girer. İşlem yapılması ile bu değişiklikler de kabul edilmiş sayılır. Bu koşullar link verilen diğer web sayfaları/uygulamalar için de geçerlidir.\nTYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti, silinme, kayıp, işlemin veya iletişimin gecikmesi, bilgisayar virüsü, iletişim hatası, hırsızlık, imha veya izinsiz olarak kayıtlara girilmesi, değiştirilmesi veya kullanılması hususunda herhangi bir sorumluluk kabul etmez. \nReklam Yönetimi alanı/sekmesi TYG Turkey’nin kontrolü altında olmayan başka internet sitelerine / uygulamalara bağlantı veya referans içerebilir. TYG Turkey, bu sitelerin/uygulamaların içerikleri veya içerdikleri diğer bağlantılardan sorumlu değildir.\nTYG Turkey Reklam Yönetimi alanının/sekmesinin genel görünüm ve dizaynı ile alandaki/sekmedeki tüm bilgi, resim, Trendyol Go markası ve diğer markalar, işbu İşlem yapılan uygulama adı, logo, ikon, demonstratif, yazılı, elektronik, grafik veya makinede okunabilir şekilde sunulan teknik veriler, bilgisayar yazılımları, uygulanan satış sistemi, iş metodu ve iş modeli de dahil tüm materyallerin (\\"Materyaller\\") ve bunlara ilişkin fikri ve sınai mülkiyet haklarının sahibi veya lisans sahibidir ve yasal koruma altındadır. Reklam Yönetimi alanında/sekmesinde bulunan hiçbir Materyal; önceden izin alınmadan ve kaynak gösterilmeden, kod ve yazılım da dahil olmak üzere, değiştirilemez, kopyalanamaz, çoğaltılamaz, başka bir lisana çevrilemez, yeniden yayımlanamaz, başka bir bilgisayara yüklenemez, postalanamaz, iletilemez, sunulamaz ya da dağıtılamaz. Reklam Yönetimi alanının/sekmesinin bütünü veya bir kısmı başka bir internet sitesinde/uygulamada izinsiz olarak kullanılamaz. Aksine hareketler hukuki ve cezai sorumluluğu gerektirir.TYG Turkey’nin burada açıkça belirtilmeyen diğer tüm hakları saklıdır.\nTYG Turkey, dilediği zaman bu Kullanım Koşulları sayfasının içeriğini önceden duyurmak kaydıyla, güncelleme yetkisini saklı tutmaktadır ve kullanıcılarına Reklam Yönetimi alanına/sekmesine her girişte ayrıca Kullanım Koşulları sayfasını ziyaret etmelerini tavsiye etmektedir.\n\n\nD. SEPET İNDİRİMİ KAMPANYASI \nAVANTAJ PAKET KAPSAMINDA MAĞAZANIZIN SEPET İNDİRİMİ  KAMPANYASINA KATILIMI, TURBO PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nSEPET İNDİRİMİ KATILIM KOŞULLARI\nKampanya kapsamında, 400 TL ve üzeri siparişlerde 125 TL indirim uygulanır.\nSiparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 400 TL\'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 400 TL olması gerekmektedir.\nİndirimin tamamı restoran tarafından karşılanacaktır.\nHerhangi bir kullanıcı bakımından kampanyadan yararlanabilme sınırı (kampanyaya katılma sayısı vb.) bulunmamaktadır.\nKampanya ilk olarak 01 Ocak 2025 tarihinde başlayıp, Trendyol Yemek tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir. Satıcı vermiş olduğu onayla, kampanya başlangıç tarihinden sonra kampanyadan çıkmadığı müddetçe kampanyanın onay vermiş olduğu mağazasında geçerli olacağını kabul eder. Kampanyaya katılım ve kampanyadan çıkış işlemleri kampanya başlangıç tarihinden sonra herhangi bir zamanda yapılabilir.\nTrendyol Yemek kampanya tarihleri, indirim tutarı, minimum sepet tutarı dahil olmak üzere kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda belirtilen tarihte yürürlüğe girecektir. Kampanyaya katılmış olan restoranlar, kampanyadan çıkmadıkları müddetçe, Trendyol Yemek tarafından yapılan değişikliklerin yürürlük tarihinden itibaren kendiliğinden geçerli olacağını kabul etmiş olacaktır.\nBu kampanya, Flaş İndirim kampanyası, Yedikçe İndirim, kupon, indirim kodu ve maliyetinin tamamına satıcının katlandığı sepet indirimleri ile birleştirilemez. Maliyetine kısmen satıcının katlandığı veya maliyetine tamamen Trendyol Yemek’in katlandığı sepet indirimleri işbu kampanya şartlarında belirtilen sınırlamalara tabi olarak birleştirilebilir.\nAynı anda birden fazla kampanyaya katılmanız halinde indirim miktarı yüksek olan kampanya geçerli olacaktır.\nTrendyol Yemek, kampanya süresinde ve koşullarında değişiklik yapma hakkını saklı tutar.\nİndirime sınırlı sayıda restoran katılabilecek olup, kampanya Trendyol Yemek tarafından duyurularla desteklenecektir.\nBu kampanyanın tamamı satıcı tarafından karşılanacaktır.\nSatıcının katıldığı bu kampanyaya ek olarak, aynı siparişte kullanıcı için daha avantajlı başka bir kampanya, indirim veya promosyonun da geçerli olması halinde; daha avantajlı olan kampanya, indirim veya promosyonun tutarı üst sınır oluşturmak kaydıyla, işbu kampanya ile diğer kampanya, indirim veya promosyon birleşebilecektir. Satıcı’nın karşılamayı üstlendiği tutar işbu kampanya için kullanılacak olup, birleşen kampanya kapsamında tüketiciye sunulacak ek faydanın maliyeti Trendyol Yemek tarafından karşılanacaktır.\nBu kampanyanın tamamı satıcı tarafından karşılanacaktır.\n\n\n\n\n`;true;',relationalRule:[],isRelational:!1},464:{test:"Insider.__external.turboPackageContent198199=()=>`\n    <div id=\"package-conditions\">TURBO  PAKET KATILIM KOŞULLARI</div>\x3c!-- OPT-200885 --\x3e\n     TURBO  PAKET KATILIM KOŞULLARI\nTURBO PAKET KAPSAMINDA REKLAM BAKİYESİ TANIMLAMA \nSatıcı mağazasına, Satıcı’nın “Turbo Paket” onay metnini kabul edip, 3.000 TL tutarındaki reklam bakiyesini ayrıca yüklemesini takiben 6.000 TL’lik reklam bakiyesi tanımlanır. 3.000 TL ve katlarında yapılacak reklam bakiyesi yüklemelerinde, tek seferlik 6.000 TL’lik reklam bakiyesi tanımlanır. Reklam oluşturma işlemi mağaza bazlı olup, satıcının dilediği mağazalarında bakiye yükleyerek reklam oluşturması mümkündür. \nOtomatik olarak, bakiye yüklenen tarihten 45 gün sonrasına kadar sürecek şekilde reklam oluşturulur. Bu süre reklamın geçerli olabileceği maksimum süredir, bütçe harcama hızına bağlı olarak reklam bu süreden daha önceki bir tarihte sona erebilecektir. Satıcı’nın birden fazla mağazası için Reklam Yönetimi sayfasında herhangi bir şekilde reklam başlatmış olması halinde, yüklenen toplam bakiye satıcının reklam veren tüm  mağazaları  için geçerli olacak toplam bakiyeyi oluşturur.  Bu durumda Hızlı Başlangıç Paketleri kapsamında açılan yeni reklam 45 günlük süreden daha erken bir sürede sonuçlanabilir. Satıcı bakiye yükleme ekranından bakiye takviyesi yaparak reklamını devam ettirebilir.\nReklam oluşturma işlemi, Hızlı Başlangıç Paketini onaylayan mağazanın bakiye yüklemesini takip eden 1 günlük süre 4. maddede düzenlenen koşullarda yeni bir reklam oluşturulması ile olur. Bu süre içinde, herhangi bir şekilde, ilgili mağazanın dahil olduğu bir aktif reklam olması halinde paket kapsamında reklam açma işlemi yapılmaz. Satıcı yüklediği bakiyesi ile aktif reklamı sonlanınca kendisi yeni bir reklam açabilir. \nBütçe tipi “Günlük” olarak seçilir. Günlük bütçe 300 TL olarak seçilir. Bu durumda satıcı 6.000 TL’lik reklam bakiyesini maksimum 45 gün içerisinde günlük maksimum 300 TL hedeflenerek reklam bakiyesi bitene kadar kullanır.\nHızlı Başlangıç Paketi kapsamında tanımlanan reklamlarda, tıklama başına maliyet dinamik olacak şekilde TYG Turkey tarafından belirlenir.  \nSatıcı dilediği zaman reklam kullanımını durdurabilir.\nBelirtilen şartlar dışında, aşağıda yer verilen Reklam Hizmeti Kullanım Koşulları da geçerli olacaktır. \nC. GO PLUS\nTURBO PAKET KAPSAMINDA MAĞAZANIZIN GO PLUS KATILIMI, AVANTAJ PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nGo Plus Katılım Koşulları\nKullanıcılar her bir takvim ayı boyunca Go Plus programı kapsamında ulaştıkları seviyenin kupon kazanımına yeterli olması halinde Trendyol veya Trendyol Go uygulamalarında geçerli toplamda her bir takvim ayı için 2 adet olacak şekilde her biri 60 TL tutarında Go Plus kuponu kazanır.\nGo Plus kuponları kullanıcının Go Plus programı kapsamında ulaştığı seviyeye bağlı olarak kazanılabilir, kazanılan Go Plus kuponları Go Plus kampanyasına dahil olmuş restoranlarda (“Go Plus restoranları”) harcanabilir.\nBir kullanıcı bir siparişte tanımlanan Go Plus kuponlarından yalnızca bir tanesini kullanabilecektir. Her siparişte 1 kupon kullanılabilecektir. Go Plus kuponları yalnızca kazanıldıkları takvim ayı içerisinde geçerli olacaktır, bir sonraki takvim ayına devretmez.\nTrendyol ve Trendyol Go uygulamalarında kullanıcılara tanımlanacak 2 adet kupona ek olarak yalnızca Trendyol Go uygulamasını kullanan kullanıcıların faydalanabileceği üçüncü, dördüncü ve beşinci Go Plus kuponları aktif olacaktır. Bu kuponlar da Go Plus programı kapsamında kullanıcının ulaştığı seviyeye bağlı olarak tanımlanacak olup, üçüncü kuponun değeri 60 TL; dördüncü ve beşinci kuponların değeri ise sırasıyla 75 TL ve 90 TL olacak, Go Plus kuponlarının koşullarına tabi olacak ve Go Plus kampanyasına dahil olmuş restoranlarda (“Go Plus restoranları”) harcanabilecektir.\nSatıcı, kullanılan kupon tutarından bağımsız olarak, kullanıcı tarafından kullanılan ilk üç kupon için, her bir kuponun 60 TL’lik tutarının maliyetini karşılar. Satıcı tarafından karşılanan kısmı aşan kupon tutarlarının maliyeti Trendyol Yemek tarafından karşılanır.\nİndirimde karşıladığınız tutar üzerinden komisyon kesintisi yapılmayacaktır.\nKullanıcılar Go Plus kuponunu diğer kampanyalarla birleştiremez.\nGüncellenen şartlarıyla kampanya belirtilen güncelleme tarihlerinde başlayacak olup, Trendyol tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir.\nGo Plus Yemek Kuponu Kampanyasına katılan restoranlar ana sayfada, Go Plus sayfasında, filtrelerde ve birçok farklı alanda listelenecektir.\nKampanya Trendyol Yemek tarafından duyurular ve reklamlarla desteklenecektir.\nTrendyol kampanya tarihleri, kupon adedi, kupon tutarı, kupon maliyetinin kimin tarafından hangi oranda karşılanacağı dahil olmak üzere Go Plus kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda daha ileri bir tarih belirtilmediği müddetçe duyurunun çıkılmasından 7 gün sonra kendiliğinden yürürlüğe girecektir. Restoran lehine yapılacak değişiklikler duyurunun çıkılmasından 1 gün sonra kendiliğinden yürürlüğe girecektir.\nRestoran vermiş olduğu onay ile Go Plus kuponlarının maliyetlerini karşılamayı ve restoranında platform üzerinden kazanılmış Go Plus kuponlarının kullanılabilmesini kabul etmiş olacaktır. Go Plus kampanyası restoran tarafından kampanyadan çıkılmadığı veya Trendyol Yemek tarafından iptal edilmediği müddetçe süresiz olarak yürürlükte kalacaktır.\nGo Plus Yemek Kuponu kampanyasına herhangi bir zamanda katılma ve kampanyadan çıkma hakkı bulunmaktadır.\nKampanya süresince yapacağınız katıl/çık işlemleri, kullanıcı memnuniyeti sebepli uygulamaya 1 saat sonrasında yansıyacaktır.\nTYG Turkey, Go Plus programının, Go Plus kampanya koşullarının ve/veya Platform kullanıcılarının (Satıcı ve Alıcı da dahil) Go Plus programı ve/veya Go Plus kampanya deneyiminin geliştirilmesi ve iyileştirilmesi amaçlarıyla sınırlı olarak ve bu amaçların gerektirdiği ölçüde, Platform kullanıcılarının (Satıcı ve Alıcı da dahil) beklenti, tercih ve davranışlarını tespit etmeye yönelik kullanıcı grupları bazlı veya kullanıcı gruplarına kampanya kapsamında sağlanan menfaatler özelinde satıcıya ilave maliyet yüklemeksizin geçici süreli, mevzuata uygun test uygulamalarını devreye alabilecektir.\nKullanıcının Go Plus kuponu kullanılmadan önceki sepet tutarının minimum 150 TL olması ve Go Plus kuponunun kullanılmasıyla oluşan sepet tutarının her koşulda restoranının minimum sepet tutarını karşılaması gerekmektedir.\nD. SEPET İNDİRİMİ KAMPANYASI \nTURBO PAKET KAPSAMINDA MAĞAZANIZIN SEPET İNDİRİMİ  KAMPANYASINA KATILIMI, TURBO PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nSEPET İNDİRİMİ KATILIM KOŞULLARI\nKampanya kapsamında, 400 TL ve üzeri siparişlerde 125 TL indirim uygulanır.\nSiparişin tamamlanması için indirimin uygulanmasıyla oluşan indirimli sepet tutarının restoranın minimum sepet tutarına uygun olması gerekmektedir. Restoranın sistemde tanımlı minimum sepet tutarının 400 TL'nin altında olması halinde, her koşulda indirimin kullanılmasıyla oluşan sepet tutarının restoranın minimum sepet tutarını karşılaması kaydıyla, kullanıcının kampanya kapsamında ilgili restorandan siparişini tamamlayabilmesi için indirimi kullanmadan önceki sepet tutarının en az 400 TL olması gerekmektedir.\nİndirimin tamamı restoran tarafından karşılanacaktır.\nHerhangi bir kullanıcı bakımından kampanyadan yararlanabilme sınırı (kampanyaya katılma sayısı vb.) bulunmamaktadır.\nKampanya ilk olarak 01 Ocak 2025 tarihinde başlayıp, Trendyol Yemek tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir. Satıcı vermiş olduğu onayla, kampanya başlangıç tarihinden sonra kampanyadan çıkmadığı müddetçe kampanyanın onay vermiş olduğu mağazasında geçerli olacağını kabul eder. Kampanyaya katılım ve kampanyadan çıkış işlemleri kampanya başlangıç tarihinden sonra herhangi bir zamanda yapılabilir.\nTrendyol Yemek kampanya tarihleri, indirim tutarı, minimum sepet tutarı dahil olmak üzere kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda belirtilen tarihte yürürlüğe girecektir. Kampanyaya katılmış olan restoranlar, kampanyadan çıkmadıkları müddetçe, Trendyol Yemek tarafından yapılan değişikliklerin yürürlük tarihinden itibaren kendiliğinden geçerli olacağını kabul etmiş olacaktır.\nBu kampanya, Flaş İndirim kampanyası, Yedikçe İndirim, kupon, indirim kodu ve maliyetinin tamamına satıcının katlandığı sepet indirimleri ile birleştirilemez. Maliyetine kısmen satıcının katlandığı veya maliyetine tamamen Trendyol Yemek’in katlandığı sepet indirimleri işbu kampanya şartlarında belirtilen sınırlamalara tabi olarak birleştirilebilir.\nAynı anda birden fazla kampanyaya katılmanız halinde indirim miktarı yüksek olan kampanya geçerli olacaktır.\nTrendyol Yemek, kampanya süresinde ve koşullarında değişiklik yapma hakkını saklı tutar.\nİndirime sınırlı sayıda restoran katılabilecek olup, kampanya Trendyol Yemek tarafından duyurularla desteklenecektir.\nBu kampanyanın tamamı satıcı tarafından karşılanacaktır.\nSatıcının katıldığı bu kampanyaya ek olarak, aynı siparişte kullanıcı için daha avantajlı başka bir kampanya, indirim veya promosyonun da geçerli olması halinde; daha avantajlı olan kampanya, indirim veya promosyonun tutarı üst sınır oluşturmak kaydıyla, işbu kampanya ile diğer kampanya, indirim veya promosyon birleşebilecektir. Satıcı’nın karşılamayı üstlendiği tutar işbu kampanya için kullanılacak olup, birleşen kampanya kapsamında tüketiciye sunulacak ek faydanın maliyeti Trendyol Yemek tarafından karşılanacaktır.\nBu kampanyanın tamamı satıcı tarafından karşılanacaktır.\n\n\n\n\n\n\n\nREKLAM HİZMETİ KULLANIM KOŞULLARI\nİşbu Reklam Hizmeti Kullanım Koşulları (“Kullanım Koşulları”), Satıcı’nın, Satıcı Paneli’nde bulunan Reklam Yönetimi sayfasında, işbu Kullanım Koşulları’nda tanımlanan anlamıyla herhangi bir İşlem yapması halinde geçerli olacak şart ve koşulları düzenlemektedir. \n1. Reklam Bakiyesi Yükleme\nSatıcının reklam oluşturabilmesi için öncelikle reklam bakiyesi yüklemesi gerekmektedir. İstenilen tutarda reklam bakiyesi yüklenebilmekte olup, tek seferde en fazla 10.000.000 TL (on milyon türk lirası) reklam bakiyesi yüklemek mümkündür. Yüklenen reklam bakiyesinin ödemesi iki şekilde yapılabilir:\n Hesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür)\nYüklenen reklam bakiyesinin tutarı kredi kartı ile ödenebilir.\nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, reklam bakiyesi yüklendiği anda yüklenen bakiye tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez.\n Aksi duyurulmadığı müddetçe, yüklenen reklam bakiyelerinin herhangi bir son kullanım tarihi bulunmamaktadır. Yüklenen bakiye tüketilene kadar kullanılabilir. \nSatıcıların tercih etmeleri halinde otomatik reklam bakiyesi yükleme talimatı vermeleri de mümkündür. Bu talimatı vermekle satıcı, mevcut reklam bakiyesinin kendisi tarafından belirlenen tutarın altına düştüğü her sefer için, belirlemiş olduğu tutarın otomatik olarak reklam bakiyesine aktarılmasını kabul eder. Otomatik reklam bakiyesi yükleme talimatı neticesinde yapılan yüklemelerin faturalanması ve ödenmesi bakımından işbu Kullanım Şartları’nda düzenlenen şart ve koşullar geçerli olacaktır. Satıcı, vermiş olduğu otomatik reklam bakiyesi yükleme talimatını her zaman Reklam Yönetimi sayfası altından iptal edebilir. TYG Turkey tarafından zaman zaman belirli kural setlerine uygun olarak belirlenebilecek satıcı gruplarına çeşitli reklam bakiyesi kampanyaları sunulabilecektir. Bu kampanyalar “Bakiye Satın Al” sayfası altından incelenebilir. \nTYG Turkey tarafından başlatılan reklam bakiyesi kampanyalarından yararlanmak isteyen satıcılar, kampanya kapsamında TYG Turkey tarafından karşılanacağı duyurulan tutarın düşürülmesi neticesinde kalan bakiyeyi ödeyerek reklam bakiyesi yükleyebilecektir. (Örneğin, TYG Turkey tarafından 2000 TL’lik reklam bakiyesi yüklemelerinin, 225 TL’sinin TYG Turkey tarafından karşılanacağı duyurulmuşsa, satıcı 1775 TL tutarında ödeme yaparak 2000 TL’lik reklam bakiyesi yükleyebilecektir.)\n2. Hediye Bakiye\nHediye bakiye sayfasından, TYG Turkey tarafından satıcılara karşılıksız olarak yüklenebilecek hediye reklam bakiye tutarlarına erişilebilir. TYG Turkey, hediye bakiyelere son kullanım tarihi belirleyebilir, son kullanım tarihinin belirlenmesi halinde, bu tarihe kadar kullanılmayan reklam bakiyeleri geçerliliğini kaybeder. \n\n3. Reklam Oluşturma\nSatıcı reklam oluşturabilmek için Reklam Oluşturma Sayfası üzerinden, reklamına bir ad verip, reklamın geçerli olacağı tarih aralığını belirler. Satıcı tarafından belirlenen reklam adı müşterilere gözükmeyecek olup, satıcının raporlamalarında reklam metriklerini takip edebilmesi amacıyla kullanılır.\nSiparişlerinin teslimatının Satıcı tarafından yapıldığı model ile çalışan satıcılar, ayrıca reklamların gözükeceği dağıtım bölgelerini tercih edebilir.\nSatıcı tüm veya belirli şubeleri özelinde reklam başlatabilir. Bunun için reklamın geçerli olacağı şubeleri tanımlaması gerekir.\nSatıcı tarafından reklam harcamaları için günlük bütçe tutarı ve tıklama başına maliyet belirlenmelidir. Minimum 200 TL olmak kaydıyla, Satıcı tarafından belirlenen günlük bütçe her gün satıcının yüklemiş olduğu reklam bakiyesinden çekilir. Tıklama başına maliyet, kullanıcıların satıcı tarafından başlatılan reklama her tıkladığında günlük bütçeden çekilecek tutara karşılık gelmekte olup, belirlenebilecek minimum tıklama başına maliyet 7.5 TL iken, maksimum tıklama başına maliyet 20 TL’dir.\nSatıcı ayrıca seçtiği belirli bir tarih aralığı için geçerli olacak toplam bütçeyi ve tıklama başına maliyeti belirleyip, belirlemiş olduğu toplam bütçenin reklamının geçerli olacağı tarih içindeki dağılımını TYG Turkey tarafından yapılmasını da tercih edebilir. Satıcının bu tercihte bulunması, herhangi bir şekilde satıcıya sıralanma/listeleme garantisi veya bütçenin seçilen tarih aralığında kısmen/tamamen harcanılacağı taahhüdü vermemektedir.\nTYG Turkey tarafından zaman zaman satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, reklam bakiyesi yükleyen satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder.\nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Kullanım Koşullarının tüm hükümlerini ve reklam oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\n4. Abonelik Sistemi\nSatıcılar oluşturdukları reklamların işbu Abonelik Sistemi Şart ve Koşulları uyarınca, satıcının sonradan aboneliklerini sonlandırmayı tercih edecekleri tarihe kadar sürekli olarak yenilenmesini tercih edebilir.\nAbonelik oluşturabilmek için satıcının öncelikle ilgili sayfada kendisine TYG Turkey tarafından önerilen reklam paketlerinden birini tercih etmesi ya da tarih, bütçe, tıklama başına maliyet, şube tercihlerini yaparak şart ve koşullarını kendisinin belirlediği bir reklam oluşturması gerekmektedir. Satıcı, TYG Turkey tarafından oluşturulan reklam paketlerini paket kapsamında satıcıya önerilen bütçe, tarih, tıklama başına maliyet, şube seçeneklerini de özelleştirerek reklam oluşturma imkanına sahiptir. TYG Turkey tarafından satıcılara tıklama başına maliyet önerisinde bulunulabilecek olup, satıcı dilerse reklamını oluştururken tıklama başına maliyetin TYG Turkey tarafından belirlenmesini tercih edebilir.\nSatıcının abonelik sistemini başlatması halinde, satıcının oluşturduğu reklam, ilgili reklamın bitiş tarihinin dolması üzerine, reklamın geçerli olduğu dönem uzunluğunda tekrar etmeye devam eder. Örneğin, satıcının başlangıçta 7 günlük bir reklam oluşturması ve bu reklamla birlikte abonelik sistemine geçmesi halinde, 7 günlük reklam süresinin dolması üzerine, oluşturulan reklam satıcının tercih etmiş olduğu bütçe, tıklama başına maliyet ve şube tercihleri ile birlikte 7’şer günlük dönemlerde devam etmeye devam edecektir.\nSatıcı, Reklam Yönetimi sayfasında yer alan “Abonelik İptal Et” seçeneğini tercih ederek abonelik sisteminden çıkma imkanına sahiptir. Satıcının bu tercihte bulunması halinde, mevcutta geçerli olan reklamının bitiş tarihinin sona ermesi beklenir ve bu tarihin dolması üzerine ilgili reklam yenilenmez.\nAbonelik sistemini başlatmak isteyen satıcının ödemeleri iki şekilde yapılabilir:\nHesaptan yükle seçeneği (satıcının sistemde bulunan ve Trendyol Go platformunda yapacağı satışlardan doğan hak edişinden yüklenmek istenen bakiye tutarı düşülür. Şüpheye mahal vermemek adına, satıcının tercih etmiş olduğu reklam bütçesinin içeride bulunan ve ancak henüz ödemesi Satıcıya yapılmamış hakediş tutarından fazla olması halinde satıcı bu opsiyon uyarınca ödeme gerçekleştiremeyecek ve abonelik başlatamayacaktır.)\nSatıcının reklam cüzdanında yeterli bakiye olması halinde, ödemeler reklam cüzdanından düşülür.\nÖdeme için hangi yöntemin tercih edildiğinden bağımsız olarak, yapılan ödeme tutarı kadar fatura düzenlenir. Satıcının TYG Turkey ile arasındaki elektronik ticaret aracılık sözleşmesinin herhangi bir nedenle sona ermesi hali hariç olmak üzere, Satıcının yüklemiş olduğu reklam bakiyesi, tutarı iade edilemez.\nReklam oluşturan satıcılar arasından sponsorlu veya benzer isimlerle listelenecek olan satıcılar algoritma kuralları uyarınca belirlenecektir. Sponsorlu veya benzeri isimlerle listelenecek/öne çıkarılacak olan satıcılar için belirli bir sıra garantisi verilmemektedir. Algoritma uyarınca listelenemeyecek olan satıcılar, uygulama içerisinde geçerli algoritma kuralları uyarınca herhangi bir reklam bakiyesi harcaması yapmaksızın listelenmeye devam eder.\nTYG Turkey tıklama başına maliyet, satıcı tarafından belirlenebilecek günlük veya toplam bütçe tutarları dahil işbu Abonelik Sistemi Şart ve Koşullarının tüm hükümlerini ve reklam oluşturma/abonelik oluşturma sürecine yönelik herhangi bir işlemi/süreci önceden duyurmak kaydıyla değiştirme hakkını saklı tutar.\n5. Diğer Hükümler\nReklam Yönetimi sekmesine girmeniz, bu sekmede yer alan herhangi bir bilgiyi kullanmanız ve bu sekmede herhangi bir işlem yapmış olmanız (Hepsi birlikte \"İşlem\" olarak kullanılacaktır) aşağıdaki koşulları kabul ettiğiniz anlamına gelir.\nİşlem yapılması sebebiyle, herhangi bir sözleşmenin ihlali, haksız fiil ya da başkaca sebeplere binaen, doğabilecek doğrudan ya da dolaylı hiçbir zarardan TYG Turkey veya herhangi bir grup şirketi sorumlu değildir. TYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti hususunda herhangi bir sorumluluk kabul etmez.\nTYG Turkey işbu Reklam Yönetimi sekmesi başta olmak üzere, Satıcı Paneli ve uzantısında mevcut her tür hizmet, ürün, uygulamayı kullanma koşulları ile uygulamada sunulan bilgileri önceden bir ihtara gerek olmaksızın değiştirme, uygulamayı yeniden organize etme, yayını durdurma hakkını saklı tutar. Değişiklikler, aksi duyurulmadığı müddetçe, uygulamada yayın anında yürürlüğe girer. İşlem yapılması ile bu değişiklikler de kabul edilmiş sayılır. Bu koşullar link verilen diğer web sayfaları/uygulamalar için de geçerlidir.\nTYG Turkey, sözleşmenin ihlali, haksız fiil, ihmal veya diğer sebepler neticesinde; işlemin kesintiye uğraması, hata, ihmal, kesinti, silinme, kayıp, işlemin veya iletişimin gecikmesi, bilgisayar virüsü, iletişim hatası, hırsızlık, imha veya izinsiz olarak kayıtlara girilmesi, değiştirilmesi veya kullanılması hususunda herhangi bir sorumluluk kabul etmez. \nReklam Yönetimi alanı/sekmesi TYG Turkey’nin kontrolü altında olmayan başka internet sitelerine / uygulamalara bağlantı veya referans içerebilir. TYG Turkey, bu sitelerin/uygulamaların içerikleri veya içerdikleri diğer bağlantılardan sorumlu değildir.\nTYG Turkey Reklam Yönetimi alanının/sekmesinin genel görünüm ve dizaynı ile alandaki/sekmedeki tüm bilgi, resim, Trendyol Go markası ve diğer markalar, işbu İşlem yapılan uygulama adı, logo, ikon, demonstratif, yazılı, elektronik, grafik veya makinede okunabilir şekilde sunulan teknik veriler, bilgisayar yazılımları, uygulanan satış sistemi, iş metodu ve iş modeli de dahil tüm materyallerin (\\\"Materyaller\\\") ve bunlara ilişkin fikri ve sınai mülkiyet haklarının sahibi veya lisans sahibidir ve yasal koruma altındadır. Reklam Yönetimi alanında/sekmesinde bulunan hiçbir Materyal; önceden izin alınmadan ve kaynak gösterilmeden, kod ve yazılım da dahil olmak üzere, değiştirilemez, kopyalanamaz, çoğaltılamaz, başka bir lisana çevrilemez, yeniden yayımlanamaz, başka bir bilgisayara yüklenemez, postalanamaz, iletilemez, sunulamaz ya da dağıtılamaz. Reklam Yönetimi alanının/sekmesinin bütünü veya bir kısmı başka bir internet sitesinde/uygulamada izinsiz olarak kullanılamaz. Aksine hareketler hukuki ve cezai sorumluluğu gerektirir.TYG Turkey’nin burada açıkça belirtilmeyen diğer tüm hakları saklıdır.\nTYG Turkey, dilediği zaman bu Kullanım Koşulları sayfasının içeriğini önceden duyurmak kaydıyla, güncelleme yetkisini saklı tutmaktadır ve kullanıcılarına Reklam Yönetimi alanına/sekmesine her girişte ayrıca Kullanım Koşulları sayfasını ziyaret etmelerini tavsiye etmektedir.\nE. FLAŞ\nTURBO PAKET KAPSAMINDA MAĞAZANIZIN FLAŞ KATILIMI, TURBO PAKETİ ONAYLAMA TARİHİNİZDEN İTİBAREN 1 GÜN İÇİNDE GERÇEKLEŞTİRİLİR. \nFLAŞ KATILIM KOŞULLARI\nFlaş İndirim kampanyasından, daha önce hiç sipariş vermemiş kullanıcılar yararlanacaktır.Kampanyadan günlük 5 müşteri yararlanabilecektir. Restoran kampanyadan çıkmadığı müddetçe, bu seçimler otomatik olarak uygulanmaya devam eder.\nFlaş İndirim kampanyası, uygulamaya girdiğinde doğrudan Flaş indirim kampanyasından yararlanabilecek kullanıcının karşısına çıkacak olup, kullanıcının indirimden faydalanabilmesi için 15 dakika içinde siparişini tamamlaması gerekmektedir. Kampanyanın gösterileceği kullanıcılar, restoranınızın bu duyuruda açıklanan şartlar uyarınca kitleyi genişletme hakkı saklı olmak üzere, Trendyol Yemek tarafından belirlenecektir.\nFlaş İndirim kampanyası kapsamında kullanıcıların hem Trendyol Go uygulamasında hem de Trendyol uygulamasından erişim verilen Trendyol Go kanalında faydalanacağı indirimler, kullanıcının oluşturduğu sepet tutarına göre değişiklik gösterecek olup, kullanıcı her 250 TL'lik siparişte 100 TL, 350 TL'lik siparişte 130 TL, 450 TL'lik siparişte 160 TL'lik bir indirim kazanacaktır. Ek olarak flaş indirim kampanyası kapsamında kullanıcılar yalnızca Trendyol Go uygulamasında geçerli her 550 TL'lik siparişte, 200 TL'lik bir indirim kazanacaktır. Kullanıcıların kazandığı bu indirim tutarlarının maliyetine ilgili Flaş İndirim Restoranı katlanacaktır. Ayrıca daha önce Trendyol Go uygulamasında ya da Trendyol uygulamasından erişim verilen Trendyol Go kanalında yer alan Trendyol Yemek bölümünden hiç sipariş vermemiş kullanıcıların, Trendyol Go uygulaması veya Trendyol uygulamasından erişim verilen Trendyol Go kanalında bulunan Trendyol Yemek bölümünden verecekleri ilk siparişlerinde faydalanacağı indirimler, kullanıcının oluşturduğu sepet tutarına göre değişiklik gösterecek olup, kullanıcı 200 TL'lik siparişte 150 TL, 300 TL'lik siparişte 200 TL, 450 TL'lik siparişte 250 TL; yalnızca Trendyol Go uygulamasında geçerli 600 TL'lik siparişte, 300 TL'lik bir indirim kazanacaktır. Daha önce Trendyol Yemek'ten hiç sipariş vermemiş kullanıcıların verecekleri ilk siparişlerinde geçerli olacak bu indirim tutarlarının %47’sine karşılık gelen kısmının maliyetine Trendyol Yemek katlanacaktır. Daha önce Trendyol Yemek'ten hiç sipariş vermemiş kullanıcıların yararlanacağı indirimler, restoranın kullanıcı kitlesi olarak \"\"daha önce restoranından hiç sipariş vermemiş kullanıcıları\"\" tercih etmesi halinde uygulanacak olup, daha önce sipariş vermesine rağmen restoranın belirlediği süre zarfında tekrardan sipariş vermemiş kullanıcı kitlesini tercih eden restoranlar bakımından geçerli olmayacaktır.\nFlaş İndirim Restoranı'nın karşıladığı indirim tutarı üzerinden Trendyol Yemek tarafından komisyon kesintisi yapılmayacaktır.\nFlaş İndirim kampanyası, Yedikçe İndirim, kupon, indirim kodu ve maliyetinin tamamına satıcının katlandığı sepet indirimleri ile birleştirilemez. Maliyetine kısmen satıcının katlandığı veya maliyetine tamamen Trendyol Yemek'in katlandığı sepet indirimleri işbu kampanya şartlarında belirtilen sınırlamalara tabi olarak birleştirilebilir. Ayrıca, herhangi bir kullanıcı, kampanyadan yararlanmasından itibaren 15 dakika geçmedikçe, aynı restorandan vereceği siparişte herhangi bir kampanyadan tekrar yararlanamayacaktır.\nFlaş İndirim Restoranı tarafından belirli tarih için tanımlanan belirli adetteki kullanıcı indiriminin, Kullanıcılar tarafından ilgili tarihlerde kullanılmaması halinde, kullanılmayan indirimler sonraki bir tarihe devredilmez.\nKampanya ilk olarak 10 Temmuz 2023 tarihinde başlamış olup, Trendyol Yemek tarafından aksi yönde herhangi bir duyuru yapılana kadar devam edecektir. Flaş İndirim Restoranı'nın kampanyanın devam ettiği süre boyunca kampanyadan yararlanabilmesi için Satıcı Paneli üzerinden ya kampanyadan yararlanabilecek günlük müşteri sayısını belirlemesi ya da Flaş İndirim Kampanyasının geçerli olacağı tarih ve saat aralıklarını her bir tarih için geçerli olacak müşteri sayısı ile birlikte belirlemesi gerekmektedir.\nRestoran vermiş olduğu onay ile Flaş İndirim kampanyası kapsamında Kullanıcıya tanımlanan indirimlerin maliyetlerini karşılamayı ve restoranında bu indirimlerin kullanılabilmesini kabul etmiş olacaktır.\nFlaş İndirim kampanyasına herhangi bir zamanda katılma ve kampanyadan çıkma hakkı bulunmaktadır. Kampanya kapsamında Flaş indirimler, indirimin tanımlanmasından veya güncellenmesinden itibaren; kampanyadan çıkma ise çıkma hakkının kullanılmasından itibaren 1 gün sonra kullanıcılara gösterilecek olup, tanımlanan veya güncellenen indirimler ya da kampanyadan çıkıldığı aynı gün içinde kullanıcıya gösterilmez.\nKampanyadan çıkmadan önce ilgili restoranda Flaş İndirim'in geçerli olduğunu gören kullanıcılar, siparişlerini indirimli olarak tamamlayabilir, diğer kullanıcılar ise restoranın kampanyadan çıktığı andan itibaren restoranı Flaş İndirim Restoranları arasında görmezler.\nTrendyol Yemek kampanya tarihleri, indirim tutarı dahil olmak üzere Flaş İndirim kampanya şartlarının tamamını veya bir kısmını restorana Satıcı Paneli üzerinden duyurmak kaydıyla değiştirme hakkını saklı tutar. Bu değişiklikler duyuruda belirtilen tarihte yürürlüğe girecektir. Kampanyaya katılmış olan restoranlar, kampanyadan çıkmadıkları müddetçe, Trendyol Yemek tarafından yapılan değişikliklerin yürürlük tarihinden itibaren kendiliğinden geçerli olacağını kabul etmiş olacaktır.\nFlaş indirimler, sadece belli bir uygulamada geçerli olacağı özel olarak belirtilen ek indirimler saklı olmak üzere, hem Trendyol Go uygulamasında hem de Trendyol uygulamasından erişim verilen Trendyol Go kanalında geçerli olup, kullanıcının Flaş İndirim'den yararlanmasıyla oluşan indirimli sepet tutarının sipariş verilen restoranın minimum sepet tutarını karşılaması gerekmektedir.\nTrendyol Yemek, Aracılık Hizmetleri'nin ve/veya satıcı ve alıcıların Platform ve ilgili Flaş indirim kampanya deneyiminin geliştirilmesi ve iyileştirilmesi amaçlarıyla sınırlı olarak ve bu amaçların gerektirdiği ölçüde, indirimlerin geçerli olduğu uygulama / kanal, indirimleri görebilecek kullanıcı kitlesi, kampanya kapsamında geçerli olacak indirim sayıları, indirimlerin geçerli olduğu şehir konuları başta olmak üzere çeşitli konularda Satıcı ve Alıcıların beklenti, tercih ve davranışlarını tespit etmeye yönelik geçici süreli test uygulamalarını devreye alabilecektir.\nSatıcının katıldığı bu kampanyaya ek olarak, aynı siparişte kullanıcı için daha avantajlı başka bir kampanya, indirim veya promosyonun da geçerli olması halinde; daha avantajlı olan kampanya, indirim veya promosyonun tutarı üst sınır oluşturmak kaydıyla, işbu kampanya ile diğer kampanya, indirim veya promosyon birleşebilecektir. Satıcı'nın karşılamayı üstlendiği tutar işbu kampanya için kullanılacak olup, birleşen kampanya kapsamında tüketiciye sunulacak ek faydanın maliyeti Trendyol Yemek tarafından karşılanacaktır.\"\n`;true;",relationalRule:[],isRelational:!1},465:{test:"Insider.__external.CreatePackages198199=(variationId,builderId)=>{'use strict';const self={};const hasSelectedPackageStorageName=`ins-has-package-selected-${variationId}`;const menuButtonClickStorageName=`ins-menu-button-click-${variationId}`;const hellobarClickStorageName=`ins-hellobar-click-${variationId}`;const packageAcceptClickStorageName=`ins-package-accept-click-${variationId}`;const storeId=window.meal?.getRestaurant()?.id;const config={plans:{headerSectionText:'Hızlı Başlangıç Paketleri',selectPackageText:'Paketi Seç',selectedPackageText:'Paket Seçili',discountText:'İndirim',informationText:'Bilgilendirmeyi Oku',footerText:' *Olası Sipariş Etkileri Nisan - Kasım 2025 tarihlerinde yapılan platforma yeni katılan 12 bin satıcının incelendiği bir çalışmaya dayanmaktadır. Gerçek sonuçlar kampanya ayarlarınıza, restoran performansına ve farklı dış sebeplere bağlı olarak değişiklik gösterebilir.  ',discountIcon:'%',currencyIcon:'₺',tagIcon:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/svgviewer-png-output-1752244486.png',packages:{standart:{header:{title:'Standart Paket',icon:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/fd9ad847-9a9b-4770-8232-579b2a4a949d-1752244013.png'},subHeader:{title:'Siparişlerini <b>1.5x</b> kadar artırma şansı yakala!',icon:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/t-1752244013.png'},includedText:'Bu paketi seçerek aşağıdakilere <br/> otomatik olarak katılırsın;',includedItems:[{icon:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/FirstImage-1766433932.png'}],advertisingText:'Reklam kampanyan için bakiye <br/> yüklerken özel indirimden faydalanırsın',balanceText:'değerinde reklam bakiyesi',originalPrice:'3.000',discountPrice:'2.100'},advantage:{header:{title:'Avantajlı Paket',icon:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/t%20%282%29-1752244061.png'},subHeader:{title:'Siparişlerini <b>3x</b> kadar artırma şansı yakala!',icon:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/t-1752244013.png'},includedText:'Bu paketi seçerek aşağıdakilere <br/> otomatik olarak katılırsın;',includedItems:[{icon:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/Second%20badge-1766433204.png',feature:'Reklam'}],advertisingText:'Reklam kampanyan için bakiye <br/> yüklerken özel indirimden faydalanırsın',balanceText:'değerinde reklam bakiyesi',originalPrice:'4.000',discountPrice:'2.400'},turbo:{header:{title:'Turbo Paket',icon:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/t%20%281%29-1752244061.png'},subHeader:{title:'Siparişlerini <b>5x</b> kadar artırma şansı yakala!',icon:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/t-1752244013.png'},includedText:'Bu paketi seçerek aşağıdakilere <br/> otomatik olarak katılırsın;',includedItems:[{icon:'https://web-image.useinsider.com/trendyolyemekb2b/defaultImageLibrary/Third%20Badge-1766433204.png',feature:'Reklam'}],advertisingText:'Reklam kampanyan için bakiye <br/> yüklerken özel indirimden faydalanırsın',balanceText:'değerinde reklam bakiyesi',originalPrice:'6.000',discountPrice:'3.000'}}},popup:{closeButton:'X',content:{standart:'standardPackageContent198199',advantage:'advantagePackageContent198199',turbo:'turboPackageContent198199'},confirmButton:'Paketi Onayla ve Reklam için Bakiye Yükle',confirmedButton:'Onaylanmış Paket Mevcut',checkboxOptions:{standart:[{textCondition:'Hızlı Başlangıç Paketleri koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'package-conditions'},{textCondition:'Reklam Hizmeti koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'advertising-conditions'},{textCondition:'Sepet İndirimi Koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'sepet-conditions'}],advantage:[{textCondition:'Hızlı Başlangıç Paketleri koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'package-conditions'},{textCondition:'Reklam Hizmeti koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'advertising-conditions'},{textCondition:'GO Plus koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'yedikce-indirim-conditions'},{textCondition:'Sepet İndirimi Koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'sepet-conditions'}],turbo:[{textCondition:'Hızlı Başlangıç Paketleri koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'package-conditions'},{textCondition:'Reklam Hizmeti koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'advertising-conditions'},{textCondition:'GO Plus koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'yedikce-indirim-conditions'},{textCondition:'Sepet indirimi koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'sepet-conditions'},{textCondition:'Flash İndirim Koşullarını',textApprove:' okudum ve kabul ediyorum.',scrollTarget:'advertising-conditions'}]}},scroll:{up:'▲',down:'▼',step:200}};const classes={style:`ins-custom-package-style-${variationId}`,wrapper:`ins-custom-package-main-wrapper-${variationId}`,container:`ins-custom-package-main-container-${variationId}`,headerContainer:`ins-custom-package-main-header-container-${variationId}`,packageWrapper:`ins-custom-package-wrapper-${variationId}`,packageContainer:`ins-custom-package-con