1757","text":"16943"},{"range":"21758","text":"16943"},{"range":"21759","text":"16943"},{"range":"21760","text":"16943"},"Replace `·ipcRenderer.send('log-system-event',·{·message,·type·}),␍` with `⏎····ipcRenderer.send('log-system-event',·{·message,·type·}),`",{"range":"21761","text":"21762"},{"range":"21763","text":"16943"},{"range":"21764","text":"16943"},["21765","21766"],{"range":"21767","text":"16943"},{"range":"21768","text":"16943"},["21769","21770"],{"range":"21771","text":"16943"},["21772","21773"],{"range":"21774","text":"16943"},["21775","21776"],{"range":"21777","text":"16943"},{"range":"21778","text":"16943"},["21779","21780"],{"range":"21781","text":"16943"},{"range":"21782","text":"16943"},{"range":"21783","text":"16943"},{"range":"21784","text":"16943"},{"range":"21785","text":"16943"},{"range":"21786","text":"16943"},["21787","21788"],{"range":"21789","text":"16943"},["21790","21791"],["21792","21793"],{"range":"21794","text":"16943"},{"range":"21795","text":"16943"},{"range":"21796","text":"16943"},{"range":"21797","text":"16943"},["21798","21799"],{"range":"21800","text":"16943"},{"range":"21801","text":"16943"},{"range":"21802","text":"16943"},{"range":"21803","text":"16943"},["21804","21805"],{"range":"21806","text":"16943"},["21807","21808"],["21809","21810"],{"range":"21811","text":"16943"},{"range":"21812","text":"16943"},{"range":"21813","text":"16943"},{"range":"21814","text":"16943"},["21815","21816"],{"range":"21817","text":"16943"},{"range":"21818","text":"16943"},{"range":"21819","text":"16943"},["21820","21821"],{"range":"21822","text":"16943"},["21823","21824"],["21825","21826"],{"range":"21827","text":"16943"},{"range":"21828","text":"16943"},{"range":"21829","text":"16943"},{"range":"21830","text":"16943"},{"range":"21831","text":"16943"},{"range":"21832","text":"16943"},{"range":"21833","text":"16943"},["21834","21835"],{"range":"21836","text":"16943"},{"range":"21837","text":"16943"},{"range":"21838","text":"16943"},"Replace `·ipcRenderer.invoke('update-price',·{·productName,·portion,·price·}),␍` with `⏎····ipcRenderer.invoke('update-price',·{·productName,·portion,·price·}),`",{"range":"21839","text":"21840"},{"range":"21841","text":"16943"},{"range":"21842","text":"16943"},{"range":"21843","text":"16943"},{"range":"21844","text":"16943"},{"range":"21845","text":"16943"},{"range":"21846","text":"16943"},{"range":"21847","text":"16943"},{"range":"21848","text":"16943"},{"range":"21849","text":"16943"},{"range":"21850","text":"16943"},{"range":"21851","text":"16943"},{"range":"21852","text":"16943"},{"range":"21853","text":"16943"},{"range":"21854","text":"16943"},{"range":"21855","text":"16943"},{"range":"21856","text":"16943"},{"range":"21857","text":"16943"},"Delete `␍⏎␍`",{"range":"21858","text":"16943"},{"range":"21859","text":"16943"},{"range":"21860","text":"16943"},{"range":"21861","text":"16943"},{"range":"21862","text":"16943"},{"range":"21863","text":"16943"},{"range":"21864","text":"16943"},{"range":"21865","text":"16943"},{"range":"21866","text":"16943"},{"range":"21867","text":"16943"},{"range":"21868","text":"16943"},{"range":"21869","text":"16943"},{"range":"21870","text":"16943"},{"range":"21871","text":"16943"},{"range":"21872","text":"16943"},{"range":"21873","text":"16943"},{"range":"21874","text":"16943"},{"range":"21875","text":"16943"},{"range":"21876","text":"16943"},{"range":"21877","text":"16943"},"react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\bilal\\SARACAPP\\SARACAPPV3\\app1\\src\\renderer\\src\\App.tsx:20:7\n  18 |   useEffect(() => {\n  19 |     if (username && password) {\n> 20 |       setIsAutoLoggingIn(true)\n     |       ^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  21 |       window.api.login({ username, password }).then((res: any) => {\n  22 |         setIsAutoLoggingIn(false)\n  23 |         if (res.success) {",{"range":"21878","text":"16943"},["21879","21880"],{"range":"21881","text":"16943"},{"range":"21882","text":"16943"},{"range":"21883","text":"16943"},{"range":"21884","text":"16943"},{"range":"21885","text":"16943"},{"range":"21886","text":"16943"},{"range":"21887","text":"16943"},"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'onLogin', 'password', and 'username'. Either include them or remove the dependency array. If 'onLogin' changes too often, find the parent component that defines it and wrap that definition in useCallback.","ArrayExpression",["21888"],{"range":"21889","text":"16943"},{"range":"21890","text":"16943"},{"range":"21891","text":"16943"},{"range":"21892","text":"16943"},{"range":"21893","text":"16943"},{"range":"21894","text":"16943"},{"range":"21895","text":"16943"},{"range":"21896","text":"16943"},{"range":"21897","text":"16943"},{"range":"21898","text":"16943"},{"range":"21899","text":"16943"},{"range":"21900","text":"16943"},{"range":"21901","text":"16943"},{"range":"21902","text":"16943"},{"range":"21903","text":"16943"},{"range":"21904","text":"16943"},"Replace `·style={{·height:·(!(window·as·any).electron)·?·'100vh'·:·'calc(100vh·-·32px)',·width:·'100vw',·display:·'flex',·alignItems:·'center',·justifyContent:·'center',·backgroundColor:·'var(--bg-dark)'·}}>␍` with `⏎······style={{⏎········height:·!(window·as·any).electron·?·'100vh'·:·'calc(100vh·-·32px)',⏎········width:·'100vw',⏎········display:·'flex',⏎········alignItems:·'center',⏎········justifyContent:·'center',⏎········backgroundColor:·'var(--bg-dark)'⏎······}}⏎····>`",{"range":"21905","text":"21906"},["21907","21908"],"Replace `·onSubmit={handleSubmit}·style={{·padding:·'40px',·borderRadius:·'var(--radius-lg)',·backgroundColor:·'var(--bg-panel)',·boxShadow:·'0·8px·30px·rgba(0,0,0,0.5)',·width:·'350px',·display:·'flex',·flexDirection:·'column',·gap:·'15px',·transform:·'translateY(-50px)'·}}>␍` with `⏎········onSubmit={handleSubmit}⏎········style={{⏎··········padding:·'40px',⏎··········borderRadius:·'var(--radius-lg)',⏎··········backgroundColor:·'var(--bg-panel)',⏎··········boxShadow:·'0·8px·30px·rgba(0,0,0,0.5)',⏎··········width:·'350px',⏎··········display:·'flex',⏎··········flexDirection:·'column',⏎··········gap:·'15px',⏎··········transform:·'translateY(-50px)'⏎········}}⏎······>`",{"range":"21909","text":"21910"},"Replace `·style={{·textAlign:·'center',·margin:·'0·0·15px·0',·fontSize:·'28px',·fontWeight:·800,·letterSpacing:·'1px'·}}>Login</h2>␍` with `⏎··········style={{⏎············textAlign:·'center',⏎············margin:·'0·0·15px·0',⏎············fontSize:·'28px',⏎············fontWeight:·800,⏎············letterSpacing:·'1px'⏎··········}}⏎········>⏎··········Login⏎········</h2>`",{"range":"21911","text":"21912"},"Replace `·className=\"cart-input\"·placeholder=\"Kullanıcı·Adı\"·value={username}·onChange={e·=>·setUsername(e.target.value)}·style={{·padding:·'12px·15px',·borderRadius:·'var(--radius-md)',·backgroundColor:·'var(--bg-dark)'·}}·/>␍` with `⏎··········className=\"cart-input\"⏎··········placeholder=\"Kullanıcı·Adı\"⏎··········value={username}⏎··········onChange={(e)·=>·setUsername(e.target.value)}⏎··········style={{⏎············padding:·'12px·15px',⏎············borderRadius:·'var(--radius-md)',⏎············backgroundColor:·'var(--bg-dark)'⏎··········}}⏎········/>`",{"range":"21913","text":"21914"},"Replace `·className=\"cart-input\"·type=\"password\"·placeholder=\"Şifre\"·value={password}·onChange={e·=>·setPassword(e.target.value)}·style={{·padding:·'12px·15px',·borderRadius:·'var(--radius-md)',·backgroundColor:·'var(--bg-dark)'·}}·/>␍` with `⏎··········className=\"cart-input\"⏎··········type=\"password\"⏎··········placeholder=\"Şifre\"⏎··········value={password}⏎··········onChange={(e)·=>·setPassword(e.target.value)}⏎··········style={{⏎············padding:·'12px·15px',⏎············borderRadius:·'var(--radius-md)',⏎············backgroundColor:·'var(--bg-dark)'⏎··········}}⏎········/>`",{"range":"21915","text":"21916"},"Replace `<div·style={{·color:·'#ef4444',·fontSize:·'13px',·textAlign:·'center'·}}>{error}</div>}␍` with `(⏎··········<div·style={{·color:·'#ef4444',·fontSize:·'13px',·textAlign:·'center'·}}>{error}</div>⏎········)}`",{"range":"21917","text":"21918"},"Replace `·type=\"submit\"·disabled={isAutoLoggingIn}·className=\"btn·btn-primary\"·style={{·height:·'45px',·fontSize:·'16px',·marginTop:·'10px'·}}>␍` with `⏎··········type=\"submit\"⏎··········disabled={isAutoLoggingIn}⏎··········className=\"btn·btn-primary\"⏎··········style={{·height:·'45px',·fontSize:·'16px',·marginTop:·'10px'·}}⏎········>`",{"range":"21919","text":"21920"},{"range":"21921","text":"16943"},{"range":"21922","text":"16943"},"Replace `·type=\"button\"·onClick={()·=>·(window.api·as·any).exitApp()}·className=\"btn\"·style={{·height:·'40px',·backgroundColor:·'#ef4444',·border:·'none',·color:·'#fff',·fontSize:·'14px',·marginTop:·'2px'·}}>␍` with `⏎··········type=\"button\"⏎··········onClick={()·=>·(window.api·as·any).exitApp()}⏎··········className=\"btn\"⏎··········style={{⏎············height:·'40px',⏎············backgroundColor:·'#ef4444',⏎············border:·'none',⏎············color:·'#fff',⏎············fontSize:·'14px',⏎············marginTop:·'2px'⏎··········}}⏎········>`",{"range":"21923","text":"21924"},["21925","21926"],{"range":"21927","text":"16943"},{"range":"21928","text":"16943"},{"range":"21929","text":"16943"},{"range":"21930","text":"16943"},{"range":"21931","text":"16943"},{"range":"21932","text":"16943"},{"range":"21933","text":"16943"},{"range":"21934","text":"16943"},{"range":"21935","text":"16943"},{"range":"21936","text":"16943"},{"range":"21937","text":"16943"},{"range":"21938","text":"16943"},{"range":"21939","text":"16943"},{"range":"21940","text":"16943"},{"range":"21941","text":"16943"},{"range":"21942","text":"16943"},{"range":"21943","text":"16943"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\bilal\\SARACAPP\\SARACAPPV3\\app1\\src\\renderer\\src\\App.tsx:71:7\n  69 |     const token = localStorage.getItem('pos_token')\n  70 |     if (token) {\n> 71 |       setIsLoggedIn(true)\n     |       ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  72 |     }\n  73 |   }, [])\n  74 |",{"range":"21944","text":"16943"},{"range":"21945","text":"16943"},{"range":"21946","text":"16943"},{"range":"21947","text":"16943"},{"range":"21948","text":"16943"},{"range":"21949","text":"16943"},{"range":"21950","text":"16943"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\bilal\\SARACAPP\\SARACAPPV3\\app1\\src\\renderer\\src\\App.tsx:78:5\n  76 |     if (!isLoggedIn) return\n  77 |\n> 78 |     setIsLoadingData(true)\n     |     ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  79 |     \n  80 |     const handleOffline = () => setIsOffline(true)\n  81 |     const handleOnline = () => {",{"range":"21951","text":"16943"},{"range":"21952","text":"16943"},{"range":"21953","text":"16943"},{"range":"21954","text":"16943"},{"range":"21955","text":"16943"},{"range":"21956","text":"16943"},{"range":"21957","text":"16943"},{"range":"21958","text":"16943"},{"range":"21959","text":"16943"},{"range":"21960","text":"16943"},{"range":"21961","text":"16943"},{"range":"21962","text":"16943"},{"range":"21963","text":"16943"},{"range":"21964","text":"16943"},{"range":"21965","text":"16943"},{"range":"21966","text":"16943"},["21967","21968"],{"range":"21969","text":"16943"},{"range":"21970","text":"16943"},{"range":"21971","text":"16943"},{"range":"21972","text":"16943"},{"range":"21973","text":"16943"},{"range":"21974","text":"16943"},{"range":"21975","text":"16943"},{"range":"21976","text":"16943"},["21977","21978"],{"range":"21979","text":"16943"},{"range":"21980","text":"16943"},{"range":"21981","text":"16943"},["21982","21983"],{"range":"21984","text":"16943"},{"range":"21985","text":"16943"},{"range":"21986","text":"16943"},{"range":"21987","text":"16943"},{"range":"21988","text":"16943"},{"range":"21989","text":"16943"},{"range":"21990","text":"16943"},{"range":"21991","text":"16943"},{"range":"21992","text":"16943"},{"ra